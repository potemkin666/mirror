  will-change: transform;
}

.f̞̣̞̮̗̟̝̓͊͌̓͂̔̏̚ó̴͆̿̈̑͊͆͆ǧ̵̶̵̛͉̰̼̭̩̈́̇͂͋͋̀̒ {
  touch-action: none;
