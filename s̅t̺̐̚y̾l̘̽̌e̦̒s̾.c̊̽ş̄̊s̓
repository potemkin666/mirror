/* ༹̠͇͌ᚎ̗̏̎̉𒀍̠𒁊̜̍̀ᛕ̡ᛩ͈𒀿͉༕̭𒀛̥̲̋̚ᚑ͍̝̜̾ᚅ͉ ͋͌́̕ᚙ̨̦̹̏༳̢̠͉͈ᚓ̤𒁊̧̗̳̓᚛̢̳̼ */

*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

:root {
  --silver:      rgba(185, 198, 220, 0.65);
  --silver-dim:  rgba(160, 172, 198, 0.30);
  --glass-dark:  rgba(10, 12, 18, 0.92);
  --ink:         rgb(2, 2, 5);
}

html, body {
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: var(--ink);
  -webkit-font-smoothing: antialiased;
}

/* ༔̞̊𒀢̫͍̔༕̰ᚊ̦ᛮ̡̘༷̍̅́̿ᚵ̹̣͌̇༼̟̈̇𒁂̐ᚙ̚༧̗̹᚜̯̀͆༛͌༠̦̘̫́ᚢ͆ᛝ̧̺̭̈༬͌ᛧ̹̮͇̪༅̗͌༫̞̔̚ᚙ̡̤̐ᛖ̤̗̹̏ᚓ̞̮̱̑𒀯̻̰ᚕ̹̒ᚾ̜ཇ̻̖̉ᚗ̥̿̋ ̮̪̪̄𒀼̎̽ */
body.js-cursor {
  cursor: none;
}

/* ༰̙̄༸̒̚ᚠ̫ང̽ᛑ̠͍̌̂𒀢͇ᛊ̫ᚩ̢̓𒀛̏ᚐ̪𒀳̂̑ᚘ͌̂ག͉͆̆𒀝̥̠̒༯̫͎͆𒁇̀̓̔̂ᛔ̮̍́𒀁̣͆༨̑̉ */

#glass-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  display: block;
  z-index: 0;
  pointer-events: none;
}

/* 𒀃̰̂́ᚳ̱̏̾𒀰̳̽̉ᚋ̈́̔̾ᚲ̜̟̗̂᛬̘̓́̃ᚋ̚༗̹̦̗̃༻̠༉̧ᛍ̳ᛍ̢̬̭̊༉̑𒀟̭̤̻̚ᚒ̬̈ᚆ̧̡̭̿༨͎̓̏̀ᛤ̭̋͆ᛢ̢͉̜᚛̪̈́͋̐𒀁̟̤̯̦༱̘͍̍̆ᛟ̿༎̨̡𒀴͋ᛝ̒𒀲̞̀͊̚𒀛͇𒁃͍̅̈ཅ̪̞༸̙̋̅ᚒ̼̺̎͊་̓ͅ༑̽͂ᛤ̻̩͋̚ᛀ͂ᚓ̼̉ᛏ̊༦͇ᚚ̢͍̑̊ */

#mirror-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  display: block;
  z-index: 1;
  /* ༉̧̲̯̆ᚒ̗̞̎𒀰̥༰̐ᚿ̬𒀟̨͉ᛁ̖̠̓̚ᚪ͎̽̋̃ᚱ̠͍𒁇̥̂̀̒༭̬͈̾́𒀞̾𒁊̹͇̋ᚍ̬̂̆༅̰̑̀།̜ */
  mix-blend-mode: screen;
}

/* ༨̞̉̃ᛕ̓̊̌་̣̘𒁁̨́༳̒̉ᚚ̢̮̒̓𒁌̳̿ᚷ͇̋̑ᛋ̪̻́ᚰ͂̉𒀢̺͊ */

#vignette {
  position: fixed;
  inset: 0;
  background: radial-gradient(
    ellipse 68% 65% at 50% 38%,
    transparent 0%,
    rgba(0, 0, 0, 0.35) 55%,
    rgba(0, 0, 0, 0.80) 100%
  );
  pointer-events: none;
  z-index: 5;
}

/* ཇ̫̈̌̃𒀒́𒀢̻̬̄ᛂ̘ᛯ̪͉̔ᛣ̆̐༸̽ᚅ̂༏͇̀́̆༡̓̐𒀤̨̭̗𒀟̳̉ᛊ͇͍̽̌༶̡͈̂ᛟ̺̜̈́̆ᚐ̡̡̙͇ᛟ̠̆̎ᚋ̆ */

#text-overlay {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 20;
}

.text-fragment {
  position: absolute;
  font-family: 'Georgia', 'Times New Roman', serif;
  font-size: clamp(0.60rem, 1.1vw, 0.80rem);
  font-style: italic;
  color: rgba(182, 194, 218, 0.00);  /* 𒁎̭̜̅𒁂̟̳͇̐ᛅ̔͋̉༞̢𒀳̦̫̃ᚐ̪̝̣̔༏̻ᚕ̢̬̓̐༟̋ᛊ̣̮̄ᛦ̩̃ᛂ̯̌ᛝ͇̱̝͌༖̣ᚌ̯ᚗ̐̃́̿ */
  letter-spacing: 0.10em;
  line-height: 1.70;
  max-width: 220px;
  transition: color 2.2s ease;
  pointer-events: none;
  user-select: none;
}

/* 𒀊̫͆̅́ᛃ̒̐ᚐ̤͉̾̿ᚎ̜͈͌ᛐ̘̝͂̊𒀐̡̲̓ᚰ̠̝̈́̍ᚓ̝̐͆̚ᚦ̙̇𒀂̨̄ */

#landing-veil {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1.2rem;
  background: rgb(1, 1, 3);
  z-index: 100;
  transition: opacity 2.4s ease;
}

.mirror-title {
  font-family: 'Georgia', 'Times New Roman', serif;
  font-size: clamp(2.2rem, 5.5vw, 3.8rem);
  font-weight: 300;
  letter-spacing: 0.50em;
  color: rgba(200, 212, 232, 0.62);
  text-transform: lowercase;
  padding-right: 0.5em; /* ᛊ̭̘̋̏ᛗ̕ᛙ́̑̀̀༧̟̱༵͆𒀚̪̮̋𒁅̡̹̦༨̙ᛛ̾̍̂𒀯͉༽̈́ᚃ̳̽́̚ᚖ̨̜ͅ༛͆ᛮ̜̭̓̏ᚆ͉̭𒁉̩̈́𒀟̞ᚐ̨͊ᚘ̦̚ᚘ̳̆̅̈𒀑̧̼́ᚒ̡ᚐ̙̞̀̽𒁏̢̲ᚃ̩𒀞̀ᚉ̟̑ᚈ̢̱̐ༀ̤͂̒ᚅ̰̀̇̾༡͂ᚈ̒̕ག̢ͅᛣ̌̑ͅᚽ͇ᚐ̨̨̍̐ᚴ̲ཀ̃͊༻̄̍ */
}

.invitation {
  font-family: 'Georgia', 'Times New Roman', serif;
  font-size: clamp(0.65rem, 1.3vw, 0.82rem);
  letter-spacing: 0.30em;
  color: rgba(155, 168, 196, 0.38);
  font-style: italic;
  animation: breathe 4.2s ease-in-out infinite;
}

.landing-hint {
  font-family: 'Georgia', 'Times New Roman', serif;
  font-size: 0.60rem;
  letter-spacing: 0.25em;
  color: rgba(120, 135, 165, 0.22);
  font-style: italic;
  position: absolute;
  bottom: 2.8rem;
  animation: breathe 5.6s ease-in-out 1.4s infinite;
}

@keyframes breathe {
  0%, 100% { opacity: 0.35; }
  50%       { opacity: 1.00; }
}

/* ᚉ̦̫͇̈༇̙͇́͂𒀋̮̆̉ᚏ̍̄̐ᛎ̒́̂ᛏ̈́̿ᚄ̅̌𒀲̼ᛠ̻̻ᚏ̱̈́༒̝༛͇̚༕̭̭̓𒀥̦̠̄̏ᛥ̖ᚵ̞̍̀་̊͂́̈𒀂͉̰̑̂༆͇̘̤̀𒀗̡̻̼̍༾̽̍ᚻ̔̈́͋̕𒀼̼̿̓𒀣̝̂༎́̕ᛇ̻͈̻̑༕̐̒̀𒁏̮̈́ᛝ̳́͂ཀ́ᛄ̻̼̆̉༝̊ */

#controls {
  position: fixed;
  bottom: 1.6rem;
  right: 1.8rem;
  z-index: 50;
  display: none;          /* ᚜̙ᚠ̃ᛛͅ𒀧̫͉̯̈́ᚂ̒͂̄ᚘ̥̔̿𒀈̙̜ᚬ͎𒀪̻̭𒀊̖͉̔̂ᚁ̝̘͈̅𒁃̡̭͆ᚯ̽ᚸ̗̘̇̓ */
  flex-direction: column;
  align-items: flex-end;
  gap: 0.45rem;
  opacity: 0;
  transition: opacity 0.7s ease;
}

#controls:hover,
#controls:focus-within {
  opacity: 1;
}

/* ᚄ͈̩𒀒͈̠ᚐ̢𒀚̞̼𒀨̥̘̉̔ᚊ̚ᛠ̪̂᛭̩̒̇̃ᚘ̝̓ᚓ̨͈̆̾𒀭̢̘̀̚ᛆ̦ᛰ͋ᚹ̮̹́͌ང͍͍̲𒀧̡͎̞̉ᚅ̮̓༦̨͎͊̽ᚑ̌̉𒀲̝̬̀ᚱ͂̀ᚏ̥̫̋ᚈ́͌ᚪ̘̅ᚳ̢̞̍̔༥̩̆༟̗ᚔ̾͂༇̮̋̋̾ */
#controls::after {
  content: '·';
  position: absolute;
  bottom: -1rem;
  right: 0;
  font-size: 1.4rem;
  color: rgba(160, 175, 205, 0.25);
  pointer-events: none;
  opacity: 1;
}

body.awakened #controls {
  display: flex;
}

.ctrl-btn {
  background: none;
  border: none;
  color: rgba(155, 170, 200, 0.42);
  font-family: 'Georgia', 'Times New Roman', serif;
  font-size: 0.68rem;
  font-style: italic;
  letter-spacing: 0.18em;
  cursor: pointer;
  padding: 0.18rem 0.5rem;
  transition: color 0.4s ease;
  outline: none;
}

.ctrl-btn:hover,
.ctrl-btn:focus {
  color: rgba(210, 222, 240, 0.88);
}

/* ᚍ̣̣̉́𒀠̢̀̔𒀧̔𒀓͊ᛟ̼ͅᛚ̪͊ᛓ̢̹̓𒀰̻̻̏ག̤͎𒀂̠̏ᚑ̤̀̒̾༨̖̀̅̌༭̂̀༊̡̜̯̄༊̋̎̎̕ᛒ̰̃̃𒁍̟̔ᚐ̟͍́ᚮ̀͆̏̕༳̓ ̼̠𒀇̡̢̎̑ */

#diagnostics {
  position: fixed;
  bottom: 1.2rem;
  left: 1.2rem;
  z-index: 50;
  font-family: 'Courier New', 'Lucida Console', monospace;
  font-size: 0.58rem;
  line-height: 1.65;
  color: rgba(140, 160, 188, 0.55);
  background: rgba(0, 0, 0, 0.68);
  padding: 0.85rem 1rem;
  max-width: 300px;
  border-left: 1px solid rgba(100, 120, 155, 0.18);
  pointer-events: none;
}

#diagnostics[hidden] {
  display: none;
}

/* 𒀬̧̭̅ᚶ̯ᚈ͈͆̓𒀼̰̞̋ᚇ̥̥̣̿ཆ̂ᛰ̥ᚐ̫༆̲̒̐༭̰̀༳́̏̈́ᚯ̧̟̎ ͎̻᚛̺̊ᚉ̃̿̓ᚕ̬̎̔༸̜ᚰ̫͈̄̚𒀸̼̑𒀮̪̗̈̄᚜́̑᚛̤̏̆͂༇̕༐̡̭̅ᚋ̯̱̘̋𒁄͍̱̘͊ᚱ͆𒀿̍༡̒͆ᚇͅ𒀉͎̆̐̚ᚳ̣̓ᚠ͈̄̏ᚢ̲͆̔ᛨ͍́̇̄᚜͉̏̿̇ */

#cursor {
  position: fixed;
  width: 5px;
  height: 5px;
  background: rgba(205, 218, 238, 0.55);
  border-radius: 50%;
  pointer-events: none;
  z-index: 200;
  transform: translate(-50%, -50%);
  transition: width 0.15s ease, height 0.15s ease, opacity 0.3s ease;
  mix-blend-mode: screen;
}

#cursor.hovering {
  width: 3px;
  height: 3px;
  background: rgba(230, 240, 255, 0.80);
}

/* ༠͋͆ᚑ̀ᚕ̈༽͎̞̋̋𒁄̝̲̼̝𒀒̯̩ᛋ͇͊̑𒀨̦̫༨̾̆༰̰ᚈ̢̏̎𒀤̧͇̮ᚖ̧̬̼̐༉̫̃̄̔𒀴̻ᚊ̯̯̗̃ᚮ̈́̈́̋͆ᛎ͇̬̬𒀝̣̱̋ᚹ͋ᚴ̔̐𒀄͌ᛤ̝͈̽̚ᛑ̟̿̑ᚈ̒̓ᚓ̂̔༲̙͍̬ᛙ̗͍̉̿𒀨̰̂ᚉ̮̦̈́̾ᚰ̢̣̓̓𒀐̫̀̅ᚉ̋ */

@media (max-width: 768px) {
  .text-fragment {
    font-size: 0.68rem;
    max-width: 175px;
  }

  #controls {
    bottom: 1rem;
    right: 1rem;
  }

  .mirror-title {
    letter-spacing: 0.35em;
  }
}

/* ᚃ͈̹̈́𒀪͉̺̎𒀡̼̾̂᚜̱ᚕ̩̌̈̚𒀘̗̩̹̖༈̢̤͂̐ᚊ̼̜̝̄ᚁ̠̣̀́ᛡ̬̚ᚖ̟̐̆̚𒀻͎̲̰̃ᛞ̇𒁍̂𒀕̥༙̟̦̊̿̍̚̚༅̠̋༟̣̫̀̅𒀓̲̌𒁆̦̗̑́༴̣༲̗͇͍̀𒀄̤͇̾͆ᚷ̡༵̭̾̔̏𒀾͇͆༻̌̔ᚹ༹̞̜̍༐͌̂ᛞ͈̩͍༽̠ᛗ̲ᛖ̭ᛔ̟̓ */

@media (prefers-reduced-motion: reduce) {
  .invitation,
  .landing-hint {
    animation: none;
    opacity: 0.5;
  }

  #landing-veil {
    transition: none;
  }
}

/* ᛉ̘͇̬𒀶̢̏̀༂̱̰ᛊ̈༺̡̨̤𒀮̱ᚬ̄̉ᚄ̞̓ᚕ̃𒀠̹̐𒁏̩̘̌̎ */
/* ༃̥̮̿ཇ̄ᚅ̠̜́ᚍ̙ᚖ̝̰ᚊ̙̺̃ᚮ̌̈́͋𒁉͈̼༨͎̑̓ᚎ̗̊༎̚𒁊̼̓ᚈ̞̓༌̘̣̀་̙̝̉̕𒀱͍̺̃𒀯̅𒀌̰̎̔͊𒀿́ᚇ̲͉༘͈̓͊́̈ᛀ͂̔ͅᛙ̠̳ᚧ̱̆̔ᚓ̙𒁏̨̬̝̎᛭̀༔̣̣͋𒀎͉͇̲̥ᚁ͊̿᚜̀̿𒀂̃᛭̨̮̑̉𒀽̊̌͆𒁍͎ᚇ̲𒁂̱ᛩ̤̼̺̿༛̙͍͂́ᚑ̝̄ */

@media (prefers-color-scheme: light) {
  :root {
    --silver:      rgba(165, 158, 148, 0.65);
    --silver-dim:  rgba(145, 138, 130, 0.30);
    --glass-dark:  rgba(18, 16, 14, 0.88);
    --ink:         rgb(12, 11, 10);
  }

  html, body {
    background: rgb(12, 11, 10);
  }

  #vignette {
    background: radial-gradient(
      ellipse 68% 65% at 50% 38%,
      transparent 0%,
      rgba(10, 9, 8, 0.30) 55%,
      rgba(10, 9, 8, 0.75) 100%
    );
  }

  .text-fragment {
    color: rgba(155, 148, 138, 0.00);
  }

  #landing-veil {
    background: rgb(11, 10, 9);
  }

  .mirror-title {
    color: rgba(180, 172, 162, 0.58);
  }

  .invitation {
    color: rgba(140, 133, 125, 0.35);
  }

  .landing-hint {
    color: rgba(110, 104, 96, 0.20);
  }
}


/* ᚃ̪́ᚆ̀𐤇̩𐍁̕ ̀ᚾ̟̯̓̂𐌿̒༮̲̊ᚴ̑𒀣̗̔͋𐌴̭̀𐌶̦𐌴̇𐤛̮ᚴ̙̫̐̈𐌺̞̖̋ᚯ̪ᚃ̄͂ͅ༿͎͋̀𐤃̗̳̲̈́𐍂̹ᛙ̳̅ᚁ̳̂༠̥̇̓̕ᛩ̤̗̑̔ᚔ̀𐌵̨̲̹༇͉̳̐༼̳̣̠̍༄̀ͅ𐤛̻̏̅̎ᚓ̋̍͌ᛉ̟̃̾ᚗ̟̰̼𐤙̫̋ᚌ̡̱̅̒𐌴̩͈𐤘̀͊ᛪ̹𒁍̨̺̾ */

