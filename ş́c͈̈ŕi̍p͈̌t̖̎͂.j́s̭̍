  // ჹ̭̅თ̅͌ᚔ̭́༑̓ሜ̱ᚌ̠̭̬𒁄͎͇̋̈́༈̤ܓ̡͉უ͇̃̔།̫̾̄ᚴ̩̙̍̕ჱ́̚ჲ̝̯̓̅ᚃ̏ᚿ͉ᚈ̋̓̅ᛥ̳̇ჵ̨̑
  if (env.viewportW > 1600) {
    e.intimacy = Math.max(0, e.intimacy - 0.15);
  }

  // ቈ̱̖̈̀ᚁ̮̾̀ᚷ͈̆̂̈ሾ̧̗̩̝̈̀݊̀̃ܠ͉̕ᚫ̝̹̉ܘ͎̦̐კ͍̋ჺ̓̀̀ͅგ̧̉͋༺̭̱̀𒀑̗̬̲̌ᚃ̨̐̍ሺ̤̊̔̒ᛡ̒̂რ̰̤̈́̊თ̭
  if (env.isTiny) {
    e.compressionY = Math.min(e.compressionY + 0.3, 1);
    e.sovereignty  = Math.max(0, e.sovereignty - 0.2);
  }

  // ᚏ͎͌༏̨ᚒ͇༦̱͆ሱ̢ܓ̩̚ܓ̠̱̀ሢ̙̥ჭ̫̬͋
  if (env.isFullscreen) {
    e.sovereignty = 1.0;
    e.anticipation = Math.min(1, e.anticipation + 0.15);
  } else {
    // ო̖༳̳̦̯ܟ̗̅̔̆𒀸͊ᚊ̍𒀴̨͇́͋ᚼ̝͂̉ܦ༘̝̬̐თ̏̃ქ̗̩̅ܡ̬́̕ͅᚃ̘̑̉ܨ͆ቅ͉̗̀̔ᚄ̦̆̅ᚚ̙̝̉༉̡̜̳̩̽݅ᚙ̯̦̣̓ᛨ̻̇̍̚ხ̣̅̚ᛧ̘̠ͅܨ̝ܙ̪̿ლ̔𒀳̜̚კ̅͂ሚ̐̀́ჺ͇͎ᚔ͈̿́𒀱͎̍̉ᛋ݄̙̾̀̄̊ͅᚓ͍̓̕𒀸̢̟̎̍𒀆͍ܱ̥̗̌̄̌̅
    e.sovereignty = Math.max(0.4, e.sovereignty - 0.15);
  }

  // ᛤ̡̊̓ሡ̜𒀟̞̹𒀽̅̈́ᚈ̼̕ღ͉̘͍̂თ̡̀᚛̲̞̥̐ለ̧ላ̳͈̈ሌ͉̓̾ሾ͌ም͎̦̓̚𒀪̏̋̈́̚ቁ̠͊ܞ̉̇𒀥̢̔̽ე̮̪̠̿ܫ̨̳̫͌ᚴ̤ܒ̧͍͉̱݁̈̀ᚲ̝̦̰̉̓݃̃͊ህ̧̉𒁉̬͊༯̧̞ܻ́̕ሲ̡̨ስ̆𒀆̀ܖ̻̏𒀫̗
  // ܜ̞̖̇̄ܤ̻̟ሬ̤͈́̋ᚒ̨́͆ሔ͉͊̕ᚯ̱̮͎͌ᛣ̹̱̇ሳ̣̦͌͆ሲ̊ቃ̹ሒ̿̉᚛̘̓̋̆ღ̈͌̃̃ᚱ̲̪͆ი́ሸ̩̜̂ሁ̩͍̙̥̬݁̈̌ᚄ̏̓ᚼ̟𒁎̱̦̥͌݃̆͊ཁ̣͎͊ͅᚠ̺̫͋̇ܶ͂́ჲ͎͍̣ሔ̑̐ტ̱̮̰̻̭̖݀́̔ᚍ̐ᚿ̘ᚈ͉̙̯𒀳̫ᚽ̧̧̮͈ܴ̬̀კ͉ვ̳̓̑͌𒁂̪̲̐̿༇̩͋
  // ܔ̠͊̊ᛘ̺́ܒ̭͇̐༨̮̫̐̆ᚷ̄ᚪ͎̱͌͂ᚗ̯
  if (env.touch) {
    // ᚜̧̡͉̲ༀ̘̃̀ͅქ̢́𒀌͇̄ܙ̼̏̽̽𒀋̙̎̓ᚦ̯́̕ܧ̱𒀩̩͉ᚄ̫̀̍ܤ̅͆̏ሀ̤̎༕̧̠̱ܷ͇
    e.intimacy = Math.min(1, e.intimacy + 0.20);
    e.edgeQuality = Math.max(0, e.edgeQuality - 0.10);  // ሦ̨̫ܗ̨͌̔ሄ̐̃̀ͅჴ́̌ܤ̪̦̙̾ᛁ̼̍͋̇ቈ̠̾͂̐ܦ̝̻̺̯ᛆ̳̐ሪ̘̏ህ̧̖̏̚ሎ̭͈͆ͅ𒁄̊ე̼݈̍̃̐̕ც̑̕𒀣̼̰ᚚ̤̯̀𒀰̿ᚃ͇̼͍༏͍̝̠͇ཇ͍̤͋͂𒀖͉͌́̏ ͍̼̚ᛨ͇́̽༌̮͇͌༸̰̍̎ܡ̩̪̉ლ͆ჴ̝̅ܨ̩̍̋𒀥̡̤̒̈́̓ܺ̎ᛀ͈̳𒁎̚༦̳̜̲̍ᚐ̑̂༟͆̃ᛩ̌̚ሀ͆
  } else {
    // ᚑ̙̲̃ᚓ͎ᚁ̽̈́༥͇̳̾̀ᛆ̦͆̾ჰ̗̦̚𒀽̜̈́ͅ𒁄̖̀͆ሟ༹̺̫̃ᛋ̄̓ም̼́̒ሸ̣̋̽̂ܡ̧͉͇ሬ͌̊𒁎̙́༁̜ܼ͉̪͎̿
    e.intimacy = Math.max(0, e.intimacy - 0.10);
  }

  if (env.pointerCoarse) {
    // ሕ̞ሒ͈̜̒ܩ͋ᛪ͇̓ܨ̨͈̑ზ̱̹ᚥ̯̔𒁉̰͊ͅᚪ̺ᚎ̯̤͎́݅𒀐̒̿̐༫̣́༥̘͉̇ም̝ᚾ̮̙̝ܬ̘ᚖ̤̹̰̆༬̺̺͋ჶ̲̈̀̄༄͆ᚂ̗̗̼𒀟̯̓༭̬͇̃ܞ̟̥̍̒݀̏ܛ̿̚ሪ͊̈̊ͅᚦ̳͌̾𒁈̤̞̏̚𒀢̳̭̀𒁍̩͋̈́ᚰ̲̐𒁋̘̄ᚖ̙̩𒀒̎ჴ̝̚̚
    e.specularWidth = Math.max(0, e.specularWidth - 0.10);
  }
  if (env.pointerFine) {
    // ᛗ̣́𒀻͉̕ᛨ̺̏ሢ̜̜̅གྷ̯̳ე̌ᚃ̬̠̖̉༤̨̱ܚ̠͇༵̾̏͋𒀧̱͇
    e.specularWidth = Math.min(1, e.specularWidth + 0.10);
    e.edgeQuality   = Math.min(1, e.edgeQuality + 0.08);
  }

  if (!env.hoverCapable) {
    // რ̪̃ᚚ̨̃ᛉ̦̅̾̔ር̬̲̐წ̨̄̽ᛡ̫͂ჲ̒̓༈̑გ̬̘̉̉ᚃ̼̭̱𒀯̢̟̈̅𒀩̦ჵ̠̻̑᚜̈́̋ܝ̹ჟ̫͍̮ͅ𒁏̳̫̄ᚽ̨̓𒀔̲ᚻ̥̀ͅሒ̳̚༱̯͇̈̕༊̺̋მ̫̳͈̓
    e.anticipation = Math.max(0, e.anticipation - 0.2);
  } else {
    // ჵ͇͈༑̠̰༘̰̲̐͊̓ረ̈̎ჺ̩̰ܼ̞̎̑ᚴ͇͈̯𒁉̪̗̯̎ᚋ̖̙̔ቁ́༉̝̗̒͌ག̡̘̞̒
    e.anticipation = Math.min(1, e.anticipation + 0.1);
  }

  // ቆ̼͈͌ი̤̦̏ܡ͊༬̈̈̀ͅ𒁎̨𒀚̏𒀜̂ͅᛤ͂ᛚ̤̘͆́ህ̝̺̋ᛇ̺ჵ̣̔𒁏̦͌̾ቀ̫ჺ̲̰̽ሯ̢̟̱̓ܙ̭̻ቆ̢ჶ̞͂̇༔̡ხ̡̆ሙ̗̅̀̊ხ̭ჵ̞̻̝̕ჯ͉̰̟̓ሟ͎̋ሺ͇̄̿̋ᛍ̟ረ͉ͅᚈ̺͎
  // ሉ̨ሟ̝͊̀̓ሎ̍̕𒀰̱̣̯̌𒁏̖̬̭̕ᚗ̧̹̌́།̣̂̔༮̟ቂ̪༩̞ᛉ̿̔𒀾̬ ̥༎͉კ̑ᚫ͈̓̑̉ჴ̧̧̣̚ᛑ̗
  // ̣̘݁ᛠ̍ᚅ̒ܐ̭ჩ̹̈̌́༾̔͋̕༫͇ᚉ̗͇̅ሗ̦͇ᚯ͍̻̳̊༚̡ᚥ̣̪̈́ᛙ̢̲͍ሠ̬̾̎𒁋̓̒͊ܢ̹̥͋̐ᚁ̬̋რ̡̆༨̢̝᚜̳̣༆̉̔̈ሂ̙̮̊ܙ̟̪̩̳ᚢ͍̑͊̓ሞ̧̨͉̏ᚴ̭̗̑͋𒀊̙͈̽̿ሡ̘༏̲
  if (env.lightMode && !env.darkMode) {
    // ܑ̭̭̇̔ღ̪́̉ᛙ̣̑̒ܚ̢̻̂̇݀𒀽̡̑ሄ̘͈̾ᚖ̅̕ᛰ̈́ܠ͍̼ლ̡̢̇გ̡ͅ༫̼͋̔͌𒀢̣̓ᚽ͎̱̀ᛨ̢̙̜̋ᚡ͊ܺ̓༫̖͎̀̄დ̳͂̈ͅᚘ̡͉́ͅᚁ̧̝̚༯̖̤ͅფ̿𒀺̅𒁄̓
    e.paletteR = 210; e.paletteG = 205; e.paletteB = 198;  // გ̢̺̋ჺ̬ჷ̊ܕ̡͉̯̖ᚗ̡̫͉̀𒀺̦̔𒀰̿̀̌ܖ́
    e.bgR = 12; e.bgG = 11; e.bgB = 10;                    // ̧̬̻ܵܽ͋𒀾͇̥͇̗𒀀͈̪̈༓݆͉̽͂༐̺̤ᚉ̜̹̩̰ܱ͈̑ܰ̿ͅჺ͍̋ሺ̼̅̃ܔ̨̊̓ͅᚉ̧ሖ̨̳͎݈͇̀̓ͅܭ̞ᛩ̜ᚊ̠̎ᚭ̘ᚷ̙ᚁ̺̜͉̻ሧ̣ᚤ̥̥̉̓༚͎̺̓̑ᚧ̱დܑ̠̗̐̃𒀰̼̇ሀ̪̩𒀘̍̀̎༓̧̥́༗̺̯͋̈ᚪ̬͇̏ͅ
    e.surfaceWet  = Math.max(0, e.surfaceWet - 0.30);       // 𒀋̥წ̢༕̈კ̨͋ቃ̜̆̏ᚆ͉͎𒀱͍́
    e.grainCoarse = Math.min(1, e.grainCoarse + 0.15);      // 𒁋̋̀̕𒀭̺͇̊̿ᚐ̺̯̖ܜ̢̊ᚦ́ᚚ̡̣̀ᛓ̥̋̔ܖ̈́́ᚲ͉̥́ᚚ͎ᚃ̃დ̀ሬ̀̚ᚉ̃͌͋༔̘̎ᚅ̺ཀ̧̼̽ᚘ̺༚̡̭̊ͅᛂ̱̀̈́ᚊ̦̺̂̎ნ̨ሟ̈༱̈́༄̨̳̎ᚘ̫̬̠̐ᚌ̬̃̇̍𒀲̣̭ᛙ̪̈́ܺ͊ܖ̙̘̅̕ᚔ̤𒀖̪̥̒̚ᛨ̳̀
    p.lightWarm   = Math.min(1, p.lightWarm + 0.12);        // ཇ̋𒀟̘̓ხ̺͈̉ͅᚗ̜̫̊𒀉̅̀ᚻ̫͂̽ჭ̌͊̂͂ᚅ̏ᚍ͈̻̎ ̩͍ჸ̝𒀈̄̔༎̦́̾̏ჟ͉ሲ͋̿ᚚ̨̅̎𒀟̋ܡ̮̽𒁃̙̣წ͌პ̱̈́ሙ̻ሪ̥̔͊𒀏̒̽𒀐̨༾̚ͅᚳ̧̢͍̀̎݃̓ᛆܷ̳̭̜̈̉ᚊ̃̓ང̥ܼ̾̒̾ሷ̡͈̖
  } else {
    // ܑ݂̝͂̓̍̔ᚢ̾͊ო̓𒀓͌༦̡̩̿ܬ̪̻̓ሞ̝ᚃ̢̰𒀈́͊̐̋ᚑ̝ფ̅ሪ̰ჳ̂̐༼͇̅̄ᛁ̭წ͊̓༪̞͍̽ᚼ̠̏̾̕ܪ̫ო̮̥༰̥ܡ̀̚༖̰𒀺͉̒͂ͅ༺̗̫ᚆ̗̪ሪ̅̕᚛̢͍
    e.paletteR = 185; e.paletteG = 198; e.paletteB = 220;   // ᚄ̀͌መ͍̬́͌ሃ̩̙͇ფ̨̐͊̓ᚋ̺͆̆ͅܨ̬̓݉̑̐̕𒀫̯̮̲͆ᚗ̪͎̒ܦ̨̠̝̒ܨ̨͌̃͆༊̬̏̾̊݃̈̈̂ማ̗̯̍̚𒁆̔̕ᚕ͇̂̽༸̮ᛃ̣ܠ̨̈̃̽ܝ̧̳̀̉𒀧̨̦ܯ̥̅ᛝ͈̒𒀀͍̊̒ᚘ̅̌ܮ̥̯̓ᚗ͉͋̅ༀ̥̄̿𒀨̻̾̒̕ჹ̣̯̩̼̠̀̈ܶ̍ᚹ̧̇̕ͅᚓ̗̀́ͅ𒀐̲̹̪᛭̚ᚚ̡̢݊
    e.bgR = 2; e.bgG = 2; e.bgB = 5;                        // ༑̌𒀺̭͎̼ͅ༣༵̺̻̃̆͆̔̑́რ̧͋ͅჴ͈ᚈ͉̘̑ბ̢̂́͋წ̩ܱ̯ቃ̧͉̺ᚒ͇̊̔̐ሻ̜̙͊݉ܨ̲̅༄̥̎̌̄༥̦́ᚕ̨̈̍ͅ𒀏̃ͅܭ̝̻̾̈
    e.surfaceWet  = Math.min(1, e.surfaceWet + 0.10);        // ᛖ̧̣̑̚𒀀̩̉ቁ̾𒀟͊̔ᛓ̔ᛌ͇̙͎უ̙͋𒀘̲̆̋ሆ͆ስ͈̻𒀰̇́͆ᛰ̿̔ሉ̻̳́̒ც͂͊ᛄ̻̹ᚯ̌𒀐̖͉͌ᚐ̮̋ܠ̰͇͎̒ᚷ༹̿̃ᚅ̺̦̋ᛕ̪ᛡ̐𒀶̧̪̅༸̏̌ᚅ͋̀ჶ̦͈̂̌ტ̖̫̦݂̱̠̞̓̋ᚂ̅ო̗͋
  }

  // ᚭ̡̓̽გ̬ᚚ̍ლ̌ᛑ̢̗̦͆ᚕ̰̯̅ሾ̔̿ᚍ̧̄𒁃̥༻̡̓𒁌̻̻̘̽ᛚ̰̞̎
  // ܡ̠̘̒̅ჶ̠͋ܦ̐𒀗̠რ̦༟̖̖༸̭̼̟̬͌ܳ̒ძ̪ᚋ̎̚ᛆ̧̖̇ჺ̒̾༒̖͂ჳ̱̃
  // ნ̪ჯ̢͊̿ሪ̟ᛢ̢̹͈݂̹̜̽̎̽༣̱͋𒀻̰͉̪ᚍ̰݈̯̈͂̏𒀘̺̬ሡ̫̋༇̟́̊̉ሩ̂ქ͎̇ཇ̱̯́̓𒀛̾̄ܤ͇̜̉ᚹ͍̫͊͂ᚏ̚𒀮͉ሳ̼̯̺̒ሖ̧̞̈́̔ᛈ͍༠̣ᚨ̬ሌ̣̐᛭̗̰̳̚
  if (env.reducedMotion) {
    e.motionScale   = 0.15;   // ᚯ̳̠̎𒀋̞̀͊თ̳̲̈ܤ̖̂̃ͅჹ̤̐ስ̲͊ᚖ̅ሺ͊̚ჯ̲̹̣̖༸̱̙̽ቈ̭̈́༎̩͍̺ᚂ̦̑̽̓ჟ̨̰̾̊ᚅ̡̮།̲̌̍
    e.idleRestless  = 0.1;    // ም̉̊̀ͅ𒀥̅̒ག̬̩̇̉༲̮̐̃𒀯̭༇̖𒀣̄̄̌
    e.anticipation  = Math.min(1, e.anticipation + 0.2);  // ჵ͈̮̿̌ቆ̗̾ͅሒ̽̑ܪ͈̜̿̽ᛖ͍̯̝წ̼͇̎̐ᚢ̖ბ̧̎ͅ𒀊̇ሡ̎̓̒ሜ̈́𒀵̢̟́̽̓݅̊̂༧̠̔̔̌ᚔ̹̗̔̕ᚆ̜̽ჴ͌ሰ̥͇ᚗ̦͎̆ᚶ̯̅𒀃̔ჲ̻͇̅ᚐ̊͆̓̄ე̭̬̾̑დ̩́𒁊͎ლ̣̤༽̲͍ሊ̒̿ራ̭̍̕ᚐ́̓ሄ̨̦̳̓̇݅̂̃ᚂ̼̌ለ̿ᚯ̙̣̯̈́ᛙ̞̓
  } else {
    e.motionScale = 1.0;      // ܝ̖̻̮̊ሆ͈̬𒀾̙̄̀ᚁ͈ჶ̨͆̈̋ჴ̢̍̓
  }

  // ო͉͊̍༿̢̻̻უ̬̦͂༽̟ᚬ̒ᚅ̯̎༖̻̀̆͂ܛ͈̩͋̾༸̝̰̀̅𒁃̦̒̋ሶܱ̘̥͋̋̊ሩ̖͈̪͂ܮ̐ᚢ̘̔̑̀ቆ̭̅ᚸ̩̑̕ᚊ̢̀̃ም̩̒̃̂ი̟̳̻̆ሀ̢̯̱͇
  // ܯ͂̄ሢ̥̏̕𒁋̐ᛝ̠̈́̊̌რ̡ᚁ̜̑̔̂༖͈͍ͅᛈ̻̼̚༽̤𒀈̫͇̊ᛊ͉́̓༛̮̥݁̓ჟ̢̟͍ტ̘̿̿პ̲༾̨͈͇შ̲ᚙ༹̪͈̿̊̚ც̞̭̌͂ሽ̧͍̽ͅძ̯̖̌̓ለ̉ༀ͍̑ჟ̝̏̈́ሀ̯̿༢͈͉̦̉ܤ̝̠͍̑ቂ̆ܔ͉͇̱ᚆ̮̗̜͈͂ܿ̕ᚏ͍́݁́̌𒀗̻̙̽̓ᚓ̢̡̏̕ᚍ͉̋
  // ᚇ̡̪̲ܸ̀̇́̈༫̜͎͂̏ܝ̪̙̤ᚖ̣̇ܶᚎ̓ሙ̧̌ყ͈ᚍ̡͉̅༞̘̲͍ᚩ̄̌
  if (env.reducedTransparency) {
    e.lacquer = 0.65;    // ᚪ̚ͅჟ̙̖́ܖ̙͍ᚗ̿̆ቄ̩̗݄̻̅̍̌ܗ̧̣̈́̀ნ̘̥̲
    e.surfaceWet = Math.min(1, e.surfaceWet + 0.15);
    e.grainCoarse = Math.min(1, e.grainCoarse + 0.10);
  }

  // ᚇ̚ܓ̜ሃ̡̝̋༖̎ሳ̭̆ܧ̩̾̍̇ቄ̤̘ᛅ̼ሯ̻ᚑ̗ᛍ͈̜̍༴̨͎͇̿ቆ̳ᛛ̡ᚃ̀𒀽͉̙̹̅ሑ̺ܨ͎̣͂უ̧ሆ̢̻̂ჷ͇̏̑̚ༀ̧̻ܷ̏ᛁ̲̀̄𒀞̩͉̇̚ሺ̇𒀵̻̊ཅ̻̓𒀗̄̿ᚐ̫̥̟̄ܶ͆ራ̘̕༚͇̞̈͌𒀸̩̅̒༉̌̓ᚓ̗𒁃̽
  // 𒁇͊ᛕ̰͊̿༚̳̦͊ܮ̭̿༕̎̀̏ჹ̇̌͊̑༐̱̟̂ᚻ̹̀ሉ̭̮͇͌ሼ̙̭̓წ̐̍̅
  // ༲̲ለ̢͎̺𒀶̖̜̆̿ሠ̰̇ᚌ̩͍̃̎𒀆̢̢̮̓
  // ჰ̑ბ̞̿̐̕𒁆̰̈ሼ̝̜͂ሼ̢͇͈̅᚛̬̺̘𒀥̱͋ᚍ̆ሇ̭͌݉̈́͋̑༧̗݂̽̈́͌́།̠̝༶͈͉̓̾ᚨ̝̠̫̂ᚗ̠͆́̕ᚮ̐𒀦̢͇̮ᛐܑ̗̖̌̓𒀼̖̘̇͆ሐ̲̀ሯ̟̏́̕𒀓̘́́͊პ̩̂̈́𒀨͊ሲ̨̙̐ᚭ̱̘̰̎𒀱̥͈͋̔𒀥ܑ̺̱̈ჵ̠გ͆͊̍̒།̧̖̠̔𒀈̄̕
  // ᚈ̱ᚄ̺̐̂̕༞̨̠̞̐ჲ̗̍̚ᚯ̌ᚙ̉̓ნ̲̽༫̹ሻ̆̀გ̓𒀯̻͉͈̃ᚷ̩̙̱ᚅ̟̺̺̆𒀴̮͎̺ܸ̀̎̂

  // 𒀦̡̀̀ሷ̤͉̐ང̣ᚌ̘̙༼̬͈́́𒀃̕̕ᚁ̱̊ሹ̦̼̼͂ჺ̢̝̅̐ᚿ̡ლ̫̀𒀢̌ᚈ̯ᚯ̊͆𒀋̦̻̈́𒀕̠̬̠̇ᚊ̀ჱ̡̀͊ܧ̞̯̚ᚣ͎̜ܾ̃͆̉̉༐̩̤̌̋𒀕̘̑͋̕ܙ̓ᚅ̊̀პ̙̗͋ቇ̳̰̼̝͌ܿᚗ͌̊ლ̨̥̹ᚂ̠ᚶ͉̼𒀱̈́̏თ̋ͅლ͂𒀀̯̈́̂༈̙̖
  e.driftDir = env.isRTL ? -1 : 1;

  // ჷ̝̝ܹ̮̥̀̿ᚤ͍̿ᛕ̚ሰ̯̀᚛̬𒀆̈́༄ܼ̥̽̓ܜ̙̏𒀚͇ᚎ̱͉݈̠̂ᛗ̧̜͍̓ᚔ̺̇̀̔ᚊ̜̒́ძ̭͈̾̚ܨ̫̱̖̑ძ̝ܹ̂̽̐͆̂პ͇̘̈́̃ᚑ̆ფ̧͉̩̿ሟ̡ቆ̫̀̿ܯ̀ჟ̩̀̓̐ሙ̗༞̟̙̐̋
  // ܫ̋ܺ̀̍̕ͅሦ̥͇̀ჺ̬ᚌ̥ሻ༹̭͎͋̾̽́̄ͅ༮̊ሙ̫̬̮̚ሲ̤̅𒁈͋̌̕𒀫̦̼̟ᛑ̢̂̒གྷ̤̹̋͋᚜̺༛̒ሳ̖̤͍̓ძ̧̌ܽ̂̀̚ყ̩̼̰̪ᚱ̧͎ܐ̠͈𒀂͆ლ̖̲̎̈́ᚎ̥̼̌ᚭ̄̃́𒀙̦̫̚ཁ̞̀̾ყ̻̬̋𒀛̤̹̚ሻ͊༯̟ᚉ̙̑͌ᛂ̄༰̈̏̀ͅძ̩͉̃ᚅ͎̕
  // ܤ̠̺́ჩ̰̓̀̓ᚨ̿̓̔ᚄ̆ᛡ̜͊ა̂͂́ሕ̒̓ᚌ̠̪̔ᚧ̜̈́͆ܩ̧̯̦ܞ̺̾ᚃ̝ჱ̫̤̚༓̡̺᚛̣̹̎𒀖̖̙ܻ̍̊ᛖ̗̬ᚔܴ̘̅̇̀͋̏𒁁̎̎თ͋͌ᚃ̺̞̼ቄ̽ᚦ̖͈̎𒀠̾ყ̑̔𒀯̟̓̍ሆ̢̦̠̣

  // ̼ܺᛡ̿ܬ̘༻̀̎̓̑ᛏ̉ܚܻ̼݆̜̙̪̊́́̒͂̀ნ͈̒𒀓̧̜̞̣
  // ᚚ̍̑ሢ̯̦̣ͅᛃ̿̒̌̊ሙ̍̅͆ᚋ̜ሬ̼̥͆̕ᚒ́͌̀༌̣̾༜͎̰̍ᛆ̱̱̏̉༰̽𒀆̈́༆̫̺̘͆ჴ̥̕ܕ͎̊̏ჸ̨̘ს̏༎༹̼̟͉̂̀̀̔ზ̧̅̌͊ᚃ̜͍̽̿༬̢̰͎̪ფ̅ለ̨̦̋̓༾̗͍̈́ჺ̻̅ფ̹̞̹̺ᚿ̭̈́̆̌ᚦ̡ᚦ͉̽̆𒀎̗ᚂ̺̘̄ᚙ̲̑̑
  // ᛭̧༆̈́ჭ̞̌̃̉༎̀უ̻༮̓͆̊ܫ̒͆ჳ͇͉̈̂ᚒ̆̀̂̎ሠ̝̱̚𒀰̀̆̕ང̡́͌ხ̥༿͇̖͆̇ሜ͆̚ͅᚲ̦ვ̬̇̚ᛞܑ́̾̒͌መ̻́͆̈́ᛋ̩̓༎̋̾͂ͅᚑ̲̅̃̕ሆ̃͊ᚥ̞ᚃ̲̿ხ̧̼͂̔ር̋̒̕༛̞̏́̄ܧ̡̰͉̉ᚔ͉̩͆̀༆̠͇ᛄ̭̿̕ჰ̮̝̽ሔ̝̳̭̽ᚌ̧᛫̩̙̀̾̍݉̑ᚸ̌
  const cores = env.hardwareConcurrency || 2;
  const mem   = env.deviceMemory || 4;

  // ᚥ̠̅̎𒀵̔̆͆ቇ̬̯̂͋ჯ͌͆̑̆ᚪ̳𒀤̒𒀓̢̦͆ሹ̝̹
  e.secondaryEyes = cores >= 8 ? Math.min(3, Math.floor((cores - 6) / 2)) : 0;

  // ༽̎ᚇ̡̼̭̀ᛕ̩͇ܚ̠̏შ̰ܸ̬ე̳̓̈༸̪̼̀̒ረ̪̗̀༰̯̀ᛕ̓͌̾ሒ̨̲̓̓𒀢̤༜̺̤̩̆
  // ᚣ̫̍ი̀༉͇̰̀̒𒀍̡̗̜̍𒀦̜ܱ̥̍͆᚛̥̏̓̕ᚆ̈́̆ᚋ̢̞̈́᚛̻̔̏̈༁̘̃͌̎ཇ͉̲̰͊༸̙̳ᚇ̳̳̰̦̼̇̓݉ܧ̧̲༙͉̹̽̔ሷ̫̩̆̔ჲ̣̖̂ሤ̭̎̀̽༎̙̙̖̽͂݃́̈̏𒀒̖̗̊̇ᛋ͊́ܺ̑̾ͅሷ͆͂𒀿̦́ჭ̹͉̬̈́ሧ́̐ᚹ̪̏̚ᚓ̎̾ჷ̯̗͊ᚍ̙̌̈́ᛎ́ͅᚓ̻ჯ̪̀̌̑ܚ̡̣̺
  if (mem >= 8 && cores >= 6) {
    e.shardDensity = 1.3;   // ܒ̨̯͉͎ჟ̎༨̮̩̥̈́𒀇̡͍̺͋ზ̘̓𒀡̯̂͊ሤ̖ܸ̈́ང̱̹༡͎͉͇̇ᚧ̲̪́͌ე̱̓̈ͅᚑ༘̊̾̎̉ܟ̕ᚁ̟̘ᛠ̙̞ჟ̰̺̇ᛰ́ᚃ̫ሂ̥ᛐ͆̊ቆ̳̙͋̚უ̑͂̈ܬ̓̀ᚅ̗͌̑༳̖̯͌ᚫ̉ܲ̆̍𒀣̗ჶ̖̉̎𒀒͊̏ᚙ̚𒀝̨̱̥̣ბ̹̗͂͌
  } else if (mem <= 2 || cores <= 2) {
    e.shardDensity = 0.7;   // 𒀢༹̝̖̭̉̈́𒀱̂ܛ̺̞̗̔გ̹̽̎𒀰̤̰̊𒀓̕𒀤̙̲ᚁ̜͉̋ᚗ̺̀ჭ̩𒀏͂̔̍̚ტ̠༷͉͇̉ძ̮̩̐́ᚗ́ܵ̀̀𒀄̢͂̎᚛̖̼̐ܬ̱̈̇̓ᚍ͌ᚆ͊̀ᚹ̄͌༿̓ᚇ̲̥༷̀̓̚ᚉ̧̗̈́ᛆ̨̃༧́ᚬ̬͊ᚂ̪̄᛭̒ტ̓́ᚇ̜̒𒀶̤́𒀊̉ᚉ̧͌̎
  } else {
    e.shardDensity = 1.0;
  }

  // ჰ̧ჯ̩̔̔ܶ̾͆̂༲̫̅ቈ̧̟̜̈́ჷ̜𒀆̡̩̠ᚐ̧̘͍ሣ̬̖́̊ᚔ͍̞̈ཀ̙̬ᚷ̓𒀻̎́ᛪ̦̱̀͂ᚈ̳̗͋̀ᚄ̨͍́𒀏̄ሌ͌ᛇ̯̹͊ᚌ̗̗ሯ̤̞ሹ̹ሥ̧༔̗̾̃ᚘ̜̇༽̻̯̓𒀈̌ᛖ̀
  if (env.touch && env.viewportW < 900 && mem <= 4) {
    e.shardDensity = Math.min(e.shardDensity, 0.75);
  }

  // ჩ̤ͅᚙ̗̖͍ვ̓̀ሕ̩̾ᛗ̄̿༿̞͂ͅ𒀅̩̔ህ̠ܝ̳͇̄༐̮̽̔̽ჵ͋ᚠ̣̖̗̥ቄ̢̙̥̈ᛥ̡ང͍̇ᚍ̧̧̯༚̙͊́𒀭͉̜ᚄ̱̾̂ᚇ̦̈ᛏ̯͊̓̽ሷ̀ሲ̊̀̀ᚂ͍ᛄ̰͍͌ܩ̦́͆ላ̦ܝ̲͂𒀼̀̎ᛝ̮ᚑ̱̯ܥ̠ს̐̾̔ܧ͇̱ܔ̮̖
  // ᛠ̻ܭ͈̃༊̡̪̇ܓ̃́ᛋ͈̳̣̄༔̝̳͆̐ჺ̖ᛇ̘̽̉ሥ̦̑͆͊ᚚ̤ሠ̧݈̓̇̕ᛂ̬̰ᚨ̭̿̿̚𒁉͇̽̏𒀅̢ᚴ̋ራ̤͆́̂𒁊͎ჰ͉́𒀾̮̬̿ܿ̒͊̚𒁁̢ሧ̊̚
  // ܫ̪̩̈̓ᚌ̳̐̋𒁋̺͂̓̚𒀵̩͈̘ᚆ̜͂ᚷ̢̬̣̾ሞ̢̦̠̻̠̋̆̉ܵ̓݀ნ̟́̔̑ᚉ̯ሏ̀ვ͈̦̥ሷ͇̽́̀ᛓ̨̾ᛑ̩͈̋༼͎ᚌ̟̍ᚍ̘̀́̇ܖ̯ሽ̯̍𒀮̺ჸ̦̑ნ̭̽ჷ͌̄̉༤̣́̽͆ሐ̊𒁄̔ᚥ̩͂̋ᛁ̍ᚉ̲̓͌̕
  // ი̮͊უ̰͊͂͆ܙ̀ᛨ̡ᛛ̆ሟ̩̝́ჵ̧̩̀̊ܖ̈̃̾ܖ̱̜̔ს̺̹ܴ̰ͅሱ̥̥̅ჴ͇̅̋͆༮̭̃͊༳̩̞̊̒ნ̈𒀳̧̭༙̫̟̒ᚚ̰ხ̭𒀰͎͍რ̩̈̎ს̺͋͂ᛗ̙̙́ሷ̤̑͊̄ᚗ̪̀͌𒀪̼̌̌̆ܘ̫̃ሆ̲̣́̈́༤̧̟̥́ᚯ̚̚ᚕ̼̔͌᚜̰̆ᚎ̒̾ᚗ̱̓̇͌ስ̆͂𒁊͂̚შ̫̾რ̬̹̈́̚𒀌̮̇
  // ༌̮̙̫̽̽݉́̾ᚂ̖̠̙̯ᚑ̨𒁃͈͈ჴ̻̦̳დ̨̖̖̀݅𒀷̟̥̿̕ᛐ̪̫̑ო̮ᛈ̺̐̐̂ᚡ̓𒀅̟̤̓́ᚹ̻მ͉ჭ͍̬̒ᚃ̗ሟ̎
  if (env.touch && env.orientation === 'landscape') {
    e.compressionY = Math.min(1, e.compressionY + 0.2);  // ᛌ̢̯ᚓͅგ̾ᚋ̨̼̱̏ᚚ͂༠͍͍̜༒̲̌ܖ̼ᚖ̤̯͆ሁ̥̭̲ሱ̝̟̺ა̨༾͍
  }

  // ᚜̻̠̎᛬͇̣ᛄ͇́ᚍ̺̔͋ჳ̼̼̒ᚮ̤̒́ᚉ̯̮̩̒ሼ̺̺̓̂༛̳̋̅ͅნ̻̕ᚏ̺𒀸̡̟̜͉݉̆̇ማ̳ᚚ̲͆̂̅༻̢̹͇ቂ̝̈ლ̜̼̂̍ሗ͎͈̃̊ܕ̓̎ზ̮̥̂̕ᛔ̄̇̿͆
  // ჲ̗ჶ̢̫̅ቀ̬̳̿᛬̯̪̹𒁎̆͂̚ᚚ̫̍ሻ͇̍̈𒀛͉̤̻ሉ̢̠̾́ቅ̧̣ܾ̗̃̄͊̚ᚕ̤̯̃ქ̖͎̀ᚍ̀̏ᚵ͌̾̓̊༴̣̓̏̀ᚒ̼̉̓̊𒀝̂̇ᚖ̋གྷ̢̒ͅᚬ̦̰̓͋
  // ܡ̧̢̈̎ᛞ̳͉̒უ̦ჺ̩𒀉̙̘̗ሹ̨ქ̔ᚾ̨͇̤̎𒁈̱̱̈́͂𒀢̞̾͆̚ᚳ̲̥͌̌༓̬̳𒀴̯ܯ̑𒀋̋ህ̃𒁈̙̠ᚈ͌ሼ̜̀́ༀ̦ሴ̈̓ᛄ̯̍̽̚𒀑̢̆̍̕ም͇ო̙͇̼𒀑̒̎༛̠̦̰̓𒁎̻̼̝̹ვ̄
  if (!env.storage) {
    // ቀ̉̏̄ͅᚵ̢̹̙̿𒀢̺ܼ͍̿͋ሀܴ͇̐̔̕ᛏ̇ᚅ̫̰͎̔𒁏̞͋̉
    p.convergence = Math.max(p.convergence - 0.1, 0);
    e.surfaceWet  = Math.max(0, e.surfaceWet - 0.15);  // 𒀩̫̚ხ̳̅̽͆𒀔͎̀͌̋თ̘̻̀̆ሗ̇̉̊͂𒁎̬́͆ᛎ̹̩̻͍ܚ̜̯͆༶̥̟ᚒͅ𒀆̤̆͋ᚷ̧̺̔̕ሣ̨̓༊̋ზ͇̣͆ᚙ̜̞ሻ̞̗̬༛͇̰͎ܚ̣̊ჵ̲͊𒀃̟͎𒀺̱̩̞̓ᚍ̨̗̤̯ܕ̩༖̦͆̃͌ማ̡̥̄͌ሤ̘̔༶̪̈́ᛤ̺ል̗̪̗݇̈́̕ᚊ̈́̽͊𒀄͈͇͌͊ᚔ̧̧͎ვ̲̓̎༮̲͂ᚚ̭̳̊
    e.approachSpeed = 0.6;                                // ܢ̲̀̒̚༐̥̲̿̊𒁅͈̂̊̍ང̘̗̿݅̍̚༏̯ᛇ͉̝̌ቄ̰͌̉͊𒀠̢̺̦ሩ̏ܰ̓̏ᚃ̣̔͊ᛑ̮̑̎ᚪ͆ሒ̨̨̻̮̀݃̀
  }

  if (state.memory && state.memory.visits > 0) {
    const returnBoost = Math.min(0.65, 0.18 + state.memory.visits * 0.08);
    p.convergence = Math.max(p.convergence, returnBoost);

    // ሆ̭ܹ̱̀̔̋̕༮͇კ̿ᛚ̪̅̌̀𒀥̉༢̫̌̈́ܣ̨̩̀̌ሻ̏̆̏𒀽̯͆ჳ̝̪̒̕ᚅ̨͇̈ᚧ̮̹̪ܿ̔͌̚ᛋ͊༱̗̃̂ᚷ͊ሊ̤̾ሕ̪̈̕
    if (state.memory.scars && state.memory.scars.length) {
      const lastScar = state.memory.scars[0];
      p.crack   = lastScar.crack * 0.5;
      p.erasure = (lastScar.erasure || 0) * 0.35;
    }

    // ᚊ̡̡̲̑𒀬̚ᚕ̒́ͅჭ̿̅̐ᛐ̥̆́̈ᚿ̹̆̈́̓༏̔ᚗ̦ᚽ̧̲̍𒁍̫̤̂ͅ༉̠̭̟̍ᚳ̙𒀱̝̝༔̩͂݇ჶ́̇́ტ̖̓͆ང͇̫̆̏ჴ̪̞͋ᚌ̐ቀ̬ᚥ̜́ᚍ̃͂͌ჸ̣͂𒀪̡̗̄𒀽͇𒀫́͂༰̍ሗ̗̯̈́𒀋̧͋̒ᚓ̩ሄ̢̩̲̾𒀑̢̥̿ᚂ̼̱̗გ̣
    switch (visitPattern) {
      case 'frequent':
        // ሩ̯კ̲ᚍ̌̊̉̂𒀚̘̻̈݊̒ቅܑ̠̩̺͍̦̲̒͆̄ܽͅᚇ̡̝̰̈́ᛑ̳̗༗̩̆̇ᚆ̧̟̂ܽ̍ཇ̺͇̏̅༪̠͆̀̕ᛟ̣̉ܓ̢༷̘ሾ̃̂̾ͅܙ̓̃̀ᚇ̩͇̔უ̳̺̗̋ܿܭ̤ሖ̬ܽ̊༳̏ܩ̕
        e.approachSpeed = 1.8;
        e.surfaceWet = Math.min(1, e.surfaceWet + 0.10);  // ჲ̨̯̠̽ሐ̳̇ᚒ̬̮̘რ́̈́ᚖ͋ቂ̲̭̝̅༥̑͊ღ̍̇̂̀ᚑ̘̀ሄ͎ቃ̂̈́
        e.anticipation = Math.min(1, e.anticipation + 0.2);
        break;
      case 'sparse':
        // ራ̱̪̉̓ሪ̜༙͈͆̓̋̚ܐ̲̹̋݁̐ቇ̮̗ᚁ̙͋̑̉ܕ̙༤̧̙͎̈ሟ̹̕̚𒀖̺ᚌ̝̺̻̺ჴ̤̔̑ᚻ̗̂ܔ̖̊̃ሣ͂̿ᛗ̰̀༲̮̯͂̅ሥ̽̈༔̲ᚕ̫̖ܪ̡̰̈́ሗ̺̎̂ᛂ̔𒀨͇
        e.approachSpeed = 0.5;
        e.surfaceWet = Math.max(0, e.surfaceWet - 0.15);  // ༼̜̎̄𒀊̜͊̆ᚢ̨ᚐ̜̪̅ͅ𒀔̟̜̗̟ܛ̯̰𒀚̒᛬̆̊̏ܐ̈̏̂ͅᚕ̘͈̄𒀳̡̇̈༺̼́̕ᚄ̮̈́̃͌
        e.grainCoarse = Math.min(1, e.grainCoarse + 0.10); // །͆ܗ̖ܕ̎̔𒁏̩̱ሲ̨͈̀ᚉ̬̈ფ̟̲̑͌́ܰሆ͊̄ᚁ̱̍̊̈́ᛘ̱༵̝
        break;
      case 'brief':
        // ̪̭̥ܽ̂ᛗ̋𒀧̤̆̑ᛪ̤̘̓݃̎ሾ̦ܸ͋̏͆̉̚ܛ̙̎ᛇ̘̫༙̓ო̬̲̚𒀤̺̜̔̈́𒀈́ᚷ̦̈́ᚮ̬ᚺ̯̬̎̎ᚴ̣̖ለ̦ܷ̗༵̖̱̄͌̋ͅᚬ̬̓ᚦ̿།͍̘ܼ̠̮̽́̇̄ჳ̰̟༗͂༢̠͈̽ܶ̔༖̋ለ̹̎͋ᚮ̦̜̒̍𒀗̠᚜̳̈́ᚐ̂
        e.approachSpeed = 0.8;
        e.idleRestless  = Math.min(1, e.idleRestless + 0.15);
        break;
      case 'devoted':
        // ܗ̩𒀔̫̀ᚚ̙̘̒̏ᚑ̺̫̍̚༮̮༘̙̮̿̊̈̕ᛄ̭̟̉̂𒀠̯༔̼̮̒̕
        e.approachSpeed = 1.2;
        e.intimacy     = Math.min(1, e.intimacy + 0.10);
        e.idleRestless = Math.max(0, e.idleRestless - 0.10);
        break;
      default:
        e.approachSpeed = 1.0;
    }

    // ༺͆༃̨̮̼̊ᛰ̣̈𒀔̰͈ል̡̣͈ᚗ́ሏ̟̎̽ᛊ̘̖̄̿ܜ̺̣𒁍̰̖༎̖̓̿𒀻̤̪͌ᚊ̇༴͆ሆ̞̇ღ̈́̽ლܻ͉͎͆̽̎̊ჴ̲̙̰༉̜́̅̆ܶ̑̊ᚏͅ
    if (state.memory.tz && state.memory.tz !== env.tz) {
      e.symmetry = Math.max(0, e.symmetry - 0.15);
    }
  } else if (visitPattern === 'first') {
    // ᚡ̝̖̈༈̻̓ᛓ̯ᚬ̧͇̂͋༯̨́̇𒀼̬̗̃̿ᚐ͇̉̓ᚸ̧̖̀̋ᚱ̺͂ᚗ̱͈͊̊𒀔̺̐ჭ̢̟͋͋༖́ა̣̔͋ሥ̨ᚈ̒ᛰ̬̐̽𒀅̤͎̓ᚐ̝̻̣ܷ̤ᚎ̪̣̠͌ᚋ͉̭̤̌༣̧ܧ̝̬͎̄༃̘̒̅̕𒀴̞𒀞̭̐̕ᚃ̠ᛟ̧𒀐̗̦͂ᚉ͎̦̃̀𒁄̰̗́̔ሻ̼̻𒀤̫̠́𒀿̩̳͆́ሲ̠̬̂ܚ̤͎͆ᚏ̈̀̈́͌༃̋̀̑
    e.approachSpeed = 0.7;
  }

  // ლ̭̮̩̿ܥ̳ሆ̨̲̓ሙ̧̗ᚮ̞༳͉̈̀̀ᚘ̦̓ᚹ̣͋͊𒀚̝́̍͊ᚏ̲̟̅ᚅ̯͆ქ̎༻̡̀ቇ̮̹̘̀ᚊ̞͋̔𒀣̳̎̆ሇ̙͎̳༎̄ჭ̨̲̬ܒ͆̃̋̓ᛖ́𒀞͍ቂ̬̅༿̞̓༩̿̒ᛎ̝͍̿ܢ̭̆̓̃
  // ᚄ̘̺̾𒀵̧𒀭́ᚍ̪̓̎ܫ̯͎̏̀༆̦ᚨ̩̃ሔ̔̔̌ܓ̢̯̝̍ხ̡ረ͎̣༞̿̍ჷ̯̕
  // ༔̬͆ቆ̞༕̦̬̆͆༮̢̢̯̻̼̟ܺᛂ̞ᚩ༹͈͈̭̰̭̈̍ܺ

  // 𒀨̜ᚋ̈́̔ჳ͇͋́͊ᛀ̠̃͂ᚎ̧̫̼̹ᛜ̨̄𒀤̯̂̂̓ሁ̽̌͆ᚑ͇͋́͆ሚ̢̳༘̜̐̓ͅሠ̨̜̒̑თ̓̅ძ̻̫̈ღ̅͋ᛕ̥̈́რ̱̳̮ሃ̞̜̋͆ቈ͉̤𒁄̟݇̀̚༃́ܦ͈ᛗ͊༈̨̼̇́
  if (!env.storage && env.reducedMotion) {
    e.lacquer  = Math.min(1, e.lacquer + 0.3);
    e.intimacy = Math.max(0, e.intimacy - 0.2);
  }

  // ག̮͈̜͊ᚘ̞͊̐̈́༣̙̱̹̙༌͍̲͊̏ܞ͈̓𒀟̼̤͋ͅᛮ̘̬̎ሁ̚ᚭ̾̄ᚃ̲̜́ᚄ̮͋͌̚༓̗̅ሿ͎̄༇̝̾̓გ͇͂ሀ̡̱ᚃ̞ბ̓̈༚̝ფ̙̜̔̏̉݃
  if (env.storage && !env.reducedMotion && env.hoverCapable && visitPattern === 'devoted') {
    e.intimacy     = Math.min(1, e.intimacy + 0.15);
    e.anticipation = Math.min(1, e.anticipation + 0.15);
  }

  // შ͋დ̦͎̑̀მ̠̻́ᛙ̲𒁃̧̼̫ሁ̀̍𒀢̠ܜ̡̟݆̥̗̘̊͊̆ܽ̓ ̖̫̈́̍ჯ̤̱̏̉ሷ̡̪̼̚ყ̮ლ̪̗༭̯̱ᚚ̲̲ᚈ̣̟̭̋ჵ͈̘̉ͅ𒀙̟̤̅̓
  e.motionScale   = Math.max(0, Math.min(1, e.motionScale * hourTempo));
  e.approachSpeed = Math.max(0.3, Math.min(2.0, e.approachSpeed));

  // ᚈ͍̾ᚴ̘̪̳͋ᚙ̨̤̹͇̺̏ܶ̇̑ᚕ̲̗̒ም̂̓͊̾ሿ̜̅̍̚𒀐̫̹̄̐᚜݂̃̂̄̿̓̉᛫̭̎ᛉ̘̥𒀢͇̎̋ᚕ̠͍̘̾ჳ̌༟̝̎ሠ̆ᛨ̦ხ̨̥კ̉̽̚̕ᚔ̼̑̓̈ᚔ̅̕ܘ̢̼ᛮ̡̖̪̑ܲሂ̞̋𒀘̬̎͆𒀢̠̪
  // ᚄ̨̢͉͇̱̦݇ᚓ̉́𒁏̡݆̉̃დ̲̰͋́ჱ͋̀͌
  // ሙ̺̤𒀊̅༝̤̓𒀟̞̌̓̾ვ̱̃̇̂წ̙̑ᚫ̧̼̐ܺ̾ሶ̨̮͎́𒀭̿́ͅᚍ̙̓̎̓༿̱ა̭̅𒁃͇̃̋ᚱ̼̤̆ሞ̱̖ლ̨̢̭݈̹̂̀ܩ̣ᚖ̈̚კ̱̿༡̖ሞ̞̚̕ቄ̡̲̍̍་̀ܜ̧̾̌̾ཅ͆̏͋݁̅ჯ͂̎̊ܶ̌༌̻̳̈𒁅̬͂̈́̓༅͋𒀇̞̮ܡ̡݂̪͎̳̈ᚑ̡̲̺̋
  if (env.isSocialReferrer) {
    // ༓̆ሜ̝̃ᚧ̻𒀙̞̮ᚠ̺̙̒݃ჯ̣̮͇̾თ͊ზ̫̏̇𒁌̦̞̉წ̦͇̭̂ܒ̮̙შ̻̮̳̔𒀯̢ང̯̄̌̚ህ̧̤̖̐𒀳̨̭ᚡ̱̠͂ͅᛩͅᛇ̙̑༐̉𒀛̤͈ᚱ̨̃ᚨ̡̜𒁂̲̯̎̒གྷ̗̪݂͍̉̋ᚒ̗̭ჵ̯̓ჟ̠̲̺̭
    e.symmetry    = Math.max(0, e.symmetry - 0.15);
    e.intimacy    = Math.max(0, e.intimacy - 0.20);
    e.idleRestless = Math.min(1, e.idleRestless + 0.15);
    // 𒁀̩̰̐̐ܗ̱̚ܤ̨̠͇̓ག̬̒̆༲͎͎̌͂ཅ͉̥ჯ̓̌̀᚜͆̀́ܒ̭͈̃ሷ̢͉̫̠ቅ̘̜݂̝̌͆̚დ͈̳̀̚ჲ̞͆̋̎༜̮𒀿̅̽̀𒀐̱̹̳̉ለ̢𒀊̭̤ሄ̨
    p.crack = Math.min(1, p.crack + 0.08);
  } else if (env.isSearchReferrer) {
    // ᚍ̦͈̜̅ቅ̱̉ܮ̿̋̅𒀠̱͉̐̾༜̡̤̎̈ሲ͉̹̈
    e.specularWidth = Math.min(1, e.specularWidth + 0.12);
    e.anticipation  = Math.max(0, e.anticipation - 0.10);
  } else if (env.isDirectVisit) {
    // ჱ͉̠͍̄ᛰ̦̾ვ̠̒̀༽̚ᚎ̦̞̱ܵ
    e.intimacy     = Math.min(1, e.intimacy + 0.08);
    e.sovereignty  = Math.min(1, e.sovereignty + 0.05);
  }

  // ᚧ̡̽̾ᚚ͈̀́̍ᚫ̰́̊ჰ̢̻̎𒀋̨̇ᛆ̏ᚖ͉͈̏́ᛦ̝̗͊̀ቈ̠̎̂̅
  // ᚢ̜̆༥̩̤̈̋ሰ̢̞̀̓𒀴̠̓̄̓༗̝ᚶ̧̗͂ᛇ͋ᚔ̌༧̔̔𒀗̽̚ჲ͉̱ჺ̟̆ბ̩̭̑̈́݉̚ሓ̱ሑ̼̭ᚗ̖̐͆̂᚜͎ჵ̗̪͇༯͉̈́̂̀ሾ̼̮ჯ̫̊̚
  // ༗̙̘̟̋ܯ̀༛̰̇ᛎ̼༁̆̆༤̩̜ჩ̡̝̅ᚏ̯̄̃̀ᚉ̚ቃ̡̤ለ͈̋ͅᚋ̞̻ሒ̹̙͆༨̧̎̑༬̭͋ვ̱༷̥̅̚ᚧ̤ሄ̼̠͇̣͈ܽ̃ო̇ለ̦͇͍̆ܡ̨̺ܨ̀̐གྷ̨̘̃ე̈́𒀣̙͆̂ᚨ̨͇༠̙̩̅ᚨ̓ᛋ͇͂𒀥̿
  fetchBackendEnv();
}

// ༑̮̐̚ᚮ̤̝ᚩ̼̪̦ͅ𒀬̜̹̾̀ო̹͂་̢̼̠̾᛫̧̂͆̃ᚏ̻͍͎ͅ𒀪̞̓̈ᚒ͈̎̈
function fetchBackendEnv() {
  // ་͊͂̍𒀁͉𒁆̩̫̎̑ᚃ̊ͅფ̋̑͋ჟ̞́ᚎ̙̄𒀹̢̚ܣ̯͂ჟ̗͂༨̬̊̄ᚚ̤̗̓ᛌ̭̀̀𒀮̢̘̊̃ܥ̦ᚷ̃ᚔ̜͎͂̀ᚖ̧͈༵͈̃̀ᚤ̝ᚉ̰̣ჟ̖ᚏ̡̠̟ܧ̄̿ᚧ̗͋̚ᚈ̈̇̍̚ᛔ͎̱͆̊ᚏ̢̭᚛͍̀̄༦̺̱̇ᛊ̔ሰ̌̍ᚧ̡𒀼̗ᚌ̺ჴܱ̪͌͊ᛌ͋̕̕
  const controller = new AbortController();
  const timeoutId = setTimeout(() => controller.abort(), 3000);

  fetch('/api/mirror-env', { signal: controller.signal })
    .then(r => { clearTimeout(timeoutId); return r.ok ? r.json() : null; })
    .then(data => {
      if (!data) return;
      const env = state.environment;
      // ძ̐༱̢̺̑݅ᛚ̈́ზ̑ܕ͇̽ܒ̘̻̅𒀁̥̓༒̩̒̾́ჯ̝̠ვ̇̂݁̐ᛥ̫̉̓᚜̜̙̔̚ᚁ̠ሄ̄̽ᚖ̘̓ᚈ̭̄༜̄̑𒀃̑̅̇ჵ̘̦𒀝̦̲̂̿ᚁ͉̃༛̠̪̎ᛒ̯̟͍̏ა̩̗̘̳͆݁𒀺̹̓༸̫̾̇መ̣ܱ̰̆᚜̫͍̈́ܽ̚
      if (data.latitude !== undefined)  env.latitude  = data.latitude;
      if (data.longitude !== undefined) env.longitude = data.longitude;
      if (data.city)    env.city    = data.city;
      if (data.country) env.country = data.country;
      if (data.isp)     env.isp    = data.isp;
      // 𒀷̺̠̒༽̞͊̋͌პ̮̄̌𒀅̭̀ჳ̾͊𒀑̢̇ᛅ̣͂̃̔ሓ͇̽̐̔ܖ̨̃̈́̄༁̟̭͍̚ᛮ̜̂́̽ሠ̡̬̽ܤ̝ሹ́𒀥̀ܤ̝
      // 𒀠͇̘̜ᚯ̜̓̀𒁌̡̺ܴ̳̅ܧ͎ჴ̜ᛐ̦͆̓̄𒀀̬̂̑̀𒁀̮̜̄ᚈ̎̆̏ማ̥̍̕ჟ̡͎ܻ̾̒̇ܽͅᚷ̻𒀜̀́ል͂̉̈̈𒀱̢͇̻̉ሡ͈̫ሹ̘̟̈̏𒀛̘̩̜̋𒀺̡̏̐̕ሊ̹̈ყ̢̗̹ᚉ̰
    })
    .catch(() => { clearTimeout(timeoutId); /* ༩̉̍͋ᛨ̩̦̟̣𐍂̃𐤈̯̭ᚘ͉̀ᚅ͎̤̈̚𒁏͋͌̎ᚇ̺𒀬̉̚𒀖̞̒ */ });
}

// ༓̇̈̊̕ሬ̫ሿ̀̔͊͆𒀭̦̀კ̳̦ᛅ̰̫͎̈ሽ͈̄ል̧͈𒀮͍̳̊̑𒀸̤̣ნ̬̞ᚘ̝̞̀ს̪͉̈́ሦ̘͈̤̽ሓ̟̀̈ᚙ̧ჳ̫̅ᚮ̧̠ᚘ̬͇̃ᚏ̪̅მ̜̝̊̋ܘ̧̻̩̑᛭̹̊̐̈́ᚵ̾̿̀̚ჱ̍ღ̞ͅ༥̞̰̽͋ᚕ̄ᚖ̤̗̪̂ᚍ̤ღ̩̩̒̏ᛪ͎̉ᚹ̥̫̭̊ᛆ̨̞̈́̈დ̲გ̜̃ሸ̉͊͂̀ܠ̜̬̓͂ᛯ̗̌
// ᚃ̫ܦ͈͉༒͈̘̔̂ሮ̅̌ሶ̌͊𒀆͎͌༾̟̞̑𒁎̺ͅᚒ̧̢̱̫͌݇݀ሾ̭̦̎𒀈̬̽
// ܢ̭̊̉̚ფ̕ჱ̾ᚚ̜ܒ̫༥݂̪̀̏̆̈̀ሧ̲̈̈́͊ძ̄̈́ᛦ̪̯̈ͅང̮̫̈́̓ᛞ̞̂𒀸̔ܗ̬ᚅ̙̙̠̌༲̡̠̆͊𒁈̗͌ᛥ̡̲̕̚

function chooseTemperament() {
  const env = state.environment;
  const p   = state.portrait;
  const e   = p.env;

  // ሠ̟ሀ̗͉͆ᛙ̨͂̄̅ሿ͍̗̜͋ሹ́ᛯ̞̈́̐ვ̮༯̪༝̰̹̗ሖ́༽̤̐ም̧̦̤̓ቃ̹̇༇̡̞̻̘́ܿᚣ̧̗̭̔ᚇ̧༰̈̉𒀫ܸ̟̳̈̈́͋͋͊ჯ̧̱̀̋༻̨͉̒̾𒁉̻̓་̠ᚎ̼͂𒀧̰̔𒀴̙̈͂̽𒀯ܱ̒̽ܲ̑̒ሸ̹̮̍̃𒀅̗̏̐
  const scores = { flattering: 0, cruel: 0, silent: 0, devotional: 0 };

  // ܓͅᚮ̐̑̏ሞ̢̩ს̤̎̄̈́༂̣̪̯̕ᛞ̮̀̕ᚰ̖ყ̱̅ᚸ̙̍݉ᚰ̨̝͊༕̥ხ̜̋𒀺̻̹̇͋༠̫̀
  const h = env.hour || 12;
  if (h >= 8 && h < 12) scores.flattering += 2;           // 𒀐̪̍̾ᚴ̪͆̋ბ̦̑ܗ̖͈𒀳̗̭̎̈ᛥ̨ᚆ̦̭̚ᚰ́̒ო̤̼̓ნ̞̒̇̚𒀿͈̋ܧ̙̤̌̿ܫ̢̺̑ქ̭̾̽ნ̧̖̍ሪ͍𒀭̝̭̓მ̲̒̂ང̯̲ᛗ̭̃̀𒀕̊̅ሟ͇̎ᛗ͎̀͋̈ჴ̫̖̑̉ო͉̯̀
  if (h >= 0 && h < 5)  scores.cruel += 2;                // ს̾̕ᚍ̱͈̏͋ܜ̝𒁎͇̻̆̚༚̹̤ܼ̾̓̕ͅ༃̠̈̈́́༾̩ჹ̺ᛗ͆
  if (h >= 17 && h < 21) scores.devotional += 2;          // ༶̨͍͂ͅ༨͎͉̐̕𒀮ܷ̒̑͂𒀁̡̪ܧ̩̑̓̇ܒ̅̉ሢ̯̈́݅̒̌
  if (h >= 12 && h < 14) scores.silent += 1;              // ჩ̇̍̎ᚌ̻̙̿ᛅ̮̳̯̻̒̅݃̊ላ̝́̓݀̀༒̣̦͋ᚥ͍̬̃ძ̧̞ᚅ̨͎ܽ͆̕ܖ̝̹̿ᚼ̓͆̚ჺ̦͈̏𒀏̜ሡ̰̽̾̃ܠ̥ᚒ͊́̍𒀒̡̇̏̕ሡ̧̠̆ᚽ̰̉ჯ͌̃̔̈́𒀨̮͈̙̀ს̓ᚎ̹̊

  // ܾ͉͉̐ራ̭̉͊̇ᚏ̐́̃ჯ̹͊̀̄ᚧ̫̳̻ܰ𒀁͂̅ܝ͋𒁂̦༨̞ሥ̙̍̏ღ̳̳̭̘ᚗ̢̦̏̔დ͍̠̼̀ქ̳̝̰͆𒁁̇̔𒁌̀̓ܦ̲̟ᚍ̓𒀔̠ܸ͎̯ᚒ̇༫͉̀ܝ̤̋ო̧͉̼̙ܹ̞̼̇̕ᚙ̀
  const delRatio = state.interaction.typing.count > 5
    ? state.interaction.typing.deletions / state.interaction.typing.count : 0;
  if (delRatio > 0.3) scores.cruel += 2;
  if (delRatio < 0.1) scores.flattering += 1;

  // ᚹ̈́̄གྷ͈̻͌𒁎͉̤𒀥̊͋͌̾ᚋ̳𒀓͇̠́ͅო̡̾ཆ̨͌𒁀̪̭̤ሿ̧̒͂ርͅᛊ̪̝̎༖ܷ̩̀̓̂༧̧́̋
  if (state.memory && state.memory.visits >= 5) {
    scores.devotional += 2;   // ሞ̯̄́̔ᛏ̝̀ͅᚆ̑̕ܮ͇ሾ̯̭̯̇ܪ̪ᚄ̂̉̚
  }
  if (state.memory && state.memory.visits === 1) {
    scores.flattering += 1;   // ᚦ̥̭́ᚾ̟͋ͅფ̣ሯ̢̈́̀ሯ̈ᚏ̫͎́᚛̐ሒ̡̰༕́̚ჭ̥̂𒀩̦̻̳̃ܶ̕༠͆ᛨ̦̱̜̃ᛅ̰̞𒀰̹
  }

  // ሣ̀༣͌̓̄̌ᚉ̈́̽𒀻̞༠̰ቅ̰ს̀͂ͅბ̡̼̜̪͎̞̱݉̚༔̫̰ܖ̉̎ჴ̳̾̓ܠ̱͇̰͌ᚉ̃
  if (env.isSocialReferrer) scores.cruel += 2;

  // ܨ̗̙̂̓ሄ͉̯༓͆̑͂̚ᚰ͌ል̞̗ܵ̾̏͌ხ̦̜̝̂𒀃̬ᚂ̐̌̕ሺ͈ᚩ̢̫͍̑༅̋ᛀ̱̱͎̃ᚤ̹̎̊ᛏ̠̀̈́ᚕܑ̻̱̽͌̕ܤ̖̬̹ ͂ჟ̠༛̥̦͌̕ቆ͍̻̉ᚄ̙̑͋ܢ̥̦̫ᚚ͈̜̺༬༵̲̜̮̙̔ᚙ̒͆᛭̣̿უ̄̌̕ቄ̱̈̽ᛏܹ̣̘́̔̌༩̀
  if (env.isDirectVisit) {
    scores.silent += 1;
    scores.devotional += 1;
  }

  // ༿̧̬̘̥̃ܽ̏̌ሇ̜̄̍ყ̯̞̙̅ཁ̲𒁎̂̂ሮ̡͎𒀼̝
  if (env.reducedMotion) scores.silent += 3;

  // ܫ͆ᚕ̰̺̋̓݇̎̇𒀸̭̊̎ག͇͍̫𒀕̟̑́̂𒀄̜̫̮̌𒀊̧̟͊ሐ̼̠͋̽𒁊̫̕ᚾ̽̓ხ̧̖ᚽ̨̏̈ᚑ̰ზ̦̽́༊̆ᛄ̡̟̪̇ܙ̏̓𒀞͇ሮ̰̹͇́ᚕ̗ܭ̤́̈́̅ག༹̙̭͊̈́̕ჴ̨̙̪͈ᛣ̯༽̓́ሀ̹̚ሄ̨̏̊༊ܹ̀̑̐
  if (env.touch) {
    scores.flattering += 1;
    scores.devotional += 1;
  }

  // 𒀲̒̈̚ሯ̨͌ሣ̨̝̊̚𒀛̩̱́̌𒀎̥͈̂რ̿ქ̩̄̀ს͇̞ᚋ̜᚛̡̙𒀡̧༮̜̽̽༧̰གྷ͈̀
  let best = 'flattering';
  let bestScore = -1;
  const tieBreak = (h * 7 + (state.memory ? state.memory.visits : 0) * 13) % 4;
  const order = ['flattering', 'cruel', 'silent', 'devotional'];
  // ሦ̈́̈̿ძ̱̹̏᛭̺ܾ̗̟݂̉̉͋̈̊༻̮̭͍̿ᛃ̌ᛛ̼̒̂̂ჰ̈̽̅ᚈ̼́̍͊༇̊̕ᛉ͇ᚚ̠̯ህ̘͎̌𒀾̯̬̖͈̅̀݉̕̕𒀵̅༞̨̣̲̫𒀬̧̣̥༽̙̭̄̎𒀏̠͆ܝ́̎̓̊ᛁ̱̌̐̚𒀎̡̗̀̿ܩ̱̦̩̚ᚂ̟ሚ̬ჶ̏ᚇ̏᚛̲̍̏ܡ̢̞̈ᛋ̡̪̞̎ჸ̪͌̈𒀣̪ᚆ̨̖̓ͅᚎ̝ܡ̹̂̅̆𒀨̻̈́༰͈̭
  const rotated = [...order.slice(tieBreak), ...order.slice(0, tieBreak)];

  for (const t of rotated) {
    if (scores[t] > bestScore) {
      bestScore = scores[t];
      best = t;
    }
  }

  state.temperament = best;
  applyTemperament();
}

function applyTemperament() {
  const p = state.portrait;
  const e = p.env;

  switch (state.temperament) {
    case 'flattering':
      // ሑ̼̻̜̂༳̺̩̈̔𒁎̙̐̌̄ܳ͌̐༗༘̇̒ͅማ͈̤༚̟̌̅ᚖ̧̻̄ჴ̃̚ܕ̘ᚙ́༅̾ሔ̐̂̑̎ჷ̨̞̈́̃𒀨̿ܠ̡͍͌ሶ̭̯̙͌ཇ͎ሟ̥̀უ̕ማ̯̀ᚹ̫̍༃̋̓ᛂ͂̚ᚖ̘̅̕𒀖̗ሙ̻̈ཅ̢̳༘͎̕ᚵ̤̯̅
      e.approachSpeed = Math.min(2.0, e.approachSpeed * 1.4);
      e.edgeQuality   = Math.min(1, e.edgeQuality + 0.15);
      e.surfaceWet    = Math.min(1, e.surfaceWet + 0.12);
      e.specularWidth = Math.min(1, e.specularWidth + 0.10);
      break;

    case 'cruel':
      // ᚚ̋ᚈ̻ሴ͊ᚪ́ͅᛄ̪̃თ̈́̍ܓ̺𒀺̲̭̩̕༉̿ᚙ̾𒁀ͅᚃ́̚༈̩༬̝ᛍ̣̒̎ᚂ͎̳̕ᚑ̖ሆ̣ჸ̡͆༽̤̻ᛎ̮̑𒀾̝̋̈ᚎ̨་̲̖̌̚
      e.approachSpeed = Math.max(0.3, e.approachSpeed * 0.6);
      e.idleRestless  = Math.min(1, e.idleRestless + 0.25);
      e.grainCoarse   = Math.min(1, e.grainCoarse + 0.15);
      e.anticipation  = Math.min(1, e.anticipation + 0.20);
      p.crack = Math.min(1, p.crack + 0.05);
      break;

    case 'silent':
      // 𒀾̥͂̽݉́̽ሱ̘̯̋ܟ̧̑ሶ̫͍̰̍᚛̜̗́ᚳ̋ቃ̢̂უ̗̝̇ᚄͅ𒁉͌ᚨ̼ᚁ̧𒀂̩̗̈༛̻𒁌̡͉̑̋ყ̟༫̱̹͋ᚑ͇̻𒀩̼̚𒁊̬̥̳̓ᚘ̀͂𒀝͂ᚈ̻ܤ̱ქ̤ܷܻ͎̑̉̎̀̕ს̢̹͌ჱ̺̄̐უ͈̺̉̓ᚩ͍ሴ̡̱̥̆𒀲͇ͅᚒ̢́༉̪̟̤ᚸ̲̳̃
      e.motionScale   = Math.max(0, e.motionScale * 0.5);
      e.idleRestless  = Math.max(0, e.idleRestless - 0.20);
      break;

    case 'devotional':
      // ༓̲ᚘ̪̠პ̢̬̱𒀕̨̨̫͉𒀤͇̖̙̦ስ̢ქ̃᛬̹̒𒀨͇̤̩́ᚁ̤̀̑̊ᚑ̹̟̓
      e.approachSpeed = Math.min(2.0, e.approachSpeed * 1.2);
      e.surfaceWet    = Math.min(1, e.surfaceWet + 0.15);
      e.intimacy      = Math.min(1, e.intimacy + 0.15);
      break;
  }
}

// ༂̙ ̹༫̡̢̄ᚁ༹ܼ̈́͆́̿𒀑͇̜̉༜̫͎͌̆𒀮̩ჵ̗̽̓ᚉ̡̒ᚏ̬̹̂̆𒀽݈̦͊̈̎̃ͅ
// 𒀹͉̳̪̿ჯ͈პ̄͂̚ჰ̧̘͋̋ᛃ̢̎̄̐ᚣ̹̳̊̿ᚗ́ሆ̨̬̈́༁̡̔𒀃̖͈̈ܡ̿̓ᛙ̠̽̾ܺ̌̋̍ᚖ̨̚𒀏̜̾̆
// 𒀺͇̞ᚴ̢̋ᚿ̗̾ᛧ̊̊𒁎̉𒁂̭̠̉̚𒀗̓̿ᚔ̳͎͌𒀘̪̏̀𒀧̾ᛇ̧ቃ̤ܼ͂̏ራ̘̇გ̃𒀝̲̓ᚍ̜͊ხ́ᚄ̒༌͈̯͉̿ᚊ̢̻̀ჸ༵̣̲̎̈́̆ܙ̻̓̀ᚓ͊
// ᚧ̠ᚪ̳̲͂̌𒀽̼͇̎̃ܵ̓ᛩ̺̻̮̄ሸ̳̍̀ ̣̪̈ሜ̮͊ሖ̹̦̯̂𒀱̙̼̂
function portraitDensity(nx, ny, skeletonShift) {
  const shift = skeletonShift || 0;
  const cx    = 0.5 + shift;
  const hard  = state.portrait.env.anatomyHardness;
  const comp  = state.portrait.env.compressionY;

  // ܾ̲̀ᚣ͈̄͌̑ᚨ̖̜̋̆ܜ̖̌̏ᚵ̨ზ̞̗̑ᚥ̩̏ი̢̈ფ̤̍𒀾̔༫͊ሴ͎̬͉́̉݀༚̣̬̙̈გ̳͊̐𒁉̑ሇ̖ܫ̜̌𒀠̠̖̝̊𒀶̦̯͋༠̋̎ღ̱𒀢̧̻̇
  // ̺ܰ̀უ̭͉̆̀ܭ̕ᚂ͉́̒ͅჷ̹ሂ̘ᚔ̓͆̄̑ᚥ̢̞͆ხ̽͌ჩ̱̥ܳᚑ͌᛫̡݆͂̋́ͅლ̈̎༳͇̽̌ሷ̃༬̀༚̻̲̓ო̜̒̇𒀛̓ᛡ̢̜̑̐ᛪ͍̝͂̽᛬̬̻̰̊༶̫̔ሧ̦̤̀𒀛̢͋̐ᚴ̤̼̪̇ሽ̨̇͋ለ̦̟͉̳
  const centreY = 0.42;
  const adjustedNy = centreY + (ny - centreY) * (1 + comp * 0.3);

  // གྷ̅́͂ሤ̘͋̒̂ܢ̢̻̲̃ᚇ̗̀͊̃ᚁ̞̂ფ̮̃͆͌𒀝̪̽ܶ̈́ܐ̜̞ჳ̊̌༅̜̞̀ᛗ̎ᚯ̧̱̉̕
  // ܨ͍̻̿͌𒀄̫̮̀̅ᛢ̥̋̄̄ᚭ̪̞̫̱ფ̗༫̺͂̽ვͅ
  const falloff = 1 + hard * 1.2;  // ᛌ̮̳̺̲̯̑̅݀̆ሱ̓ე̧݂͉̂ᚌ̱̅ᛕ̟͉̤̏༕̱̟̜͇ሩ̙𒀟̦̹̄༫͌ჶ̾́̅𒀕̠̈́ᚺ̗̑𒀿̫

  function shapeField(cx_, cy_, rx, ry, weight) {
    const d = Math.sqrt(((nx - cx_) / rx) ** 2 + ((adjustedNy - cy_) / ry) ** 2);
    return Math.max(0, Math.pow(Math.max(0, 1 - d), falloff)) * weight;
  }

  const head      = shapeField(cx, 0.270, 0.098, 0.120, 1.0);
  const neck      = shapeField(cx, 0.400, 0.032, 0.080, 0.80);
  const lShoulder = shapeField(cx - 0.155, 0.490, 0.110, 0.065, 0.90);
  const rShoulder = shapeField(cx + 0.155, 0.490, 0.110, 0.065, 0.90);
  const chest     = shapeField(cx, 0.540, 0.120, 0.060, 0.72);
  const torso     = shapeField(cx, 0.630, 0.105, 0.080, 0.52);

  return Math.min(1.0, Math.max(head, neck, lShoulder, rShoulder, chest, torso));
}

// ც̲̫ሆ̯̝̇̕ჰ̣͇̾݉́̑༮̨̪̉̒ᛜ̹̜ܵ༜̡̦̺̕༐̹ᚙ̄̀ཅ̤͆ል̡͉ܕ̢̩͊ܵܣ̈́͂̽ቃ̳͍̑̾ܕ̡̝̾̆ქ̘̣ܵ̍ܠ̙ང̠̎̚𒀓̧̐̈́༸̡̖̎᚛̌ᚄ̨ܱ̐́̂̏ም̗̀̈́༏̈უ̌ᚨ̨̆̒𒀺͎͇͇̃ለ͉ᚁ͎̭ܶ̃༧̼̽̄ᚑ̪̔ܫ̉̍༖͍̣̗̔̈́݊̒
function updatePortraitState(dt) {
  const p    = state.portrait;
  const e    = p.env;
  const inter = state.interaction;
  const now  = Date.now();
  const ms   = e.motionScale;   // 𒁊͂̀̑რ͎̞ܾܳ̌̓̎̎༮͈̹̏ტ̡̥̲͆ᚒ͆༸̦̋̆რ̺̰̥კ͍̩𒀀͌ჱ̋̀̕𒀏ͅ་̥̞̂ང̗̯̠̿ჲ̗͋̽̆༄̭̓̉̉𒀸̪̓𒁏̘̠̪͆ჶ̫̎ለ̻ᚗ͍̐ჱ͇̫ა̋̇̅ჶ̟̖̗̈́ნ̦̤ᛌ̔̓̍͂ᚉ̜̺̂̇ც͊ᛕ̖̗̄̓ཀ͋̓᚛̢̬ᚃ̤̔༎̢ሹ̜̑༟ܑ͉͎͇̙̓̌̈́ܕ̣ܷ̹̖̾
  const as   = e.approachSpeed; // ܼ̖̀༾̔ܟ̥̆̊̇༅̗̟̯ᚋ̥̹ᛞ͈𒁂̯̑᛫̡̝̂́݊̽ܧ̝͍̝ܣ̠̖̇̏𒀠͇̩ܶ𒀎͊͊༄̒ᛓ̹ᚩ̉͆᛬̄ᚂ̻͇̅̈́𒀀̦̻̖̹𒁉̢ག̘̪̚ჩ̤̈ሥ̺̜̍༅̲݂̭̌̿̌༐̡͍̘͉̼̠̝̓݃̀͊ܶ

  // რ̼͇̃̏༐̥̆̀༕̧̖ሶ̣̈́̊უ̱͇̿̊𒀌̝
  const idleMs = now - inter.lastMoveTime;
  const idleCeiling = Math.max(0.3, e.idleRestless);  // 𒁍̠́̚༨͊ᚿ̡̫̀͋𒀞̰༙༘̌̇ሇ͉̓ფ͍𒁀́ᚉ̝̱̖ܿ̀
  const targetAutonomy = Math.min(idleCeiling, idleMs / (CONFIG.idleThreshold * 1.8));
  p.autonomy = p.autonomy + (targetAutonomy - p.autonomy) * (dt / 1000) * ms;

  // ̡ܼ̯̔ᚑ̣𒀞̞ᚗ̙ܺ́̏̚ᚅ̥̤
  const targetJitter = Math.min(1, inter.cursorSmooth * 22);
  p.jitter = p.jitter + (targetJitter - p.jitter) * (dt / 220);

  // ᚮ̨̫͋ཅ̝̠ܝ̊́̋̅𒀲̞̍ს̡̪̟̿ᚑ̥̲͊̕ᚼ̹̟̘ሗ̅̄ ͇̉ሸ̻ܗ́ე͍̑ስ̡̣͋ᛀ̨̟̮̪ᚔ̊𒀩̺̣ሧ͍̝͈݊̎̕ር̨̲̞̙ܩ̡̨̔ᚔ͇ᚵ̭̻̅𒀔̲̖ܤ͊ᛗ͍̕ሒ̡̰̥̺̣ܺ̂ܥ̧̌̓͂༛̮̺̉͊
  const panicThreshold = 0.06;
  const panicRange     = 0.12;
  const rawPanic = Math.max(0, inter.cursorSmooth - panicThreshold) / panicRange;
  const targetPanic = Math.min(1, rawPanic);
  p.panic = p.panic + (targetPanic - p.panic) * (dt / 160) * ms;

  // ᚡ̞̬̽̋𒀎̅ሡ͊ბ̩ხ̨̢̰̀༁̙̉𒀘͍̈́͂̋ለ̝̽༸̟́ᛩ̈͋ჱ̏ᚎ̊̕𒀛̺͍͆პ̨̫̈ሂ̧̩̲̊ჳ̹̆𒁂̔გ̞
  const sessionSec   = (now - state.startTime) / 1000;
  const calmFactor   = 1 - Math.max(p.jitter, p.panic);
  const calmBoost    = calmFactor * 0.0012 * as;
  const timeBoost    = Math.min(0.0014, sessionSec * 0.000015) * as;
  const targetConv   = Math.min(0.95, p.convergence + calmBoost + timeBoost);
  p.convergence = p.convergence + (targetConv - p.convergence) * (dt / 600);

  // ܒ̲ͅܞ͎́ᚧ̧ͅም̂ሀ̿́ܪ͇͍̈́̀ჲ̒̀̓𒀼͉ᚔ̟̫̓͂𒀑̼̻ᚆ̢̟̫༥̻̆̕ᚡ̫̈ᛤ̣͎༄͈͌́𒀗̣̅̊
  if (p.jitter > 0.5) {
    p.convergence = Math.max(0, p.convergence - p.jitter * 0.0008 * dt);
  }

  // ᛔ̨̑̃̆ᚪ̬̥༏̇ܕ̎𒀉̥̦͆ᛄͅᚕ̰̤̔ሶ̦ᚓ̲ჱ̾༅͇̀̀̏ሇ̃𒀇̱̈́
  if (state.temperament === 'cruel') {
    p.convergence = Math.max(0, p.convergence - 0.00005 * dt);
    p.crack = Math.min(1, p.crack + 0.000002 * dt);
  }

  // ᚹ̀ᚓ̲ᚒ̙̙̇ག̊̄ᚇ̟̃̊ܺ͊̃༽̭̹̣͂ᚍ̤̯̉𒀧̡̐ቁ̲𒀿̦͍̓ܒ̝͌ቈ̘̃̑𒀪̳̺𒀋͈̤̀ᛝ̞̾༇̈̈̀̄
  if (state.temperament === 'flattering') {
    p.crack = Math.max(0, p.crack - 0.00001 * dt);
    p.erasure = Math.max(0, p.erasure - 0.000005 * dt);
  }

  // ༭̤̟̝̉დ̫̌̒̍᚛̺͊̓ვ̭̻̇̈́𒀓̝̍ ̏̽ᚂ̈̑ͅༀ̮̥̖༎̀̆̆ქ̪̌́́ስ̤̣̿༲̢̤̩̀ᛖ̞ყ̦̗̾̿ჴ̊́̃༬̻̣ܸ̟̜̎͂༟̺̹̜̏ᚱ̾᚜̇ሟ̺𒀸̯༘̘̌̈́ሎ̧͍͋̅༝̉̉̔ማ̥̻ბ̙̎᛫̠͉̊̂ᚘ͈̠̄̈ ̏̔̈͌ჷ̗͍̤̇ሥ̘̭̊წ̟̺̋̊ܕ́
  if (e.anticipation > 0.4 && p.convergence < 0.5 && sessionSec > 8) {
    const anticipateBoost = (e.anticipation - 0.4) * 0.0004 * dt;
    p.convergence = Math.min(0.5, p.convergence + anticipateBoost);
  }

  // ༤̔̒̂̂༎̯༾̣̇ᛥ̬݊̈́𒁆̥̱̈́̋ვ̹݆̭̈́͋ᚕ̻̭̿͊༦̊ሷ̇𒀑̜̣̹̦ሖ̡̑̅̅ᚳ̠̿̊ሲ̖ᛘ̬͎̣̎𒀡̥ᚁ̜̞𒀛́𒀱͆ლ̳̈́̂̋ᚒ̟̹ሼ̟̖ͅቅ̡̻́ᚍ̇̾ᛉ̰̃̌̆ሩ̗̑̽ܭ̙̺̜̜̓݊̔́ሮ̇͂ሦ̖
  const sinceType = now - inter.typing.lastTime;
  p.pulse = sinceType < 2800 ? Math.max(0, 1 - sinceType / 2800) : Math.max(0, p.pulse - dt * 0.0004);

  // ხ̫̔̕თ̖̝ܿ̒𒀋̖͇̗̪݇̆ᚌ̗̅͊ე̥༄̄̓ᚕ̧͈͎̗གྷ̦̻𒀆̜̈༫̡̥̄̏ᛟ̎̈́̂̃ᚅ̯̭̲̰𒀡͈̬̖̉ᚎ̝݄̖̳͌ͅᛘ̟̯̽̃ᚓ̝̕ᚗ̗̐̌ͅᚃ̣͂ܪ̦̑
  const targetTremor = inter.typingBurstIntensity;
  p.typeTremor = p.typeTremor + (targetTremor - p.typeTremor) * (dt / 150) * ms;
  inter.typingBurstIntensity *= (1 - dt * 0.0028);

  // ᚱ͉̿ბ̗͇̙ͅჳ̹̍̒̋ყ́ᚓ͉༞̆ფ̳̦̼༆̒᚛͎̤̲ͅᚉ̑ჲ́̊̀ሾ̤ܘ͇̐͌ᚃ̘̺ე̠̯ቄ̣̱̟́ܣ̡ܼ̪̉̑𒀑̢̜̹̒ሗ͆𒀌̪̞͂ለ̰̄̋̆༛̠̂̽ܩ̺͇̔͊𒀛̮̣͋̈́ო̭̀𒀻̤༮͎̮́𒀏̞́̀ყ̖̈͋̓ᚃ̣͆̊ܵ͋̓ᚏ̩ᛐ̙ᛟ͉̺̓
  const delRatio     = inter.typing.count > 5 ? inter.typing.deletions / inter.typing.count : 0;
  const targetCrack  = Math.min(1, delRatio * 2.2);
  p.crack = p.crack + (targetCrack - p.crack) * (dt / 1500);

  // ሙܾ̬̋͂͊̎ᛛ̢ᛯ͈̊ܨ̎༚̦̆ᚗ̨̠ሪ̻̘͉ჳ̪̐ც̙̳̎͋ხ̊͆̔̈́ሽ̢̝̱̠ܽ̽́ᚒ̱̍͋͊༡̣̇̄༞̨̞̞
  const targetErasure = Math.min(1, delRatio * 3.2);
  p.erasure = p.erasure + (targetErasure - p.erasure) * (dt / 1000);

  // 𒀎̢͎ᚸ̬̩͌ܞ͋̓ᛇ̏̈́ᛞ̺͎̀̐༝̬ܵ̕𒁇̭ረ̯ሿ̞̼͍̗݀መ̱̐ᚷ̒͌ܩ̋̈́̆ܙ̗̀͊𒀄̨̬̃́ლ̲̐̓
  const scrollSpeed = inter.scrollSmooth;
  const targetSmear = Math.min(1, Math.max(0, scrollSpeed - 0.08) * 25);
  p.smear = p.smear + (targetSmear - p.smear) * (dt / 120) * ms;

  const isGentle = scrollSpeed > 0.005 && scrollSpeed < 0.08;
  const targetBreath = isGentle ? Math.min(1, scrollSpeed * 14) : 0;
  p.breathDepth = p.breathDepth + (targetBreath - p.breathDepth) * (dt / 600);

  const targetSink = Math.min(1, inter.scrollVelocity * 60);
  p.sinkDepth = p.sinkDepth + (targetSink - p.sinkDepth) * (dt / 180);

  // ༶̓̐ͅܟ̩ვ͎̏̓ሑ̺ቂ̮͎͌ᛕ̭ሽ̘̳̥̓ཁ̞̋༫̏ሪ̓͌ܞ͎̜́̔༦̠̓̎ტ̥̗̣̂༴̳̺̅ሣ̏ᚹ̮᛭͇̾ሄ̝̳̫̼༤̨̎͌̚
  // ᚣ̳̑𒁁̧̭̳ჲ̞̯̓̓კ͍ͅܯ̌ᛠ̨̜̬́ჭ̨་̽
  if (inter.scrollVelocity > 0.002) {
    p.drowning = Math.min(1, p.drowning + inter.scrollVelocity * dt * 0.0018);
  }
  // ܡ̗݆̖̖̥́̓თ̠̻𒀂̜̜̐݃̔̈ሊ̩̀ᛃ̩༤̞ཁ͊ ̙̓ͅ༮̾̅̉
  p.drowning = Math.max(0, p.drowning - dt * 0.000025);

  inter.scrollVelocity *= 0.94;
  inter.scrollSmooth   *= 0.97;

  // კ̭̃ᚇ͉͆ሥ̫͇݀̕ሁ̹̪̘̅ო̳̬𒀝̟̺ܖ̓ͅᛒ̟̠ሺ͍݄̝͊ᚠ͆༣̄̅ཀ̩͇̿͌ᛏ̨̯̓
  const targetInjury = inter.resizeInjuryRaw;
  p.resizeInjury = p.resizeInjury + (targetInjury - p.resizeInjury) * (dt / 60);
  inter.resizeInjuryRaw *= (1 - dt * 0.003);
  p.resizeInjury *= (1 - dt * 0.0012);
  if (p.resizeInjury > 0.1) {
    p.convergence = Math.max(0, p.convergence - p.resizeInjury * 0.002 * dt);
  }

  // ܚ̗͋༒̂̋́𒀨̑𒀹̆̆̓ᚁ̲̼̗ሿ͋̀𒀡̠̘მ̄ნ̜̲̩༰̰͊́ͅჴ̩̍̊͂༱̙͆̇༂̧ቅ̎ሩ̟̆͊̚
  p.split = inter.actionSwitchRate;
  inter.actionSwitchRate *= (1 - dt * 0.003);
  const targetDesync = Math.min(1, inter.actionSwitchRate * 1.6);
  p.desync = p.desync + (targetDesync - p.desync) * (dt / 200) * ms;

  // །͈̣̍𒀀̣̎̓ხ̎͂𒀫̢̙̟͋ტ̢ჵ̯̍͌̌ᚏ̱̹̓̉ܥ̧𒀚̢̟̩̏ሶ̨̨̺̑𒀻̮༚̭ყ̹ᚸ̧̘̖̞༝̻̪̐̄༛͎̀ᚖ̠̙̜།̪͇̓༦̇ሾ̩ᚠ̼̆ᚖ̋༁̙̝̏ͅሚ͆შ͈͍̽𒀟̰̙̪̂ሠ̤̐́̓༌͊̍̕ᚉ̖̬̀̇ო̟̈̄ᚶ̹ܐ̀̀ᚸ̝
  const shift   = p.skeletonShift;
  const eCX     = 0.5 + shift;
  const eCY     = 0.260;
  let eyeTarget = 0;
  for (const hp of inter.hoverPoints) {
    const dx = hp.x - eCX, dy = hp.y - eCY;
    const d  = Math.sqrt(dx * dx + dy * dy);
    if (d < 0.22) eyeTarget = Math.max(eyeTarget, hp.intensity * (1 - d / 0.22));
  }
  p.eyeIntensity = p.eyeIntensity + (eyeTarget - p.eyeIntensity) * (dt / 400);

  // ܫ̙͈ܻ͇̻̓ᚮ̱ܤ̯̬̍̌ܭ̩̭̹̈́𒀛̖
  const breathLift = p.breathDepth * 0.08;
  const smearDim   = p.smear * 0.12;
  const erasureDim = p.erasure * 0.10;
  const drownDim   = p.drowning * 0.22;  // 𒁁͆̆̅̎ሹ̣̔͂̀ᚩ̜̋ᛔ̪́̅̑༃̙̃̑͌᛭̰̩͎
  // ༭̭༂̘༦̓𒀇̱̰̑ძ͋̒ᛯ̧̝̝̼̊̆݃͌ሓ̔წ̞ᚙ̥̹̒̍ᛝ̯̫̀ᚘ̼𒀦̯̹̒ཁ̪͂̎́ᛡ̺̻̆̓ჹ͎ᛀ̓ሊ̨͇ሌ̧̦̏̊
  const baseBright = (state.environment.lightMode && !state.environment.darkMode) ? 0.34 : 0.26;
  p.brightness = baseBright + p.convergence * 0.46 + breathLift - smearDim - erasureDim - drownDim;

  // ሂ̝̲̈̒ᚐ̟͎ჸ̑̽ͅህ͋ᚗ̡̉̂ᛉ̪̫̠͌ჸ̱̆̅ሖ̩͊𒀌̡͎̂̇𒀇̜̍ᛑ̭ܤ̢̙̈̓ܝ̯༜͈͉̯̖̰̠̈݅̾ჶ̠̦͎ܲჱ̜̠̘ላ͌ܢ̲ᚓ̢͍̺̈ሟ͋̃གྷ̞̥̒̓𒀿̨̹̘̦ᚾ̥
  for (const hp of inter.hoverPoints) {
    hp.age       += dt;
    hp.intensity  = Math.max(0, hp.intensity - dt * 0.000095);
  }
  inter.hoverPoints = inter.hoverPoints.filter(hp => hp.intensity > 0.01);

  // ሱ̲̖ᚥ̲̀ᚒ̏̿༔̳̉შ̃̄ᚉ̪ჳ̘ܸ̇͋͂̀̓ᛛ̄̎̑𒀭͇̅ͅᛛ͉̻̂̉ჶ̄͆̔ჵ̟̳̈́ᛣ͍͊𒀙̠̣̥̐ᚘ̖ჭ̩𒀐̏𒁄̧̰ܸ̞̫̍́༑ܸ̏́ሩ̖̥̎͂𒀚̢̦̏𒀾̨͍̅ܡ̜̞̀̋᛬͋༃̢̅༱̼̗̾
  const mc = state.mirrorCursor;
  const spring   = 0.0028;  // ᚓ̓̑ᚄ̤̮ͅཀ̭ᛞ͇̖ᚠ͈̫̌̎𒁍̌͌ᚌ̆ሪ̘ܐ̨༚̩̘༵̯͆ܶ̊მ̲̔ᚂ̱̼̰̀༪̄𒀍̬̅༐͋̉̓̚ቂ͇̲̗̬᚜̘ᛑ̫̟͊ჲ̭̍༛̠༔͉̒̒ᚬ̒𒀪̏̔̃პ̤̀̽ᚗ̲̩̙̤̪̒͋ܵ
  const damping  = 0.88;    // ܘ͇̻͎̓ᛉ̿ͅሊ̝̞̽ᚯ̧̽ሓ̻̔̃༯̲̲̾ܮ̨̥̣༙̹̙̤̠𒀁̥̒̔𒀦͎̝̩̀ᚂ̧̧̝̳̓̉ܵͅხ̔́́ሚ̠̎̎ͅሺ̥̥͌̕ܞ̘̦̐̾𒀫͊̅̕ር̭̔ჵ̤̝
  const predict  = 0.12;    //  ͉̽̊ᚍ̹̼̭̗𒀨̇𒀄̪̉̇̆ზ̱რ͈̀̇𒀝̲̍̐̕კ̭ᚖ͈ᚋ̐̾̀ ͍͂ბ̨̤̋̔ჩ̞̈́̋ܘ̪͂ቈ͍̘́̑͂ܶ̆𒀩̯͈ᛦ̱ᛋ̢̠̹̆݃̿ᚼ͂༑͎༘̝̀̊𒀺͇̣̄ܫ͍̜̎ᚚ̘̅ᛑ̺͍̈́ͅᚓ͊𒀀̪̱̾̽ ̆̀̅̚𒀒̹̬͉ფ̙́̊ͅ༝̲̰͋
  // 𒀟̰𒀵̡̈̚ܛ̺̯͋́ܦ͉̅ტ̻݆̩ܱ̅̐̃რ̃͌̎ᚥ̾ᚔ̊̇ᚏ͍༂̧̠
  const predX = inter.cursorX + (inter.cursorX - mc.x) * predict;
  const predY = inter.cursorY + (inter.cursorY - mc.y) * predict;
  // ܹ̜ሔ̦̒͆ܒ̯̣̞ሁ̹༵̈́̚̚ሌ̼̠̳ᚃ̂𒀧̜̯ሽ̡̋̾̃ ̡̞᚛̨͇ሞ̬̲͉᚛͉̂̚̚༡̫̅̓̓𒁉͋𒀉̥̍̃ܗ̮͋ᚭ̊̾༱̢̼͉̜𒀖̏𒀊̋͂ᚏ͍̏༔̺ᚯ̧̥̤ᚰ̤ᚲ̢̽༗̑𒁁̽ჳ͉̳̇᛫̢̮͎̏ሽ́𒀅̢͍𒀱̣ᚑ̠̽̾̌༐̣̙ᚁ̽ᚉ̘̹̮𒀽͇𒀵̦
  const noiseX = (Math.sin(Date.now() * 0.0013) * 0.4 + Math.sin(Date.now() * 0.0037) * 0.2);
  const noiseY = (Math.cos(Date.now() * 0.0017) * 0.3 + Math.cos(Date.now() * 0.0029) * 0.2);
  mc.vx = (mc.vx + (predX - mc.x) * spring * dt + noiseX) * damping;
  mc.vy = (mc.vy + (predY - mc.y) * spring * dt + noiseY) * damping;
  mc.x += mc.vx;
  mc.y += mc.vy;
}

// 𒀼̱͉̇᚜̬̄ჯ͍́̓̾ሺ͉͆ܠ̲ᚕ̡̳̿ܝ̹̻̥ᛓ̤̓༞̉̅̎̀𒁎̩̚ም̙͂͆̍ᚓ̡͉̈ሰ̡́͌ო̱̇̒ᛋ͈̽პܑ̺̪̰̻͌ཇ͇𒀝̳̄ሡ͊̉༓̢̡͂̑𒁄̻͎̱̠ܰ̈ᛔ̬͈̗̾მ͎̫̃͊ሜ̠̙ღ̝͆𒀄͂̎ᚅ̜̞͆
function rebuildShards() {
  const canvas = document.getElementById('mirror-canvas');
  const W = canvas.width  = window.innerWidth;
  const H = canvas.height = window.innerHeight;

  const env  = state.environment;
  const e    = state.portrait.env;
  const sk   = state.portrait.skeletonShift;

  // ᚴ̞͇ܾ͎̀ሙ̯̍̒ᛗ͈̒ሷ̮̯̕̚𒀋̤ሐ̡́༫̥𒀜̢̩ᚏ̮̞̽༑̈́ላ̧ܻ̹̾ͅჟ̕
  const isMobile = env.touch && W < 900;
  const baseRows = isMobile ? CONFIG.shardRowsMobile : CONFIG.shardRowsDesktop;
  const baseCols = isMobile ? CONFIG.shardColsMobile : CONFIG.shardColsDesktop;
  const rows     = Math.max(8, Math.round(baseRows * e.shardDensity));
  const cols     = Math.max(6, Math.round(baseCols * e.shardDensity));

  // ე̢̒̓̊ཆ̩̪ܨ̀̇͆დ͆𒁀̨̺̳́̃݊̄̽ᛐ͍͍̀̌ሗ̧̇̄ܟ̈́ሿ̙̟݂̖̈̋ང̩᛭̰̭̑𒁊̜̙̋̑ᛨ͌𒀐̟́̌̌ሩ̠ܧ͊༈̪̓̊༼̯̪̭ს̔𒀇͉̪̿༮̠̩ም̞ᚈ͍
  // ᚡ̻༘ܾ̙̖͋̀̄ᚅ̧̱̻̲𒀫͎̖̉𒁎̑𒀹̡̻̕༼̨ሔ̼̂̿᛫̢̳͎̀ܝ̲ܷ̀̓̌ሶ̨̤͇ܴ͇̻ܽ̊̕ᛃ̨თ̼̖͆ܙ̟༻̻̎̀ᚯ̳ᚇ̨̅̐
  // 𒀫̳̻̣̰᚛̈̓͆͌𒀉͂𒁏͎̝̫ᚈ̯̥͆ͅ𒀋̩̭̔̐༥͍̟̈́̏ᚗ̞𒀌̣༄̨͈ᚥ̹̞͌𒀰̫͊͊གྷ̺̩̝́ᚣ̗̔̂ሒ̪̥̆̿ᚄ̖̝̻̀ܿ̑𒀛̹̜̌ᚓ̤პ͆̎ͅ༸̈
  const jit = CONFIG.shardJitter * (1.2 - e.symmetry * 0.5);

  // ᛔ̦̐ბ̺͌̅ფ̕ቀ̜ሩ͆ჟ̃ᚘ̲͈̤𒀧͈ሲ̦̞̍͆ሞ̤ტ̼̼ა̅ᛆ̉ჵ̆ᛢ̡̱̘̘𒀌̬̃́𒀌̯̼̿̒༲̯̈̎ቅ̳ᚙ̲̋̓წ̮̍ሗ̥̟̻ჲ̡͇̂ሲ̍̃ཇ͎̫̦ረ̺̘̳̗̺ܰ́ܜ̟̓ܘ̮ჶ̤̩̞̒ᚚ̢̙ᚈ̝̦̩̓᛬̬̳̟
  const pts = [];
  for (let r = 0; r <= rows; r++) {
    pts.push([]);
    for (let c = 0; c <= cols; c++) {
      const bx   = (c / cols) * W;
      const by   = (r / rows) * H;
      const edge = (r === 0 || r === rows || c === 0 || c === cols);
      const jx   = edge ? 0 : (Math.random() - 0.5) * (W / cols) * jit;
      const jy   = edge ? 0 : (Math.random() - 0.5) * (H / rows) * jit;
      pts[r].push({ x: bx + jx, y: by + jy });
    }
  }

  // ሑ̼̬ܪ̭̍̀𒀵̨͇̎̿ᛝ̨̟̿ᚒ̢̖̲ܻ͍̲̊̄ሿ̡𒀁͎̎̚̕ᚍ͍͋͊შ̡͍͇̌ᚁ̧̱͉́ᛒ̫ܹ̟̐𒀅̳ᚔ̡̠͎̋ܬ̏̽ܧ̗̿͊𒀳̼́𒀚̿𒀨̡ხ͋̈́𒀂̟̮ᛜ̟༃̨͉̬̆
  state.shards = [];
  for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) {
      const tl = pts[r][c], tr = pts[r][c + 1];
      const bl = pts[r + 1][c], br = pts[r + 1][c + 1];

      const makeShard = (v1, v2, v3) => {
        const cx = (v1.x + v2.x + v3.x) / 3;
        const cy = (v1.y + v2.y + v3.y) / 3;
        const dens = portraitDensity(cx / W, cy / H, sk);
        return new Shard(cx, cy, [v1, v2, v3], dens);
      };

      state.shards.push(makeShard(tl, tr, bl));
      state.shards.push(makeShard(tr, br, bl));
    }
  }

  // ᚗ͉̃͌ ͈ᛩ̠͉̣̥༛̺̿̍ᚿ̗̻́ᚿ̼̬̗̐ᚦ̣̥̦̚ᚯ̺̱̣̓༝̎ᚌ̡̊ሱ͍̫͇̂ܣ̨𒀈̽̏̂̀ᚆ̬̣ܿ̐༤̬̋ᛔ̤̺̽̂𒀞̏̋̊𒀤̦̖̭̈݀̚ᚐ̤ሡ̏ܯ̳̭̕ᚰ̎ᚚ̻̹̩ሱ̩̻̬༞̠̊̋ᚠ̱̻̑ᚓ̲́͌̓ს̲̫̈ᚾ̭̯͌ᚌ̗̣̼༩̢̳̠̝უ̩̘̳̀𒀔̼̘̖ჰ̧̙̟͈́̎݇ᚑ̥̈
  initNoise(W, H);
}

// ܩ͈̿ༀ̗̈́ᚅ̒̆ᚺ̩ᚼ͂༫̰ᚫ̭̿ᚩ͇͍̖݂̣̔კ̘͇ᚇ͇̖̒̓ᚇ̟́𒀜͎ሠ͆ᛣ̀ᚊ̨̂̾̿ᛧ̼̣̿ܬ̕ჯ̤̟̉ܮ̀͋̇̀ᛮ̼̀̏̕ᛌ̰ᛎ̅̈𒁇̢݂̀̀ቅ̞̈́ᚅ̩̐̾𒀏̫̋̓ᚺ̹̍̑ᚐ̇̆ᚄ̊̃̈́ჳ̹̿݊̒̏̔ᚘ͆̓̔ᛜ̞̲̘̻ል̮ᚇ̠̞̋̇ᚂ̤̔̐ܒ̍̔́ᚷ̉

// ܩ͇̠̔́ܬ̙̋ሞ̘̊ሥ̰̈́̃ლ̼̝͌̀𒀓́ͅჱ̮̗̞̊᚜͇̞́̕თ̤̯́პ̅ܖ̓შ̢̼ܱ̣̤̯𒀷̲̃͌ሤ̈შ̖́𒁂̂̃ܨ̂̌̿̚ᚼ̠̬̐̊ܢ͇̒ᚥ̯̯𒀒̖̒̚ჹ̘̉͋ᛐ̨𒀎̄̏ᚢ̡̊̉̉
function shardHash(idx, seed) {
  let x = Math.sin(idx * 127.1 + seed * 311.7) * 43758.5453;
  return x - Math.floor(x);
}

function initNoise(W, H) {
  const nW = Math.floor(W / 5);
  const nH = Math.floor(H / 5);
  state.noiseFramePool = [];

  for (let f = 0; f < CONFIG.noiseFrames; f++) {
    const nc  = document.createElement('canvas');
    nc.width  = nW;
    nc.height = nH;
    const nctx = nc.getContext('2d');
    const id   = nctx.createImageData(nW, nH);
    for (let i = 0; i < id.data.length; i += 4) {
      const v = Math.random() * 255;
      id.data[i] = id.data[i + 1] = id.data[i + 2] = v;
      id.data[i + 3] = 255;
    }
    nctx.putImageData(id, 0, 0);
    state.noiseFramePool.push(nc);
  }
}

// ̮̗͇ܳ͊ቄ̣̻̆ჶ̺̭̓ᚑ̤͎̂ሷ͆ს̜́̏ᚄ̓ͅܠ̭̠͍̖ܣ̱͍̱͆༲̻̾

function initDriftPolys() {
  const W = window.innerWidth;
  const H = window.innerHeight;
  const isMobile = state.environment.touch && W < 900;
  const count = isMobile ? 90 : 200;

  state.driftPolys = [];
  for (let i = 0; i < count; i++) {
    // ღ̖̻̀ܳᛀ͆̓ᚖ̹̺͆ფ̊ჸ̢̦ᚄ̟ზ̔ᚋ̱ჲ̧̓ᚏ͆̀მ̤̦̙̊ᚏ̓̍𒀜̖̠ჱ̠̭̪̄ჟ̻̤̠͋რ̩̃ჟ̠̀᛭̩̲̦ܾ̭̟͎̒̎ᛔ̭̗̪̠̄̒݀̈́̍
    const sides = 3 + Math.floor(Math.random() * 4);  // ᚗ͍𒀲̀̀ი̳̠̽ჸ̜̎ᚘ́̚ܩ̡̤́̐༊̦̬̈́ჵ̢ܭ̧̘̝̂ܓ̲𒀛̟̹𒁏̟̄̑༑̧̨́́ᛟ͍̚ܨ̝̉̃𒀔̨̠̀𒀳̳́𒀪͈ཅ̻͉̆༆͈̮̪̐ᚨ̨̔̈̀ቃ̳̀͆̚ሑ̨͇̀͌༠̂ᛕ̓̈́𒀳̧̟͂̽ᛒ͋ܯ̘𒁆̧̃̐ᚡ̞́༏̫̊ჶ̪̤̋༃̹̃ ̰͈̫̥ሚ̳̩̓̃ܦ̦̇
    const depth = Math.random();                        // ܓ̍ሲ̖̖̾༂̜ს͍̮̒ሸ̻𒀑̳ཅ̢̰͍̍༜̱̀̂̚შ̌̓ራ̤ͅ᛬̮̍ܬ̡̗̙̞̑͆ܺ̄ܣ̥̫ᛰ̲̙̦̈᛬̍ሱ̧̂̎ᛠ̲̩͆༇̍༫̖̍𒀦͈͆ሄ̡̪ቅ̋ც̀͆̋̔
    const size  = 4 + depth * 18 + Math.random() * 10; // ᚱ̗̞̫́ሕͅ༩̏ܙ̝͇̞̬ག̅༿̧̖̃ᚌ̦̮̹ܻ̪̆̉̄̐༒̤̙̝ཇ͈̀ᚊ̼ხ̐ͅ𒀍̨̼̲̈შ̥͆ܔ̹̈͋ܗ̡̚ᛣ̘̦̅პ̬̃
    const angle = Math.random() * Math.PI * 2;

    // 𒀐̭ᛍ̓̊̐ᚣ̿̎𒀇̙̓́ᚬ̞̓ሷ̬̾̈́̓ო̯̝ᚔ̤̥̋́ህ̬͈̻̒ᛄ̳́̿ܨ̖̭̄መ̉ሷ̢̾̿ሒ͎͉ᛌ̜͋̃𒀬̜̃̋̾ܩ̝̏ܢ̋ ̠̙̓́
    const verts = [];
    for (let v = 0; v < sides; v++) {
      const a = (v / sides) * Math.PI * 2 + (Math.random() - 0.5) * 0.6;
      const r = size * (0.6 + Math.random() * 0.4);
      verts.push({ lx: Math.cos(a) * r, ly: Math.sin(a) * r });
    }

    state.driftPolys.push({
      x:     Math.random() * W,
      y:     Math.random() * H,
      vx:    (Math.random() - 0.5) * 0.3,
      vy:    (Math.random() - 0.5) * 0.3,
      depth: depth,
      angle: angle,
      spin:  (Math.random() - 0.5) * 0.003,
      verts: verts,
      // ܼ͇̦̱ህ̕ᚄ͎͇͂𒁊̬̑ᛗ̀ሔ͉̳ܱ̤̈́ሔ̧̪̬༯̱̤̇̉ܵ̋̋̍̕ᚇ̦́̎ᛊ͍̇̓̕ሴ̃ሽ̹̻́ჳ͇̭̠̇ܢ̀ͅ𒀛̻̝̥͊ག̝ܱ̪̭̀͌̂ራ̫̤͎́ᚙ̼̘ᚉ̹̇̓̎შ̚ᚏ̈́̿ༀ̯̇̂̄𒀍̧̠ܥ̖̼ᚊ̰͈̤͂ሢ̢̳༙̩̽̀̈́̇ᚱ̥༚̍ܙ̜̳̌ላ̢̠͌̂ᚔ̠̫̔̔𒁈̀ᚑ̳̰́̉
      homeX: Math.random() * W,
      homeY: Math.random() * H,
      phase: Math.random() * Math.PI * 2,  // ᚁ̓͂𒀝ܱ͍̑̏ͅቃ͇̤̀ᚒ̦ᚻ̦̯̀͋ᛂ̡̱̮̓ᚋ̍̏̏̊𒁌̡̙̭̣ር̼̣ტ̙͋ܮ̿ჯ̨̣͌𒀈̪ჶ̮დ̩̞̂༴̯̍ᛅ̃́𒀆̧͂́
    });
  }
}

function updateDriftPolys(dt) {
  const W   = window.innerWidth;
  const H   = window.innerHeight;
  const mc  = state.mirrorCursor;
  const t   = Date.now() * 0.001;
  const p   = state.portrait;
  // ༤ܹ̈́ͅሊ̭̯̌̓ሰ̄𒀽̢̝ཆ̳𒁉͎̱ͅც̗̅̈́̿ཅ̯ܯ̭̈́ᛩ͌̅̕ᛖ̰̟
  const faceStrength = Math.max(0, p.convergence - 0.15) * 0.6;
  // ቁ̬̠༠̃ჰ̥̜̗̋𒀡̗̓͋መ̧̮̲݈̫̖̓̚ང̙ღ̞༑̤̪̘̙𒀼̯̓̊̅𒀃̨̢͇̱́݅́ძ̒𒀀̢̏̐̄
  const alignPulse = Math.max(0, Math.sin(t * 0.08) * Math.sin(t * 0.13));
  const align = faceStrength * alignPulse;

  for (const poly of state.driftPolys) {
    // ሴ͇̼̽̄ቄ̎༇̠̰̂̿ვ̳̩́ც̥́ვ̻̱͇̑რ̧̾𒀻̧͎̍̾ᚃ̨̮̋̓ܤ̨ሆ͇̺́ფ̦̗͉ܡ̲̓̾ܟ͍̈́ͅཅ͍̝̩̻̥ܽ𒀏͂ᛇ̪̔̒̄ჵ̪ܘ̳̃͊ᚒ̣̞̑̓ᚕ̭̦̒̋༕̪͉̋̃ᛘ̢̦̞̙ቇ͈͍̒̕།̤ᚁ̞͊ᚐ̘༷̦༘͈݈̦̄̆͂́̄̓̊̍̎ᚇ̜͊̋ᛟ͉ᚐ̞̈̑𒀴̻̥̈́̇ል̰̞̪́ᚣ̮͍̑̅
    const depthFactor = 0.3 + poly.depth * 0.7;
    const dx = mc.x - poly.x;
    const dy = mc.y - poly.y;
    const dist = Math.sqrt(dx * dx + dy * dy) + 1;
    const mouseRadius = 180 + poly.depth * 100;

    if (dist < mouseRadius) {
      // ሿ̚𒀠̰̫̈́ሾ̣͌ჲ̩̦ჟ̠̞̭̇ܢ́კ͉̙̇ᚍ̌̿༱̍༔̉̇ᛢ̾მ̲̌ᛟ̜᛭̝༃̘̠̕ᚐ̃̓ሄ̲̉̈́ᛘ̱̩̮͊ᛒ̡̲̓ͅ𒀓̊ᚎ̚ᛠ̨̯̋ͅ༏̩̺̿༧́ܩ͉̊ს̤̒̑̃ᛊ̝͉̍̔ფ̓ნ̞́͋ჵ̡̇̄𒀃̲𒀯̄͌ሰ̲ܷ̤͌̓̾ᚋ͆༕͋ͅ༯̧̞̋𒀣̡̖͇̂ܓ̲
      const force = (1 - dist / mouseRadius) * 0.08 * depthFactor;
      const repelOrAttract = poly.depth < 0.4 ? -1 : 1;
      poly.vx += (dx / dist) * force * repelOrAttract;
      poly.vy += (dy / dist) * force * repelOrAttract;
    }

    // ሠ̖ܷ̞̭͉̉̍ܝ̧̲͆ሼ̻݅̀́ᛖ̻̈͌̀𒁈̺̩͌ᛋ̽𒀢͋̂ͅ༫̟̘ܫ̳̮̃ᛒ݆̫̏͊̅̃ͅᚫ̌𒀈̬̮ܿ̑̐̕ͅܖ̫დ̮ს̢́͊̆ܮ͍̼͂ራ̬̯̈ᚋ̢̢̀𒁎̄ᚍ̼𒀁̦͇̋݅̑̕ཁ̀ჳ͍ჺ̡ሾ̮̝̯༫̑𒁂̪̠̄᚜̎𒀎̖̝
    poly.vx += Math.sin(t * 0.15 + poly.phase) * 0.003;
    poly.vy += Math.cos(t * 0.11 + poly.phase * 1.3) * 0.002;

    // 𒀉̙ᚙ̫̓ܣ̧ᚈ͍͈݂̠̘̅ሱ̢ܦ̘͇̎ᛌ̻̟͈̓ᚗ̡̮ჺ̘ᚋ̜̫̀̕
    if (align > 0.01) {
      // ჸ̹̖̀̐𒀵̄ტ̪̬̿̀ᚷ͇ᛑ̪͈͉ᚾ̦̼̌̾ሡ̻𒁊̙͎͍̓ሶ̮̓̽̔ሆ̠̹̦̽𒀦͊წ݂̙̈́𒀜͋͋ჴ̞̤
      const homeNx = poly.homeX / W;
      const homeNy = poly.homeY / H;
      const density = portraitDensity(homeNx, homeNy, p.skeletonShift);
      if (density > 0.2) {
        const pull = align * density * 0.02 * depthFactor;
        poly.vx += (poly.homeX - poly.x) * pull;
        poly.vy += (poly.homeY - poly.y) * pull;
      }
    }

    // ܦ̘̻̍̐ძ̩́̏ᛯ̤́ᚢ͇̞𒀄͋ܧ̝ᛇ͊ᚔ̦̒ჴ̰𒀣̝ͅᚑ̋̏ͅ༐̈́ᛋ̻͉̎̒𒁃̘̳̏༈̏̓̿ᚻ̨̊̂ᚐ̕𒁌͍̹
    poly.vx *= 0.97;
    poly.vy *= 0.97;

    // ᚖ̲ჴ̡̱́݁͋̍̋ᚍ̦̅̐𒀉̳̀ᚅͅᚅ̿ᚆ̱ሒ̝̋༣̦݈̜͊მ̥̞̆̌𒀋̘̗̩̏ሙ̖̙̼
    poly.x += poly.vx * dt * 0.06;
    poly.y += poly.vy * dt * 0.06;
    poly.angle += poly.spin * dt * 0.06;

    // ሄ̦̫̓ሖ̱̲̃ሐ͉̽̾༌̤̽ც̻̯̰̇𒀧́༬̞̤༉̏̊͆ლ͉̍ᛅ̳̻ᚨ̓მ̖̆𒀍̪̂̉̀ሌ͍̩͈̠̆݉༥̼͎ܵ̈ͅᚎ̜̽̇ᛜ̦̳͌ჯ̹̝͉̾̃݊݉𒀯̆ܧ̈ͅᚔ̋̄̇ყ͌ᛒ̟̌̍ჷ̉ܢ̦̻̪ᛏ̀̅ᛛ̻̪
    const margin = 40;
    if (poly.x < -margin)     poly.x += W + margin * 2;
    if (poly.x > W + margin)  poly.x -= W + margin * 2;
    if (poly.y < -margin)     poly.y += H + margin * 2;
    if (poly.y > H + margin)  poly.y -= H + margin * 2;
  }
}

function drawDriftPolys(ctx, W, H, p, t) {
  const e = p.env;
  ctx.save();

  // ቅ̺̓̔ᚂ̺𒀙̲ᚹ͂𒀻̢̞̑̆ܕ̭𒀡̘̻̀ܺ𒀂̭ܗ̨̲̉ᛊ̩͉̆̅ᚓ̡𒀗̯͆̋𒀺͉̏̐ᚉ̤̟̉ሳ̈ყ̰̹̃შ̳̌̑ᚓ̺̹̗̆ሪ̮̺̌ሕ̧̗̈ᛎ̳̬́̕ሂ͈𒀄̜̮̀ཁͅሾ͇͉͍̋ფ̯͍̐ვ̻༡̹̮̅͋ო̥̐𒁏̨̲͂𒀪̢̈́̆༴̭̌༑̙͍̠̅ሺ̱̳̋̓ᚮ̢ͅᚁ̈́̄
  const sorted = state.driftPolys.slice().sort((a, b) => a.depth - b.depth);

  for (const poly of sorted) {
    const depthAlpha = 0.015 + poly.depth * 0.055;
    const breathe = 1 + Math.sin(t * 0.7 + poly.phase) * 0.08;
    const ca = Math.cos(poly.angle), sa = Math.sin(poly.angle);

    ctx.beginPath();
    for (let v = 0; v < poly.verts.length; v++) {
      const lx = poly.verts[v].lx * breathe;
      const ly = poly.verts[v].ly * breathe;
      const rx = poly.x + lx * ca - ly * sa;
      const ry = poly.y + lx * sa + ly * ca;
      if (v === 0) ctx.moveTo(rx, ry);
      else ctx.lineTo(rx, ry);
    }
    ctx.closePath();

    // ܸ̫̰͍ᚘ̔ᚃ̧̇̀𒀖̉ᛃ̜͌ᚈ̯𒀤̢̗͊ܟ̢̲͊̀𒀓̮̄ᚶ̺͂
    const lum = 0.15 + poly.depth * 0.25;
    const fR = Math.floor(e.paletteR * lum);
    const fG = Math.floor(e.paletteG * lum);
    const fB = Math.floor(e.paletteB * lum);
    ctx.fillStyle = `rgba(${fR},${fG},${fB},${depthAlpha * 0.6})`;
    ctx.fill();

    // დ̣̎͋̉༂̺̳̝͊ܘ̪́ᛦ̳ᚍ̃ᛎ̙̙͋ᚁ̡̙̞༘̙͎̣͆̓༩͎̾̚ᛦ̪დ̭̒ᛯ̞ሲ̩̎̈ቀ̨̤̊ሏ̚წ̓ჰ͌ም̨̞̆ᛁ̭͌́̐ܨ̫̻̮ს̞̼̎ᚎ̡̜ሜ́͌ᚖ̣̗̿̏ᚠ̓̚
    ctx.strokeStyle = `rgba(${Math.min(255, fR + 40)},${Math.min(255, fG + 35)},${Math.min(255, fB + 50)},${depthAlpha * 0.45})`;
    ctx.lineWidth = 0.3 + poly.depth * 0.5;
    ctx.stroke();
  }

  ctx.restore();
}

// ༑̫̜̓ᛚ͈̓༸̈̂̄ᚅ̖̕ሞ̥͋ܖ̯̞ܽ

function initMetaballs() {
  const W = window.innerWidth;
  const H = window.innerHeight;
  const count = 5 + Math.floor(Math.random() * 4);  // ლ̮̦̅ᚃ̪̽ሥ̞̻̎𒀗̟̝̟͉༡̞ሸ̠͉ሚ̨̫̉̓ᛰ̩̹༎̜̯͂͋༎̪́ሊ̳͈̔̕ላ̧̠͇ܻ̮̃̏̄̕𒀭́̄༞̑ᛌ̲̀̍ܚ̞͌̽͊𒀝̧͆ሦ̥̙̤ᛕ̫̤̀ሚ̧͍̜̘ᛋ̣ᛐ݆́̏̾̏͊༁̤̤ཇ̢̍̕ᚩ̮ᚂ̩̚ͅᚌ̨ა̟́ᚂ̳̚ᚦ̮̗̃

  state.metaballs = [];
  for (let i = 0; i < count; i++) {
    state.metaballs.push({
      x:      Math.random() * W,
      y:      Math.random() * H,
      vx:     (Math.random() - 0.5) * 0.15,
      vy:     (Math.random() - 0.5) * 0.15,
      baseRadius: 40 + Math.random() * 80,
      radius: 0,  // 𒀽̨̓𒀝̟̪͊̽ᚐ̣༠̟̤̅̈ᚄ͇̄ང̬̉𒀺̪̏̏͊ძ̆ᚕ̰ᚋ̼̬ᚈ̏𒀉̣̚ܣ̣̩̓𒀢̀̔ᚤ͇̈́̌༨͍̥̜̉ሚ̢༠̟̋̚̕𒀒̉ᛒ̲ხ̠̌𒀒̉̌𒀛̨̧͋̉ܬ̫̊̏ᛮ͉̱̂ቁ̑ᛧ̟̥̄̋ᚆ̼̱̙̊ჩܑ̺͇̋ღ̱͋̐ᚉ̔͆ሲ͎͍͆ᚚ̭̄ᚼ̹ሱ̫̔́̔
      phase:  Math.random() * Math.PI * 2,
    });
  }
}

function updateMetaballs(dt) {
  const W  = window.innerWidth;
  const H  = window.innerHeight;
  const mc = state.mirrorCursor;
  const t  = Date.now() * 0.001;

  for (const mb of state.metaballs) {
    // ̻݁̈́𒀀̆ᚘ̡̠̱̔̋ܳ᛭̖̬ᚓ͉̲̉ᚚ̔ᚃ̺̜̎̕𒀥̠̣ཀ͍̯̈́ხ̎ᛡ̻ܴ̞̆̀́̄͊༦͂͌̓̽ᛢ̾ო̠̜̅݀͆̕༗̠̌̆͂ᚂ̗̩͎̓ᚤ̾̃̏ᚌ̢̮̊̌თ̃ܪ̬̆̈́̋༾̄̈ე̨̰̓̾༼̲݃̈̚ᚏ̞̹͌̃ᚖ̱̦შ̮̠ᛇ̡ჲ̽།̫̃̕ᛙ̗̱̉ჶ͎̣კ̡̪̺ܸ̝̖̈ሐ̦̮̱͊
    mb.vx += Math.sin(t * 0.09 + mb.phase) * 0.004;
    mb.vy += Math.cos(t * 0.07 + mb.phase * 1.4) * 0.003;

    // 𒁆̝́͊ᛅ̉ᛂ̥̰͌ܗ̒𒀢̣̹̟̭ᚙ̦͈̋݁̕༭́̚
    const dx = mc.x - mb.x;
    const dy = mc.y - mb.y;
    const dist = Math.sqrt(dx * dx + dy * dy) + 1;
    const pull = Math.min(0.015, 30 / (dist + 200));
    mb.vx += dx * pull * 0.003;
    mb.vy += dy * pull * 0.003;

    // ᚈ̭̰̖̃ᚩ̣̙̪𒀏̱̚ც̏ᚎ̠́̍ܙܹ̓͊̃̈́𒀸̱̐ᛘ͎̺̌̿ᚖ̺͍̳́𒀭̗̱̘ჴ̡̣̺ᚎ̜̓᚛̫̂̀༁̗̏̃ሖ͂̽ჺ̎ᚙ̪̤̓̂༾̖̦̾ሬ̢̲̠̾𒀗͈𒀗̱̘̹͉ᛉ́ᚖ͍ᚧ̉̈̕ᚓ͌̿༬̆͂༰̞𒁌̦͇̲͂ᚭ͎̲̯̝̬ܲ̿რ̤̾̐ͅჶ̱̍̈́
    mb.vx *= 0.985;
    mb.vy *= 0.985;

    // ሎ̞̪͌̄ሯ̢̏ᚓ̡̇𒀑̜̈̂̿𒀰͈͈̅̽რ̥̹̕ሓ̀ᚗ̪͋ᚹ͎̩ሏ͇ვ̼ܪ̱̙̍͊༔̻ᚂ̒̌̿༸̫̦̆ტ̢͂ვ̔̋ᚗ͊̋͊̚ሇ̭ქ͍̙̎͌ᛧ̺͆༫̨̯́̋ᚈ̞̜͂̕༉ܼ̰͈̂̉̇̿რ̋რ͍͆̕ᚐ̩̥̃ཅ̢̼͉ܐ̪̿ሸ̡͇̟݂̖̥̈ሁ̙̳̎༌̫̂𒀋̩̻͊̓𒁄͈̪݇ᚍ̠͆
    mb.x += mb.vx * dt * 0.06;
    mb.y += mb.vy * dt * 0.06;

    // ܱ̙͎̃ჰ̙͊̕ሰ̻̑ᚌ͇͈̇ሦ̫ვ͌ሇ͈̻̅̊ሼ̨̤͂ܒ̢̤ხ̨̀პ̪̀̔̆ᚶ̟ሙ̹𒀃̲̖̓ᚹ̦̮ᚌ̧̘ཇ̼̓̓̽
    if (mb.x < -mb.radius)      mb.vx += 0.02;
    if (mb.x > W + mb.radius)   mb.vx -= 0.02;
    if (mb.y < -mb.radius)      mb.vy += 0.02;
    if (mb.y > H + mb.radius)   mb.vy -= 0.02;

    // ܼ̊༲͉̟̔́ܛ̞̙ᚍ̻̟𒁇̢̭̏༶̏̈༖̞̥ͅཀ̦̯͍̚༂̊ხ̙̘݄̎̀ܐ͇̦̋̽ܲ̋̕ܟ̣͎̊༢̘̝͊𒀅̫ሬ̥̍ሌ̯̄
    mb.radius = mb.baseRadius * (1 + Math.sin(t * 0.3 + mb.phase) * 0.06);
  }
}

function drawMetaballs(ctx, W, H, p, t) {
  const e = p.env;
  ctx.save();
  ctx.globalCompositeOperation = 'screen';

  for (const mb of state.metaballs) {
    const pulse = 1 + Math.sin(t * 0.5 + mb.phase) * 0.15;
    const r     = mb.radius * pulse;
    const alpha = 0.025 + p.convergence * 0.018;

    const grad = ctx.createRadialGradient(mb.x, mb.y, 0, mb.x, mb.y, r);
    const cR = Math.floor(e.paletteR * 0.7);
    const cG = Math.floor(e.paletteG * 0.75);
    const cB = Math.floor(e.paletteB * 0.85);
    grad.addColorStop(0,    `rgba(${cR},${cG},${cB},${alpha})`);
    grad.addColorStop(0.4,  `rgba(${cR},${cG},${cB},${alpha * 0.4})`);
    grad.addColorStop(1,    `rgba(${cR},${cG},${cB},0)`);

    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.arc(mb.x, mb.y, r, 0, Math.PI * 2);
    ctx.fill();
  }

  ctx.restore();
}

// ᚓ́̒̿̚ᚲ̡̰̎༸́ᚃ̰ᚯ̢̗͉̉̀ܽ͆̐̀ቄ̣ͅ𒀄̘̳̂ܫ̡݄̱̽̋̐ላ̠̭𒁄̖̌ლ̥ܗ͇̱̅ͅሻ̰̖̆̑༤̧̠̣რ͇̭̟̿༉̦̂̾ჹ̼̟̊ᚦ̚ᛙ͇͋̚ܗ̞̰̭̚ܞ̨́ༀ͉ᚒ̼ს̄̅𒁇͎́̐𒁊̨͇̇́ᛃ͂̍ܗ͍̭𒀄̜ሳ̐ཀ̪̮ᛣ̩̅̓̅ሰ̙̳̭̩ᛝ̤̲ჸ̱̈ܨ̃ᚃ̫̣̹̒

function updateCursorTrail(dt) {
  const mc = state.mirrorCursor;
  const trail = state.cursorTrail;

  // ჯ̿ᛏ̲̲̙̓ሱ̱͈̀༊̯̠ር̜̱̝́ሾ̞ᛖ͇̣̣̂ᚙ̟͎̩̉მ̰͇̅̉𒀿̿ᚆ̕ᚘ̡ᛂ̊̓თ̭̮̊ჲ̀̉̄̄ჩ͇̰̣ͅ𒁈̦̋ͅܚ͍̙̈̀
  const spd = state.interaction.cursorSmooth;
  if (spd > 0.005 && state.awakened) {
    trail.push({ x: mc.x, y: mc.y, age: 0, speed: spd });
    if (trail.length > 80) trail.shift();
  }

  // ܙ̤̍̕ͅჰ̬̖ܸ̠̝̍̈́ᚙ̘̰̽́༢̤̃̓༂̫̃̓༲̝̮̆ᚄ̬͎̽̆ჸ̊̈́ག̨̨̭̗ᚄ̫̏ᚕ̟ሉ̙༁̻̾ჩ̉́̿ი̦̮̉ሚ̡̜̈̈𒀐̡̟̮ܽ́̏̌ራ̺͈̰́ሜ̡͈̒̚ ́̈́ܵ̀შ̧̇̀̉ሪ̬̠ሼ̝̂̆ܒ̱̣ვ̙̤ܹ̱̚
  for (const pt of trail) pt.age += dt;

  // 𒀢̀̍̌̓ᚫ̳̎ᛑ̭̲̂ሰͅማ̡̀𒀻̙༺͊̎͆ჭ̬͈კ̱̐ᚕ̗̇რ̟̱𒀞̟̫̓ᚶ̅ᚗ̬́̾ᛰ̬ჭ̠̗̇̅𒀑̟̤ͅᚅ̱̌𒀯̔
  while (trail.length > 0 && trail[0].age > 3000) trail.shift();
}

function drawCursorTrail(ctx, W, H, p, t) {
  const trail = state.cursorTrail;
  if (trail.length < 2) return;
  const e = p.env;

  ctx.save();
  ctx.globalCompositeOperation = 'screen';

  for (let i = 0; i < trail.length; i++) {
    const pt = trail[i];
    const life = 1 - pt.age / 3000;   // ᚃ̦༎̧͍̪̽𒀄̮̱ᚂ͈̣პ̢̹༨͈̯̌̄ᛨ̜̑ͅሚ͈̞̤̽ᛗ̘͇̆̀ሳ̨̣̰ܸ̈́ᚗ͍ሌ̧̀ბ̬̅́̆ჟ̤̟̩༐̋̀ᚪ̼̺̌ሎ̖̂ᛤ̪͊ᛡ̹̖̉𒀛̙͊̎̋ჷ̠༳̘̖ܮ̈̌𒀪̣̿̕𒀐̧̔͋ᚍ̀𒀚̟̣̈̀ሌ̟́̇̂ჱ̨̳̐𒀬̦༇̻̆𒀃̺̱̉༉̚༒̫̥ቆ̿̐̓
    if (life <= 0) continue;

    const alpha = life * 0.12 * Math.min(1, pt.speed * 8);
    const r = 6 + (1 - life) * 18 + pt.speed * 30;

    // ᛎ̗͎̚ም̡̐̋༮̧̯̏̓ሀ̻̅𒀨̋ራ̙̣༠̯̲̓͆ჱ̩͆ላ̡̪̻̍ᚚ̞̫ͅ᛭̰̪̆ᛋ̿ᛮ̇ᚑ̗̒ሞ̺ሕ̬̂̆̾ᛛ̑̌̊༏̉ᚓ̫̫́̕
    const grd = ctx.createRadialGradient(pt.x, pt.y, 0, pt.x, pt.y, r);
    const cR = Math.floor(e.paletteR * 0.5);
    const cG = Math.floor(e.paletteG * 0.55);
    const cB = Math.floor(e.paletteB * 0.7);
    grd.addColorStop(0,   `rgba(${cR},${cG},${cB},${alpha})`);
    grd.addColorStop(0.5, `rgba(${cR},${cG},${cB},${alpha * 0.3})`);
    grd.addColorStop(1,   `rgba(${cR},${cG},${cB},0)`);
    ctx.fillStyle = grd;
    ctx.beginPath();
    ctx.arc(pt.x, pt.y, r, 0, Math.PI * 2);
    ctx.fill();
  }

  ctx.restore();
}

// ܗ̤̩̰ܺ̉̕ᚆ̗̜̱̮༔̢̱̾𒀨̢͎̀̕ყ̃̽ͅͅ᛫̒̿̕ܟ̪̉𒁈̳̰̓ᚒ̥͉̩݊̊̅ͅ༆̲̥༞̗̰͋

function updateFingerTrails(dt) {
  const trails = state.interaction.fingerTrails;

  for (const trail of trails) {
    for (const pt of trail.points) {
      pt.age += dt;
    }
    // ᚁ̋𒀿͉̃ᛇ̢ᚷܷ̬̙̀༝̬̫̃ᛃ̤̑̆͋ᛏ̇ ̦ܷ̤̟́̇͋̐̕༃̞༵̭̩̭༷̾̆͌̎͋ᚩ͂̒ᚇ͇̤̓̅აܱ̆̒ሳͅ𒀒̥̀͂̕𒀠̗̎ܫ̊̐ሗ̐̇͆̆ܢ̧̭͌͋მ̲̟̇ሆ̖̰̩̭ᚔ͋̔ܬ̘́ሟ̲̤̇̔ღ̉𒀂̰͆ͅ
    const maxAge = trail.active ? CONFIG.activeTrailMaxAge : CONFIG.inactiveTrailMaxAge;
    trail.points = trail.points.filter(pt => pt.age < maxAge);
  }

  // ჷ̬༛̙̔͂ᛋ̯̈́ჸ̞̓̃መ̗݆̩̒̃̽ͅ༃̻̩̜̋𒀟̖̖̥̃
  state.interaction.fingerTrails = trails.filter(
    tr => tr.active || tr.points.length > 0
  );
}

function drawFingerTrails(ctx, W, H, p, t) {
  const trails = state.interaction.fingerTrails;
  if (trails.length === 0) return;
  const e = p.env;

  ctx.save();
  ctx.globalCompositeOperation = 'screen';
  ctx.lineCap = 'round';
  ctx.lineJoin = 'round';

  for (const trail of trails) {
    if (trail.points.length < 2) continue;

    // ტܾ̟̄̇̎̈́̿𒀣̡̤ᚔ̮̠̙͂𒀣̰̃̽̓ሪ̣̟̌༄̙ჺ̯̜̔რ̱̦̕ს̰́ჱ̘͎̓ᚳ̳̬̤̣̉͆̉݇ᚇ̦ረ̺ሾ̪̟̏༛̩̦́ᚍ̜̘̱̺̀ܺ༽̨̭̓̋ᛕ̞͋̌̏ᚉ̘̩̀ჲ̤̰̑݉̄͋̓̚ሞ͈̐͊̀ሜ̗̦༘̤͈̉
    for (let i = 1; i < trail.points.length; i++) {
      const prev = trail.points[i - 1];
      const pt   = trail.points[i];
      const life = trail.active ? 1 : Math.max(0, 1 - pt.age / 8000);
      if (life <= 0) continue;

      const pressure = pt.pressure || 0.5;
      const width = 2 + pressure * 12 + (1 - life) * 4;

      // ᚗ̮̑̊̎ᚔ̻̓༖̱̼̇̈́݉́͂ህ̹༛̓༴̼̏̀ᚲ̫̜̭ᚶ̤̃̍ཁ́̂̈̊ჰ͊̀̉̈ᚏ̝̉̾ܯ̧̫̍ሄ̣̤̎́ሮ̤̗́̾ܬ̱ܹ̃̾༥̋𒀵̽̌𒀔̭
      const warmth = pressure * 0.7;
      const wR = Math.floor(200 + warmth * 55);
      const wG = Math.floor(160 - warmth * 40);
      const wB = Math.floor(120 - warmth * 60);
      const alpha = life * 0.22 * pressure;

      ctx.strokeStyle = `rgba(${wR},${wG},${wB},${alpha})`;
      ctx.lineWidth = width;
      ctx.beginPath();
      ctx.moveTo(prev.x * W, prev.y * H);
      ctx.lineTo(pt.x * W, pt.y * H);
      ctx.stroke();

      // ༚̼͎͈̑𒀮̗͂̌༶̨̘̝͆ቈ̡̹̬͉ᚘ̪̘̃ܨ̻ሎ̰̾ᚄ̃̀̑̕ც̧̘ბ̣̦ሂ̩̮̻𒁎̓𒀩̊̃ᛂ̨͍͆ܗ̠̤̈́̈ღ̯𒁁̡̓̀
      if (pressure > 0.3 && life > 0.3) {
        const haloR = width * 2.5;
        const haloAlpha = alpha * 0.15;
        const grd = ctx.createRadialGradient(
          pt.x * W, pt.y * H, 0,
          pt.x * W, pt.y * H, haloR
        );
        grd.addColorStop(0, `rgba(${wR},${wG},${wB},${haloAlpha})`);
        grd.addColorStop(1, `rgba(${wR},${wG},${wB},0)`);
        ctx.fillStyle = grd;
        ctx.beginPath();
        ctx.arc(pt.x * W, pt.y * H, haloR, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    // ༇̍ᛄ̡̤̽ᚙ̗͈̔ܒ̻̂̌რ͈༔̭̺̱ᚄ͇ܹ̫̼̓̿ᚎ̽ͅᚍ̐ᚋ̣͈́̍
    if (trail.points.length > 0) {
      const first = trail.points[0];
      const burnLife = Math.max(0, 1 - first.age / 12000);
      if (burnLife > 0.05) {
        const bx = first.x * W;
        const by = first.y * H;
        const br = 8 + (1 - burnLife) * 6;
        const burnAlpha = burnLife * 0.18;
        const bg = ctx.createRadialGradient(bx, by, 0, bx, by, br);
        bg.addColorStop(0,   `rgba(240,220,180,${burnAlpha})`);
        bg.addColorStop(0.5, `rgba(220,190,150,${burnAlpha * 0.4})`);
        bg.addColorStop(1,   `rgba(200,170,130,0)`);
        ctx.fillStyle = bg;
        ctx.beginPath();
        ctx.arc(bx, by, br, 0, Math.PI * 2);
        ctx.fill();
      }
    }
  }

  ctx.restore();
}

// ᛄ̡̂უ͇̜̃༈́͌ቃ̮̐̂༰̣̀ܖ̋᚛̱̓͆ሟ̏̉ᚄ̢̞̻̀̿݇̌̓𒀕̾̂̏ჶ͍ሉ͇̝̇ܰ́̋༭̜ᛯ̑ᚉ̒ჯ̨̜̹͌ሽ̡̮̉͋ܩ̖̀̃ᚃ̯̅͋ᚹ̨̫ܭ̜͉͆̆ᚙ̢̪̲̔ᛆ̪̰ს̱̚𒀪̩̳͊ቈ̻̲̣̝ሶ̑͂ᚘ̣𒀏̡̕ᚢ́ᚔ̺̃̋ს̫͇ჲ͇̭̝̎ሶ̗̿̂̀༭̨̮̟̃༚̒͌

function updateHeatScars(dt) {
  const inter = state.interaction;
  const mc    = state.mirrorCursor;
  const W     = window.innerWidth;
  const H     = window.innerHeight;

  // ܨ̳́𒁎̖ሉ̧̫̙̹ༀ̇᚛̪̏ᚮ̧̥̠̈́ᚎ̽𒀈̺̱̺̂ც̣̀̃͆ᚇ̗̻༏̓͂͆̂ᛄ͈̙́ᚊ͇̖̥͇
  if (inter.cursorSmooth < 0.015 && state.awakened) {
    const nx = mc.x / W;
    const ny = mc.y / H;

    // ܨ̹̿ᚬ̼̑́ᚧ̘͉ᚏ͍̍𒀜̣̅̊̊𒁃̃͋𒀔̬̒𒁁̯̜̃ᛪ̪̱̔̀ᛁ̹̣ᚰ̻̩̿̄ሇ̯̾ለ̳́̓ᚅ̖̞͌̏ღ̌ᚈ̫̋̈̅ᚆ̡̩͌̈݉̇ቆ̝̔ሿ̝̫̎ܽ̕ܮ̠̌́ᚄ̤̩̓̋༱̑̽ᚓ̩̏̑༽̬̖̔͂ቈ͇ሾ̞͎̝ማ̼̂ቄ͎̤̀̿
    let merged = false;
    for (const sc of state.heatScars) {
      const dx = sc.x - nx, dy = sc.y - ny;
      if (Math.sqrt(dx * dx + dy * dy) < 0.04) {
        sc.heat = Math.min(1, sc.heat + dt * 0.00015);
        sc.radius = Math.min(0.06, sc.radius + dt * 0.000002);
        merged = true;
        break;
      }
    }

    if (!merged && state.heatScars.length < 40) {
      state.heatScars.push({ x: nx, y: ny, heat: 0.05, radius: 0.02 });
    }
  }

  // ჭ̍̀პ̦༂̘𒀪̨̓ܳ͆̆༨̨̻̬᚛̜̠̻𒀗̧̋̂̈ᚚܴ̺͂̆͌̕ჱ̀༱̪͈ሕ̜̊̀̃ᚫ̹ܾ̬̂̑̅̕𒀕̲͆̓კ̱ᚫ̈́̏
  for (const sc of state.heatScars) {
    sc.heat = Math.max(0, sc.heat - dt * 0.000004);
  }
  state.heatScars = state.heatScars.filter(sc => sc.heat > 0.005);
}

function drawHeatScars(ctx, W, H, p, t) {
  if (state.heatScars.length === 0) return;
  const e = p.env;

  ctx.save();
  ctx.globalCompositeOperation = 'screen';

  for (const sc of state.heatScars) {
    const x = sc.x * W;
    const y = sc.y * H;
    const r = sc.radius * Math.min(W, H);

    // ᚆ̲̰̹ᚏ́ᚢ̘̍͂̎𒀐̓ჳ̥̀̊ሳ̨̪̄ᛯ̌̈ሳ̠̕ᚕ̡͉́ͅ𒁁̗͌̔͋
    const warmth = sc.heat;
    const sR = Math.floor(180 + warmth * 75);
    const sG = Math.floor(160 - warmth * 50);
    const sB = Math.floor(130 - warmth * 80);
    const alpha = sc.heat * 0.35;

    const grd = ctx.createRadialGradient(x, y, 0, x, y, r);
    grd.addColorStop(0,   `rgba(${sR},${sG},${sB},${alpha})`);
    grd.addColorStop(0.5, `rgba(${sR},${sG},${sB},${alpha * 0.4})`);
    grd.addColorStop(1,   `rgba(${sR},${sG},${sB},0)`);
    ctx.fillStyle = grd;
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.fill();

    // 𒀠̨̐̈́̋ᚱ̩̺̆ჳ̏༧ܑ̥̅͋̋̑̅რ̇ჩ͊̎̔ნ̻͈͆̏ჱ݈͊̅̈ͅܘ̜̘̺̉ሳ̑ᛯ̳͍ᛮ̩̰̀̃ᚉ̓̀̅𒀻͉̓ყ̣̫̊̉
    if (sc.heat > 0.3) {
      const coreA = (sc.heat - 0.3) * 0.5;
      const coreR = r * 0.25;
      ctx.fillStyle = `rgba(240,235,220,${coreA})`;
      ctx.beginPath();
      ctx.arc(x, y, coreR, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  ctx.restore();
}

// ჴ̉̂̍𒀒̎ჶ̣̣̲̽ჴ̼̃ܦ̀̀ᚍ̩͈͇̰ᚙ̎̀ሥ̜͂ል̣̋̈̂ი̬̗̌ͅ༞̗̹̈́

function spawnCrack(px, py) {
  const angle = Math.random() * Math.PI * 2;
  const len   = 30 + Math.random() * 60;
  state.crackQueue.push({ x: px, y: py, angle, len, gen: 0 });
}

function propagateCracks(dt) {
  const maxCracks = 200;
  const maxGen    = 4;

  // 𒀄̖̎𒀠͍̞́ᚈ̤̬̯̅ᚅ̠༂͍̜̍ჴ̃ᚭ̦ᚋ̢̠̜݆̤གྷ̜̏̆ᚑ̭̖ཀ͂̒̈̈́𒀍̞𒀾̧̪ჸ͇̀ჺ̼͇𒁉̜̃ͅᛦ̪̭̖̏ᚢ̫̣̈̾ܨ̳̦͎̒ܫ̲̒͌༕̤̪̓̕ᚚ̈́ᛎ̳̤̰̓ཁ̺͂ሩ̭́̐ረ͍̞ᚗܑ̫̟̜̗̌̆̌ᚹ̅̀𒁍̹𒀧̍̓̌༇̳̻ͅͅᚍ͍̮ቂ̜̯
  let budget = 5;  // ܛ̗ܲ̅ღ͍𒀢̫̂ቇ̼̅ᛊ̅̕ხ̨̗̬́ᚯ͊̂𒀊͈̲̀̏ტ̡̥ᚩ̢̍𒀊̖̂̾ჷ̥̺ሸ̫ᚏ̭̾̐ማ͍̞̟༆̍ყ̖̆̚ᚄ̞̇̉ᚇ̟ᚐ̱ܴ̂̓̄̈̓ሷ̧̪̼̻ༀ͎̭
  while (state.crackQueue.length > 0 && budget > 0 && state.cracks.length < maxCracks) {
    const q = state.crackQueue.shift();
    if (q.gen > maxGen) continue;

    const x2 = q.x + Math.cos(q.angle) * q.len;
    const y2 = q.y + Math.sin(q.angle) * q.len;
    state.cracks.push({
      x1: q.x, y1: q.y, x2, y2,
      gen: q.gen,
      age: 0,
      alpha: 0.7 - q.gen * 0.12,
    });

    // ᚑ̣̽̃༓́̓̀̕ሞ̧̱̳̈́კ͆̎ᚍ̧̗ᛮ̬̅̔ღ́༦̺̱̒ሪ̻ჸ̞͉̓𒀑̿ሓ̻̭͉̠༧̧̨̺̉ᚻ̡̢̗̓༴̆ᛡ͍̈༛̟̑̓͆༗̢̮̕ᛪ̪ჲ̑̓ͅ༪̬̘ܖ̧̻̌ܠ̭̼ሧ̼̽̓̌წ̻ܠ̬̙̄𒀜̓༒̣̌ჯ͇ᛇ̦̔͊༣̤̼ჰ̤̤̮̲༰̮̀̐̂ჟ̎̿ᚚ̱̲̂́ჟ͇̤͌ቁ̨
    const branchChance = 0.55 - q.gen * 0.1;
    const childLen = q.len * (0.55 + Math.random() * 0.25);

    if (Math.random() < branchChance) {
      state.crackQueue.push({
        x: x2, y: y2,
        angle: q.angle + 0.3 + Math.random() * 0.5,
        len: childLen,
        gen: q.gen + 1,
      });
    }
    if (Math.random() < branchChance * 0.7) {
      state.crackQueue.push({
        x: x2, y: y2,
        angle: q.angle - 0.3 - Math.random() * 0.5,
        len: childLen,
        gen: q.gen + 1,
      });
    }

    budget--;
  }

  // ტ݂̊̄̄̓͊𒀷̗̜̐༿̙ራ͇̑ᛙ̢̩̑̈́ሎ̹𒀵̕ሤ̖𒀚̠ሥ̪͌ძ̜͍͂͊ሾ̝̹̎̑ሣ̺̱̝̚𒀏̪͆ͅሷ̖̺̦𒀪̨̫ܸ̗̹̒ᚲ̞̭̑̍ვ͉̂ቄ̧͆̄ᚑ͎༯̮͂̀̕ሼ̠́̍ཅ̨̂ᛕ̖𒀢̹̏ᚳ̐ቇ̝̍ܔ̊̊ᚉ̠̂̾̑ሼ͈̫̺̥ሷ̝𒀷̍
  for (const c of state.cracks) {
    c.age += dt;
    // ჲ̗̿̎ᛀ̳̙ܫ̈ᚡ̨̘̾ჴ̠͆ᚷ̹ܱ́̏̽̕ჟ̪̣̄́ሃ̨̓ܤ̡̻
    c.alpha = Math.max(0, c.alpha - dt * 0.000008);
  }
  state.cracks = state.cracks.filter(c => c.alpha > 0.005);

  // ቈ̟̠͎ს̗ ̓̍̅ლ̑̅ᛉ̜̯́𒁉̮̆𒀰̒ͅཇ̩́̀̽ሟ̲ᛌ̩̥
  for (const hp of state.interaction.hoverPoints) {
    if (hp.intensity > 0.7 && hp.age > 3000 && hp.age < 3050) {
      spawnCrack(
        hp.x * window.innerWidth,
        hp.y * window.innerHeight
      );
    }
  }
}

function drawCrackMap(ctx, W, H, p, t) {
  if (state.cracks.length === 0) return;

  ctx.save();
  ctx.lineCap = 'round';

  for (const c of state.cracks) {
    const width = 0.3 + (1 - c.gen / 5) * 0.8;
    const shimmer = 1 + Math.sin(t * 3 + c.x1 * 0.02) * 0.15;
    const a = c.alpha * shimmer;

    // ᛎ̬̥̭͉݃ͅშ͍̮̔᛭̼͆ᚈ̖̠̐𒀝̟͌ᛣ͂͆ᛰ̢̳̄̃𒀙͇̣̠̟ᚻ̡ܚ̃̊̀ᚆ̟̈́̔̅ზ̭ܸ̹̑ᛮ̹̾̋̓ძ̧𒀕̕ܮ̯̽༳̢ܹ̘̽̋ͅͅሾ̻̺̥݈̳̻ሠ̏ᚚ̭̓͆̀༥̨̝̓ᚉ̯̪̔ნ̲ᚌ̲̞̅́ᚿ͎𒁃̻̙̯̐ᚩ̦̟̇́
    ctx.strokeStyle = `rgba(200,210,230,${a * 0.6})`;
    ctx.lineWidth = width;
    ctx.beginPath();
    ctx.moveTo(c.x1, c.y1);
    ctx.lineTo(c.x2, c.y2);
    ctx.stroke();

    // 𒀼̻ᛧ̬̌̈༶̙ͅሷ̥ܔ̒ሾ͇̖̓̌ᚽͅ𒀊̨̱ᚰ̤̠ე̦̓̏̒ሸ͉̻̆ᛑ̾༊̓ᚉ̨̬̿̆ܺ̈ჺ̜̠̙̈́ሥ͈̤̉̈ᚰ͍̫̕𒀩̦ᚄ̽ᚘ̹͋͊͊
    if (a > 0.2) {
      ctx.strokeStyle = `rgba(180,195,220,${a * 0.12})`;
      ctx.lineWidth = width + 3;
      ctx.stroke();
    }
  }

  ctx.restore();
}

// ქ͊𒀒̟͊༢͉̼დ̙ሼ̳̦̀ܕ̫̘̋ᚎ̳̮̬𒀹̲̟༟̧̡̱͆ჰ̟̣͌დ͇̊͋̌ܘ̪̬̇𒀫͉𒀗̗̞ჩ̥́̊̑ᛩ͈́ሷ̱͂༲̜̫ለ̨̖̰̀༾̺̍̑͊𒀒̧́ማ̣ሽ̫̫̀̂ᚔ̫̓დ̮მ̙̩̠̂𒀷̨̔̊ሬ̤ო͆პ̲̰̾̇𒀑̗̱̦ሁ̗̩ܦ̡̩̻̌ሸ͉͉̹

function drawRitualGeometry(ctx, W, H, p, t) {
  const shift = p.skeletonShift;
  const cx    = W * (0.5 + shift);
  const headY = H * 0.270;
  const conv  = p.convergence;

  // ༓͇̏̔̕ᚉ̦̹̪༇̮͋᛬̰̀ᚉ̞̦კ͇̺კ̖̄͋᚛̦͆ሟ̨̟̄̆ܚ̤̭̝̻༶̜ᚓ̠̖́ᚓ̺̇̓
  if (conv < 0.12) return;

  // ᚢ̮ტ̧̨̬̀ᚉ̡ܚ̯̀𒀇̄̏ᛄ̊ᚒ̄ᚌ̻̽ܽ̋̽ܛ̭̹̏ሕ̙͆́̀𒀬̼𒀆̧̺̿𒀛͆͌̑́
  const devotionalBoost = state.temperament === 'devotional' ? 1.5 : 1.0;

  const alpha = Math.min(0.18 * devotionalBoost, (conv - 0.12) * 0.25 * devotionalBoost);
  const ms    = p.env.motionScale;
  const phase = state.ritualPhase;

  ctx.save();
  ctx.strokeStyle = `rgba(160,175,210,${alpha})`;
  ctx.lineWidth = 0.4;
  ctx.globalCompositeOperation = 'screen';

  // ܩ̙̭͂̕༰̥݄̱̘̮̟̏̎ܳ̓ሏ̓ᛛ͂ܚ̰̮̓͆ܛ̣༵̃̓ͅᚍ̡ቃ͇̅ሦ͍̞̮̉ܓ̖̦̗̅ᛏ̦༘̫̑̂̾ᛣ̯̈́ᚐ̲̭̪ᚆ̻͎̎ᚿ̩͎͍͊ܕ͍̇̏༃̝ᚁ̫̚ሿ̝̞ܝ̀̔ͅᚌ̣̙̞͌ܥ̊̀ቆ͇̉̀ᛒ̡̫̅ᚘ̢̲̈
  const haloR = Math.min(W, H) * 0.12;
  const haloY = headY - haloR * 0.5;
  ctx.beginPath();
  ctx.ellipse(cx, haloY, haloR, haloR * 0.18, phase * 0.15, 0, Math.PI * 2);
  ctx.stroke();

  // ཁ̭̱ܝ̧̦̏̋᚜̫̂ሼ̀̈̏ሗ̩̑́͌ቇ̇ሢ͇̔ᛐ̜̟̓ͅܮ̩̲̊𒀉̘༢̞̚
  if (conv > 0.3) {
    ctx.strokeStyle = `rgba(150,165,200,${alpha * 0.6})`;
    ctx.beginPath();
    ctx.ellipse(cx, haloY - 4, haloR * 1.15, haloR * 0.22,
      -phase * 0.1, 0, Math.PI * 2);
    ctx.stroke();
  }

  // ሜ͆̊̔̚𒀋̬̓̇ვ̭ͅሤ̉𒁁̜ͅͅზ̝̝ሠ̳̅̄ͅ༬̨̓̌༢̱̳͉̑ᚴ̹̗̎͋ც̓̏ᚻ̃ᚶ͍̳̭͋ფ̧̌̇̂༦̨̢̫݈̺̆̌̄༅͈̾གྷ̭𒀩̃̐ང̧̝̽ܚ̻̂ሀ͎̐̿ლ͈̩̉ܿ͋͂
  const torsoY = H * 0.48;
  const circleCount = 3 + Math.floor(conv * 4);
  for (let i = 0; i < circleCount; i++) {
    const r = 20 + i * 25 + Math.sin(t * 0.3 + i) * 3;
    const a = alpha * (0.5 - i * 0.06);
    if (a <= 0) continue;
    ctx.strokeStyle = `rgba(160,175,210,${a})`;
    ctx.beginPath();
    ctx.arc(cx, torsoY, r, 0, Math.PI * 2);
    ctx.stroke();
  }

  // ݄̣̏ᛤ͈̍̕༐̌̌𒀪̓ᚁ̯̤̞༙̫̞̀́́ვ͎͇𒀆̀ᚎ̧̝́̏ᛰ̫̭̌ᚋ̳̮̆̐𒀋̧̮𒀬̇პ̧̆̈༅̔𒀄͆ᚌ̈̿༪̭̬
  if (conv > 0.2) {
    const crossLen = Math.min(W, H) * 0.18 * conv;
    const crossA   = alpha * 0.7;
    ctx.strokeStyle = `rgba(145,160,195,${crossA})`;

    for (let i = 0; i < 4; i++) {
      const angle = phase * 0.08 + (i / 4) * Math.PI;
      ctx.beginPath();
      ctx.moveTo(
        cx + Math.cos(angle) * crossLen,
        torsoY + Math.sin(angle) * crossLen
      );
      ctx.lineTo(
        cx - Math.cos(angle) * crossLen,
        torsoY - Math.sin(angle) * crossLen
      );
      ctx.stroke();
    }
  }

  // ༘͍̫̍ͅ𒀃̮͎̦ͅཁ̫͉ᚄ̡𒀀̗̣ᚗ̭ტ̢̖͂ᚆ̯̰༏̡͇̕ሀ̡̿ܖ̜̃̆༏̜͋მ̑ᚔ̺̟̆
  if (conv > 0.35) {
    const outerR = 20 + (circleCount - 1) * 25;
    const tickCount = 12;
    const tickLen = 5 + conv * 4;
    ctx.strokeStyle = `rgba(155,170,205,${alpha * 0.5})`;
    ctx.lineWidth = 0.3;
    for (let i = 0; i < tickCount; i++) {
      const a2 = phase * 0.06 + (i / tickCount) * Math.PI * 2;
      const ix = cx + Math.cos(a2) * outerR;
      const iy = torsoY + Math.sin(a2) * outerR;
      ctx.beginPath();
      ctx.moveTo(ix, iy);
      ctx.lineTo(
        ix + Math.cos(a2) * tickLen,
        iy + Math.sin(a2) * tickLen
      );
      ctx.stroke();
    }
  }

  ctx.restore();
}

// 𒀷̨̱᚛̜ܤ̑ܨ̙̳̬პ͉̿ჹ̟̞̿༾̮̻̊ራ̼̠́̓༠̙̩̮ა̲̩̽̉ᚷ̮̹̓ᛠ̪̊༐̏̀̂ᛒ̆̕ო̯̱̾̀კ̊̑̂ܤ̱ᛛ̝̯̇ᚸ̳̚ᛤ̻͋͆̃ሷ̗̙̈͆ᛩ̈́༜̻ᛧ̡̗̽̚𒀙̹͂𒁆̳̻̯ᛢ̣̣̒

function spawnRipple(px, py, intensity) {
  state.ripples.push({
    cx: px, cy: py,
    age: 0,
    maxR: 60 + Math.random() * 80,
    intensity: intensity || 0.4,
  });
  if (state.ripples.length > 12) state.ripples.shift();
}

function updateRipples(dt) {
  for (const rp of state.ripples) rp.age += dt;
  state.ripples = state.ripples.filter(rp => rp.age < 4000);

  // 𒀳̖ᛨ̰̣͊̾ო̢̗̀̾ܠ̩̳͈̅ܶ༯͋ჵ̟̠̠̎ሖ̮̀̉༁̱̭̼ሱ̽ሮ͍̃̆𒀂̊ᛩ̣ჟ̡̙̼̚ე̼͉ᛖͅ𒁊̧̾ܭ̯̔̈́ᛟ̡̀̒ჰ̹̟̮݉́́ܟ̫̫̽̔̀݇᚛̪ᛙ̟̤̕ᚒ͋̚𒁏̀ჷ̼ቀ̖͍́̀ᚢ̲̌𒀸͍̦̆ቆ̻̿̕ཅ̫̍༳̈̔̄̎ቃ͊ᚉ̚𒁊͌̂̈̎
  if (state.awakened && Math.random() < 0.02) {
    const mc = state.mirrorCursor;
    const W = window.innerWidth, H = window.innerHeight;
    const headCX = W * (0.5 + state.portrait.skeletonShift);
    const headCY = H * 0.38;
    const dx = mc.x - headCX, dy = mc.y - headCY;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < Math.min(W, H) * 0.3) {
      spawnRipple(mc.x, mc.y, 0.15 + (1 - dist / (Math.min(W, H) * 0.3)) * 0.2);
    }
  }
}

function drawLiquidMirror(ctx, W, H, p, t) {
  const shift = p.skeletonShift;
  const cx    = W * (0.5 + shift);
  const cy    = H * 0.38;
  const conv  = p.convergence;

  // ფ̝̇͂̕ᚉ̧ܢ̜̳̑̒𒀩̈́ᚙ͇͌̍ᛀ̡𒀙̅̈͂͊შ̒
  const poolRx = Math.min(W, H) * (0.08 + conv * 0.10);
  const poolRy = poolRx * 1.4;

  if (poolRx < 10) return;

  ctx.save();

  // 𒀦̖ᛂ̾༏̪̜ܽ̂ͅ༑̧̹ჯ̻̼͉ቅ̢̙́ᚈ̑𒀞͉̓͆ላ̪̈́̕წ̟̠̦̫༏̖༖̡̘̝͋𒁋̰ܤ͌̓𒀣̑ᚍ̲̊ᚋ̤̘̔ᚅ̖
  const poolG = ctx.createRadialGradient(cx, cy, 0, cx, cy, poolRx * 1.3);
  const pa = 0.15 + conv * 0.20;
  poolG.addColorStop(0,   `rgba(1,1,4,${pa})`);
  poolG.addColorStop(0.6, `rgba(3,3,8,${pa * 0.6})`);
  poolG.addColorStop(1,   'rgba(3,3,8,0)');
  ctx.fillStyle = poolG;
  ctx.beginPath();
  ctx.ellipse(cx, cy, poolRx * 1.3, poolRy * 1.2, 0, 0, Math.PI * 2);
  ctx.fill();

  // መ̙̒კ̣̝༦̄ᚕ̈̇̕༣̺͋ᚏ̨̍̒𒁆̨̢ܜ̟𒀴̭̦̫̑ላ̞͉̻̿ܞ̺̱̆̔ሺ̗̘̔̐𒀭̪́͆̚ᚂ͈̰ხ̮̔ܽ̓̇̋ܛ̒ሊ̢̻̙̇̎ܲ̒̎
  const specX = cx + Math.sin(t * 0.2) * poolRx * 0.15;
  const specY = cy - poolRy * 0.25 + Math.cos(t * 0.15) * 3;
  const specR = poolRx * 0.4;
  const specG = ctx.createRadialGradient(specX, specY, 0, specX, specY, specR);
  const sa = 0.04 + conv * 0.04;
  specG.addColorStop(0,   `rgba(200,210,230,${sa})`);
  specG.addColorStop(1,   'rgba(200,210,230,0)');
  ctx.fillStyle = specG;
  ctx.beginPath();
  ctx.arc(specX, specY, specR, 0, Math.PI * 2);
  ctx.fill();

  // ༟̃̚𒁍͍̻𒀆̩̤̭̍ო̗̫ᚉ̬̟̽͆༉̼ბ̣̩̀𒀢̮̦̋་̟̯̦̚᚜̇̾ᚎ̢̌͌ሠ͍̰ቃ͊̐ᚡ̘̰ᛯ̡̗ܱ̋̿̉̀ᚄ̤༆̹̣ܸ̪̈́̊̈́ᚇ̱̔დ̗͆͋̓༸̂́ᚙ̏̅᚜̪̘̆ܦ̮̂ᚄ̧̣̫ܿᚐ̘𒀜͉̗̿͆ᚃ༹̞̌̽̌̐́̚༿̝̟ሰ̯͎́
  for (const rp of state.ripples) {
    const life = 1 - rp.age / 4000;
    if (life <= 0) continue;
    const r = rp.maxR * (1 - life * life);  // ༐̏𒀮̖̯ა̾༻ܑ̳͇͌̋ማ͍̱̈́ሄ̘̺̲́ሟ̼̝̔ᚙ͇̟̣̕༺̭̇ܛ̟́̎𒀛̼̅ཇ̰̿ቃ̳̆̏ᚆ̓ሂ͉̈ཀ͆̏ᛖ̦̙̪̑͋݀̔ሜ̆ ̤̮̔̍ᚧ̧̢̙̈ቄ͉͈́
    const ra = rp.intensity * life * 0.2;

    ctx.strokeStyle = `rgba(180,195,220,${ra})`;
    ctx.lineWidth = 0.5 + life * 0.8;
    ctx.beginPath();
    ctx.arc(rp.cx, rp.cy, r, 0, Math.PI * 2);
    ctx.stroke();

    // ̡݊͊ܐ̜̾̂̑ᚆ͉͈̓ܔ͈̄𒀈̠̈́ܭ̺
    if (life > 0.5) {
      ctx.strokeStyle = `rgba(200,215,240,${ra * 0.5})`;
      ctx.lineWidth = 0.3;
      ctx.beginPath();
      ctx.arc(rp.cx, rp.cy, r * 0.6, 0, Math.PI * 2);
      ctx.stroke();
    }
  }

  ctx.restore();
}

// ᛗ̧̙̦ᚑ̖̣̣ᚋ̮ᚇ͇̽͋𒁈̐̂ܺ̔̒ᚾ̩͇̩̝̍ܽ̂ᛦ̞̍̿𒀢̞̈̈́݇ᚄ̹̞̓̽ም̬̾̉̊ሚ̲̟ო͊𒀌ܑ̱͎̏̆̊͂༐͍̌̊ܕ̯̟ሧ̋༟̤̑𒁌̰̌ᚚ̣͇̖́݀𒀌̓ሟ̀̋ܩ̕ᛍ̓̄̎༭̮̮̏ყ̬༆̹̝̅̚ა̗͍̰ܺ̏ᚘ͉̐̂̀ሑ̨̭ቂ̖͌
// ༩̺̅̒̌𒁉͇̰ᛜ̀͊ჱ̠͇̅̏᛭̱̺̩𒀽̜̎̚ᚳ̞̖̆̒ᛔ̥̺ሎ̦͌̏̉ᛁ̮̥͆𒀱̳̠̣ᚐ͆̆̂̉𒀅̢̧̞͂ᚨ̧̼̤ሰ̘̉ᚢ̡̺̾ᚙ̢̩͈͋ሠ̢͊ܳ̑͌ᚑ̣̙̙͊ሒ̨̞̠̆ܲም̢̢̄ჸ̟̜́༐̠͈̑𒀺̄̒̚ᛆ̣̘̓͌༻̧̮̓უ̨̋̔̀ო̅̈́ ̺ტ̯̲ሺ̡̬ܻ̓̀̀ͅ

function drawMotionAnatomy(ctx, W, H, p, t) {
  const shift = p.skeletonShift;
  const cx    = W * (0.5 + shift);
  const ms    = p.env.motionScale;

  ctx.save();
  ctx.globalCompositeOperation = 'screen';
  ctx.lineCap = 'round';

  // ᚽ̗ረ̉̃̐𒀱̈ͅ𒀠͋𒁏̪̮̖͆ᚘ̥̳̈́𒀥̤̇́ᛋ̝ܢ́ረ̬̜̈̕གྷ͍̯͍̗༃̲დ̬̔ܤ̀̑གྷ̪
  if (p.breathDepth > 0.08 || p.smear > 0.1) {
    const ribAlpha = Math.max(p.breathDepth * 0.3, p.smear * 0.15);
    const ribCount = 7;
    const ribTop   = H * 0.50;
    const ribSpace = H * 0.018;
    const ribW     = W * 0.055;
    ctx.strokeStyle = `rgba(180,195,220,${ribAlpha})`;

    for (let i = 0; i < ribCount; i++) {
      const ribY  = ribTop + i * ribSpace;
      const curve = Math.sin(t * 0.8 + i * 0.3) * 2 * ms;
      const width = ribW * (1 - i * 0.06);
      ctx.lineWidth = 0.3 + p.breathDepth * 0.6;
      ctx.beginPath();
      ctx.moveTo(cx - width, ribY + curve);
      ctx.quadraticCurveTo(cx, ribY - 3 + curve * 0.5, cx + width, ribY + curve);
      ctx.stroke();
    }
  }

  // ቁ̜̣̥́ჲ͍ᚕ̓́ܚ̼̦̺̑ᛎ̫̈́ͅᚈ̠̜̋ሣ̂̍̓რ̕ჭ̨̠𒀊̮̱̬̭ჟ̗͍̫ᛝ̼̯̰̘უ̨̰̺̓ᛗ̐̐ህ̝ང̧̬̋
  if (p.pulse > 0.15 || p.typeTremor > 0.1) {
    const jawAlpha = Math.max(p.pulse * 0.25, p.typeTremor * 0.3);
    const jawY     = H * 0.36;
    const jawW     = W * 0.048;
    ctx.strokeStyle = `rgba(170,185,210,${jawAlpha})`;
    ctx.lineWidth = 0.5;

    // ᚙ̼̃̈ሉ̰̯̩𒁀̠ᚎ̡̕ᚌ̯̓͌ᚚ̼ᛥ̞̾̿ር̺̊̃𒀡̊̎ሽ̅𒁈̮༭̥̀̀̚ჺ̞̗́̕ᚙ̪͉̄ܐ͍͎̎ܳ͂̑͋༔̪͍̌ܖ̢͍̯͊ᚔ͌̒͋ለ̢̈̿༮̡̋̒ܠ̲ᚑ̧̥̐̃ჰ̫̻ᚌ̗ܫ̒͂́̌ሩ̺̌̒̍ე̡̦̎̓ᚱ̖
    ctx.beginPath();
    ctx.moveTo(cx - jawW, jawY - H * 0.02);
    ctx.lineTo(cx, jawY + H * 0.015);
    ctx.lineTo(cx + jawW, jawY - H * 0.02);
    ctx.stroke();

    // ቄ͍͋ሾ̬ܔ̠͍́̽᚜́̋̃̎ሤ̪̒̒დ́ᚬ͋ཆ̅ნ̫̜̈̕ܖ̖̬̆݉̑̕𒀷̹̮́ͅܮ͌̔ܪ̿̋̚ͅᚻ̺̊̂ሥ͉̮̌ზ̥͋̿́༟̮̜𒀽̢̼ᚖ̪̻̒͆ང̣̑̂ძ͋ᚏ̦̂
    ctx.beginPath();
    ctx.arc(cx, jawY + H * 0.018, 2, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(180,195,215,${jawAlpha * 0.6})`;
    ctx.fill();
  }

  // ሽ̨ᚅ́ᛥ́ᛠ̩̳̮̍༬̜̄̊̏ᛠ̀̓̚ቅ̂𒀣̞̋̿ჩ͈̚༿̙̙̊ᚑ͈ܸ̰͊ᚌ̢̲̈̈́𒀊̬̐თ̮ሮ͉ለ̘̂̌ͅ𒀳͉̺̉̚ჱ̃ ̖͈𒀬̦̽̑𒁄̡̞݂̙̪̒͌༮̤̍̂͂ᛂ̧̹̜̼ܹ̝̼̔̓ܿ̋̀ܚ͋̋̏ᛢ̨̟༱̓̕ლ̖̬̞́ሡ̙̗̂̄ܭ̀༉̣̟̭ᚺ͍̌͋ሎ̞𒀾̲̖̤̀ሑ̯͂̎𒀻̠̣͋̏
  if (p.autonomy > 0.15) {
    const spineAlpha = p.autonomy * 0.22;
    const spineTop   = H * 0.30;
    const spineBot   = H * 0.66;
    const vertebrae  = 12;
    ctx.strokeStyle = `rgba(160,175,200,${spineAlpha})`;
    ctx.lineWidth = 0.4;

    ctx.beginPath();
    for (let i = 0; i <= vertebrae; i++) {
      const frac = i / vertebrae;
      const y = spineTop + frac * (spineBot - spineTop);
      const sway = Math.sin(t * 0.3 + frac * 4) * 3 * p.autonomy * ms;
      if (i === 0) ctx.moveTo(cx + sway, y);
      else ctx.lineTo(cx + sway, y);
    }
    ctx.stroke();

    // ს̟̍̄ܧ̫͎ᛚ̻̓ሙ̻͂̀̈́ང̱́́̽ሐ̫̤̑̎𒁎̭͊̕
    ctx.fillStyle = `rgba(175,190,215,${spineAlpha * 0.8})`;
    for (let i = 0; i <= vertebrae; i++) {
      const frac = i / vertebrae;
      const y = spineTop + frac * (spineBot - spineTop);
      const sway = Math.sin(t * 0.3 + frac * 4) * 3 * p.autonomy * ms;
      ctx.beginPath();
      ctx.arc(cx + sway, y, 1.2, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  // ܓ̀ᚖ̫̬̉༊̃ܖ͉𒁁̐ܚ̍༼͉̻̊̉݁̎ᚗ̳̺̟̑ሕ͇̫̌ ̧̉ᚉ͍̈́ሎ̧͇ᚨ̈ᚹ̱̜
  if (p.convergence > 0.5) {
    const haloAlpha = (p.convergence - 0.5) * 0.3;
    const headY     = H * 0.225;
    const haloR     = Math.min(W, H) * 0.095;
    const pulse     = 1 + Math.sin(t * 0.7) * 0.03;

    ctx.strokeStyle = `rgba(200,215,240,${haloAlpha})`;
    ctx.lineWidth = 0.5 + p.convergence * 0.4;
    ctx.beginPath();
    ctx.arc(cx, headY, haloR * pulse, 0, Math.PI * 2);
    ctx.stroke();

    // ܒ̓ᚌ̖̊̂ሓ̘͈̮͆𒀛̆༅ͅᚣ̬̚
    if (p.convergence > 0.65) {
      ctx.strokeStyle = `rgba(210,225,250,${haloAlpha * 0.4})`;
      ctx.lineWidth = 0.3;
      ctx.beginPath();
      ctx.arc(cx, headY, haloR * 0.8 * pulse, 0, Math.PI * 2);
      ctx.stroke();
    }
  }

  // ᚉ͊ჶ̪̬̫̄༔͍͂̈ሜ̝̍ሡ̩̥́̕ᚪ̂ܦ͍̕ᚔ͎͆̈̊ܚ̩̑̈𒀅̡̯̰́ს̂ᚔ͍̮̀༢͍̰̻̹༊̡̙̺̯ᚙ̨̧༹̄̃𒀰̔ቅ̨̺̞͎̗̙ܳ̂̀ჱ̜̓̓̚ ̨͎̥̤𒀲ͅཀ̙̄͂ჭ̉ག̀̍𒀗̻༵͈ܙ̳ܴ̟̉̚ᚑ͈̻༱̀
  const mc = state.mirrorCursor;
  const handProximity = Math.min(1, Math.max(
    1 - Math.abs(mc.x / W - 0.15) * 6,
    1 - Math.abs(mc.x / W - 0.85) * 6
  ));
  if (handProximity > 0.1 && p.convergence > 0.2) {
    const handAlpha = handProximity * 0.18 * p.convergence;
    const handSide  = mc.x < W * 0.5 ? -1 : 1;
    const handX     = cx + handSide * W * 0.13;
    const handY     = H * 0.52;

    ctx.strokeStyle = `rgba(170,185,210,${handAlpha})`;
    ctx.lineWidth = 0.4;

    // ᚵ̦̜͉͍̺̾ܺ̏ܺ̋კ̨̬༒͇̍༴̜̙̀ܝ༹̘̰ሙ̼̮͆༌̪̻̝̅ჟ̼შ̩͌̊𒀫̼ܴ̺͈̙̏̾̇პ̝̿ሖ̟̯̈́̐ა̧̯ᛟ̣͂̕༡̭̲̔ᛊ̖̓̋
    ctx.beginPath();
    ctx.ellipse(handX, handY, W * 0.018, H * 0.022, handSide * 0.2, 0, Math.PI * 2);
    ctx.stroke();

    // ᚂ̒ህ̱̮̯ᛨ̇ቁ̱̎̒𒀊̫ჩ̬̥ჷ̩ܓ̟̰̍̑𒀔̫̜̺̭ܣ̮̺ሇ̺̯̱̀𒀔̤̼̆̂༺̹ᚡ̯̏̏ფ̘༤̨͉ܷ̭̀̔́გ̮̣̈́͊𒀛̯͊̄𒁈̑͋̒
    const fingerLen = H * 0.025;
    for (let f = 0; f < 4; f++) {
      const fAngle = -0.5 + (f / 3) * 1.0 + handSide * 0.3;
      const fx = handX + Math.cos(fAngle) * W * 0.018;
      const fy = handY - H * 0.022;
      ctx.beginPath();
      ctx.moveTo(fx, fy);
      ctx.lineTo(
        fx + Math.cos(fAngle - Math.PI * 0.42) * fingerLen,
        fy - fingerLen * 0.9
      );
      ctx.stroke();
    }

    // რ̳͍̽̋ᛍ̒ሐ̢̕𒁈̂̂ܩ̣̻͆ܨ̱ሾ̼̊́კ̦̘̈༴̼̘𒀔̳̇̓̕ᚗ̰̲̎͊༏̮̉̈͂𒁋̡
    const tAngle = handSide > 0 ? -0.9 : 0.9;
    const tx = handX + Math.cos(tAngle) * W * 0.014;
    const ty = handY;
    ctx.beginPath();
    ctx.moveTo(tx, ty);
    ctx.lineTo(
      tx + Math.cos(tAngle) * fingerLen * 0.7,
      ty + fingerLen * 0.4
    );
    ctx.stroke();
  }

  ctx.restore();
}

// ܓܑ̱̬̫͇݄̣̹̥̀༌̫̉̐ཇ̗͌͂̀ᚷ̧̬̯͌ܩ̰̭̕ც̻̯̳
// ም༙ܻ̫̘̔̒̄̏̄ሿ̪̓̿̈́༊̀̈ᚿ̫͍̆̿༇̯̘͊̍ᚋ̡̕̕𒁇̺̀𒀆̝͇̳́ሻ̢̆̍̏ᚐ̟̻̒གྷ̒ყ̹̖ჷ͉𒀫̢͈͋ᚲ̗̺̎̉༅̺̃ᚌ͈༷̆͂̇ህ̱̣̄̂ᚬ̰̮̅

function initScarGhosts() {
  if (!state.memory || !state.memory.scars || state.memory.scars.length < 1) return;

  state.scarGhosts = state.memory.scars.map((scar, idx) => ({
    convergence:     scar.convergence || 0,
    crack:           scar.crack || 0,
    erasure:         scar.erasure || 0,
    jitter:          scar.jitter || 0,
    pulse:           scar.pulse || 0,
    autonomy:        scar.autonomy || 0,
    drowning:        scar.drowning || 0,
    brightness:      scar.brightness || 0.26,
    temperament:     scar.temperament || 'flattering',
    sessionDuration: scar.sessionDuration || 0,
    crackCount:      scar.crackCount || 0,
    index:           idx,
    // ሦ̥̅ჷ̡𒀘̕ܢ̖̮̻̻͉̇͌ܿቇ̧͎̄𒁃̧̠̈̉ᚕ͍̐ሓ͎͋̕𒀖̧̇̌༥̽̄̑ሪ̒̐𒁎̢ფ̖̺̻ნ̖̲̓ᚁͅჯ͉ܾ̻ᛡ̩̫̲ͅༀ̹̼̭̈
    phase:           idx * 1.7 + Math.random() * 2,
    // ሩ̽͂̌̇ረ̼̬́̚რ༙̌̄̃͆͆ህ̢ᚳ̮͋ᚕ̋͂̽̒༡͎̖݈̹̎̚ᚳ̰ᛉ̨̍̒𒁂̇̾ᛊ̯༻̳̮͋̓ᛄ͎̅́ሮ̳̩𒀺̆̿ᛞ̎ཅ̡̺̤ሣ͈͆
    maxAlpha:        Math.max(0.02, (0.08 - idx * 0.015) + Math.min(0.03, (scar.sessionDuration || 0) / 3000)),
  }));
}

function drawScarGhosts(ctx, W, H, p, t) {
  if (state.scarGhosts.length === 0) return;
  // ზ̲̞̰𒀕̌̄̀ბ̘̈̅ᚉ͉̖͋༄݈̼̖༵̟̃̾̉᚜̝̌͌𒀈̩̀̊̊ვ̫̣ᛣ̝𒀫̮̟̯̥ܤ̱̀𒀸̢̡̞̲͎݊͌ᚆ̹კ̧̰ᚄ̯̤̀̑
  if (p.convergence < 0.25) return;

  const shift = p.skeletonShift;
  const cx    = W * (0.5 + shift);
  const e     = p.env;

  ctx.save();
  ctx.globalCompositeOperation = 'screen';

  for (const ghost of state.scarGhosts) {
    // ᚖ̡̦̋̚𒀣̺̹̌̽𒀜͎̔̈̑ᚃ̞̅ᚒ̀́ᚃ̰͆̎ᚼ̩̈́ሾ̍̅ܨ̙̹͋̚ი̬́ܢ̮ᛂ̭̏༜̒̅͌̚ყ̏̄ს̨̀ღ̱̃̿ሸ̐ܮ̺̱́͊შ̮̟͌ܨ̢̼͋͆༭̧̏ር͎̲̈ሆ̪̜̅̑
    const flicker = Math.sin(t * 0.3 + ghost.phase) * Math.sin(t * 0.7 + ghost.phase * 0.6);
    if (flicker < 0.2) continue;

    const alpha = ghost.maxAlpha * (flicker - 0.2) * 1.25 * (p.convergence - 0.25) * 2;
    if (alpha < 0.003) continue;

    // ᛗ̰̗ህ̻͎͈̘መ̝͎̰̄ܨ̃̆𒀅̈́̂ჰ̙̅უ̧̮̮͍͈̿݅̋̓ჵ̲̩̈́ܥ̂ራ̭̘།̻͍̂̀ሰ̩̀ሀ́̓ᚍ̈ም̧̩̱́༽̿༎̮̊ሢ̓̿༓̄̔კ̓͋ሹ̼̺̤͌݇̒͂̕ᚢ̯̓̑̀༏̇̾ᚑ͍͈̌ᚰ̈ሺ̹̤̃༚̨̜̃̅ܐ͇̻͊༻̻̟༘̦̥͉͆̊̐ሣ̫̄ᚂ͍̑͌̊ᚋ̱̜̍ნ̟̰̄̎ᛥ̐̕
    // 𒀐̀̕་͆ܣ̞̗̮ሖ̔ሙ̣̟ܷ̮̃ܿ͌𒀡̨̝̗͋ᛐ̹̕𒀽̻̪̹̿რ̢̟݈̬̇̃́̕წ̼̇͊ܒ̲̻̗̪̽̈́̆݀̇ܲ̎̀𒀻̜͇̃ᛣ̨̽ც̢̳ნ̡̘̪ቁ̽დ̯̝༶̢̗༎̺̆̔ܞ̋̚ქ̂̅̓᛭̟
    // თ̼᚛̊ሃ̞̒̑̆ჩ̌ᚈ̖̅𒀇̧̺ͅო̨̦༡̜̆̊̐༝̟̑̀მ̲ც̪́𒀷̥̤̠̿ᚵ̧̇̏̕𒁃̥̻̈́̅ܫ͂̈ͅ༠̻̂ᚇ̗̌̍ᚕ͎̈́̏ሕ̝͌𒁉͍̀𒁀̪̙̲̐ܽܫ̞̒̿ܺ̓͌̔༖̤̉་̰̫̇ᚁ̱̫̎̓
    // ሏ̨̙̅͆ሢ̿̍༱̤̑̐͆ᛞ̂̍ቀ̽ᚈ́ჷ̠̗̱̆ܶ̒̈́ჵ̲̂ͅᛐ̧̓ቂ̟͈͂𒀒̣ሷ̡̀ᚋ̭̲̋ܖ̀̓ᚚ̋̊̔།̡̥̖݅̐̏གྷ̦̗𒁂̀𒀌̒ჴ̩̄ሿ̧̣̿𒀥̻̽̈ܛ̞̙̐ᛠͅሌ̳ቄ́͂ሿ̔ᛋܷ̎̈́̿̓𒀔̡̏༺̲͈̀̒
    let tR = e.paletteR, tG = e.paletteG, tB = e.paletteB;
    switch (ghost.temperament) {
      case 'flattering':
        tR = Math.min(255, tR + 15);
        tG = Math.min(255, tG + 10);
        tB = Math.min(255, tB + 5);
        break;
      case 'cruel':
        tR = Math.max(0, tR - 25);
        tG = Math.min(255, tG + 5);
        tB = Math.min(255, tB + 30);
        break;
      case 'silent':
        // ᚸ̰𒀠̡̥͇̏ე͎̓͊̓ᚸ̖̟́ᛎ̳༔͎̪ᛧ̢̙̆𒁇͉̭̫̊ჹ̼̎ლ̖̱͂ ̲𒀗̗̰ᛅ̓ᚰ̤̂̍ᛣ͉̃༕̢͇̓ር̡̓ᚘ̳̳̰𒀬̗ᚻ̭̟̭𒀝̀ᚗ̏̍̆𒀸̟̍̈́̚ᚻ̭̥̾̆ᛮ̩̃̀̓༿̨ሶ̮̒
        const avg = (tR + tG + tB) / 3;
        tR = Math.floor(tR * 0.5 + avg * 0.5);
        tG = Math.floor(tG * 0.5 + avg * 0.5);
        tB = Math.floor(tB * 0.5 + avg * 0.5);
        break;
      case 'devotional':
        tR = Math.min(255, tR + 20);
        tG = Math.min(255, tG + 8);
        tB = Math.max(0, tB - 15);
        break;
    }

    const gR = Math.floor(tR * 0.6);
    const gG = Math.floor(tG * 0.65);
    const gB = Math.floor(tB * 0.75);

    // ሤ̨̹̕ሾ̞̤̄༐̼ሦ̚ᚤ̊ሩ͎͊ሜ̜̬̩͆𒀏̳͇̗̐ܕ̼̣̃ܥ̙̇́კ̭̄ͅე͈̄ჵ͋͊ሧ̈̓͂̃
    // ᚗ̡̳̅͆ሁ̊ሚ̫̬̫̃ᚬ͎ვ̲ͅᚘ̙̦͌𒀱͈̹̭̇ܜ̇͊ᚆ̼̞͉̯ᚂ̰̀𒁌̭̍ზ̱᚛̢ᛗ͎̑ܥ͍ቈ̥̽ძ̰̟̤
    const jitX = ghost.jitter * (Math.sin(t * 3.7 + ghost.phase * 2.1) * 3 +
                   Math.sin(t * 7.3 + ghost.phase) * 1.5);
    const jitY = ghost.jitter * (Math.cos(t * 4.1 + ghost.phase * 1.7) * 2);

    // ༛̿̆̿ᛑ̤̦̄ᚗ̧̡̅̚ᚔ̬̮̩̣ᚔ̪̓́̂𒁇̍͂ܭ́̕ሹ͂ሆ͉̪̝ͅᚍ̜͋̅̾ሻ̓ᚙ̮̇ᛗ̳༷͎̘́̓ქ͆͂̂ܐ̃ቃ̘̯ͅქ͌͊𒀥̹̬ܮ̣̉͌̈ሮ̥̅̄პ̉ა̃ᛥ̝༵̺̺̳ᛈ͌𒀨̡̳̔ሞ̣ሴ̑ა̨͈̲ͅ𒁊̐̈̉ᚚ̡𒀭̒̊ሑ̮̈̏უ̢̞͂͋ᛒ̗̤ᚥ̼ᚒ̯̖̈̎ም͎̬̖̄
    // 𒀈̡̩̈́̕𒀭̪̭̒̾ቂ̯̟𒀵̰̱́ᚗ̾̿͊ᚁ̞̀̐ͅჭ͍̺̈ᚆ̒ᚣ̘ᚗ̼̔ም̔̀̉̄ᚅ̢̃ͅჹ̐ཀ̖̰̣̄ܲᚔ̬ᚂ̡̪༠̲̆ܔ̗̓̈ང̡̑́́̋݇̏ᚖ̡ე̪̩͍̓ሗ̠̬݆̜̟̇̓̽̔ༀ̢̘̥̓პ̏̓ሧ̥̞༻̎ᚃ̰̿́ლ̜ᚑ̬̂̍შ̦̦̏ᛅ̙͋𒀦̨̃̿̈́
    const driftX = ghost.autonomy * Math.sin(t * 0.15 + ghost.phase) * W * 0.012;
    const driftY = ghost.autonomy * Math.cos(t * 0.11 + ghost.phase * 1.3) * H * 0.006;

    const gcx = cx + jitX + driftX;

    // ᛄ̙ᚱ̀̒̀𒀦̓ᚷܸ̍̎̿ܒ̄ܚ̥ღ͈̦̹̮༞̮̥̗̝ᛗ̒̚ᚪ̭̙͈̥ქ̧̟͈𒀦̀༁̮͍̀𒁃͈̂ሧ͍̜ჰ̖̟̓͆𒀌̬̲̹̒ᛖ̥̾ჩ̠𒀋̻̜̇̄༩̡̠̭ܟ̞̚̕ᚴ̨̳̎̉ܤ̼ᚵ̰̼ܻ̪̀ܡ̪͉̂̈́༓̰̪ი̦̭̃̓𒁋̼̋̕ܠ̦̩̗̕ሀ̹͋͊ჸ̄𒁏͍̓͊
    const ghostConv = ghost.convergence;
    const ghostBright = ghost.brightness;
    const headR = Math.min(W, H) * (0.04 + ghostConv * 0.06);
    const headY = H * 0.27 + jitY + driftY;

    // ̹݊༬̲̦̍̒ᚄ̊̽̽ტ̪̀͌̀༠͇̒̈́ሷ̢̯͍̈ለ̨́̂ჷ̖̔̉̕ሬ̈́𒀟͇̯̐̋ᚴ̥ᛣ̠̥̔̕གྷ̯̎͂ሎ̭͎̆̎ჸ͇́̊𒁌̞̾ᚊ̣ͅ𒀱͇̈́̅̀ᚅ̢̩̐̋́݀
    const headGlowAlpha = alpha * (0.5 + ghostConv * 0.3 + ghostBright * 0.2);
    const hg = ctx.createRadialGradient(gcx, headY, 0, gcx, headY, headR);
    hg.addColorStop(0,   `rgba(${gR},${gG},${gB},${headGlowAlpha})`);
    hg.addColorStop(0.55,`rgba(${gR},${gG},${gB},${headGlowAlpha * 0.35})`);
    hg.addColorStop(1,   `rgba(${gR},${gG},${gB},0)`);
    ctx.fillStyle = hg;
    ctx.beginPath();
    ctx.ellipse(gcx, headY, headR, headR * 1.15, 0, 0, Math.PI * 2);
    ctx.fill();

    // ᛏ̖̩̅ቄ̀ᛧ̨͎̅ᚂ̘̯̋݁͊ሥ̽̆༥̗ᚄ͈̥̌ᚅ̼̙̈𒀁̧̙̥ͅᚒ͎̘͉̆𒀚̟̫̈́ᚡ̏ܫ͈͋̌ܞ̥̥̫̆ᚐ̳𒀳̝͆𒁈̧͉̝̑ᛄ̠͉̓̀ܧ̳̳̄̓ቈ̟̳̪̳݅̽ᚔ̘̕ሴ̿̏კ̼̼̩́ܬ̪̘̉̊ი̡͈̊̔𒀒̢̰̔̔ჵ̘͉̐̕𒀁̯͌̿͆ᛌ͋ሥ̀̑ᚳ̨̓༗͍̚ᚫ̰̣̥̌ሧ̠̜༙̘̓
    if (ghostConv > 0.15) {
      const neckY = headY + headR * 0.85;
      const neckR = headR * 0.32;
      const neckAlpha = alpha * ghostConv * 0.3;
      const ng = ctx.createRadialGradient(gcx, neckY, 0, gcx, neckY, neckR);
      ng.addColorStop(0,   `rgba(${gR},${gG},${gB},${neckAlpha})`);
      ng.addColorStop(1,   `rgba(${gR},${gG},${gB},0)`);
      ctx.fillStyle = ng;
      ctx.beginPath();
      ctx.ellipse(gcx, neckY, neckR, neckR * 2.5, 0, 0, Math.PI * 2);
      ctx.fill();
    }

    // ܢ̼̻̝̬𒀀̍̄̓ᛃ̾ᚗ̧̫̑ᚅ̮̝̱𒀘̹̜̲̔༬̈́𒀷̠̈̑̚ᚁ̮͋́̕ᚃ̫̓͋𒀵̢̨̯̭ܼ̾ᛕ̡ჲ̪͌́ᚒ̞͆̀̕ᛔ̧̠̘ᚎ̡̧̽̿༈̖̳͋༈̮̰̓ᚘ̡̲̫̔ሻ̯̜̺𒀪̂̇̆ღ̻̖͎ᚇ̣̖ܹ̏̓̑ͅ𒁏̖͌̚ሻ̡̡̲ܺ̚ረ̨̲̣ᚏ̨̲̀༑̟̥̟̽𒀢̠̈́ა̌ͅᛥ̪༘̺̺𒀵̪͉̹̐
    const torsoY = H * 0.48 + jitY + driftY;
    const torsoR = headR * (1.5 + ghostConv * 0.5);
    const torsoAlpha = alpha * (0.4 + ghostConv * 0.25 + ghostBright * 0.1);
    const tg = ctx.createRadialGradient(gcx, torsoY, 0, gcx, torsoY, torsoR);
    tg.addColorStop(0,   `rgba(${gR},${gG},${gB},${torsoAlpha * 0.6})`);
    tg.addColorStop(0.45,`rgba(${gR},${gG},${gB},${torsoAlpha * 0.18})`);
    tg.addColorStop(1,   `rgba(${gR},${gG},${gB},0)`);
    ctx.fillStyle = tg;
    ctx.beginPath();
    ctx.ellipse(gcx, torsoY, torsoR * 0.7, torsoR, 0, 0, Math.PI * 2);
    ctx.fill();

    // ᚜̖̌𒀸̊ᚪ̀ქ̊͂ᛧ̫̙ሽ̰
    if (ghostConv > 0.35) {
      const eyeAlpha = alpha * ghostConv * 0.45;
      const eyeSpacing = W * 0.042;
      const eyeR = W * 0.014 * (0.7 + ghostConv * 0.3);
      const eyeY = headY - headR * 0.05;

      for (const side of [-1, 1]) {
        const exx = gcx + side * eyeSpacing;
        const eg = ctx.createRadialGradient(exx, eyeY, 0, exx, eyeY, eyeR);
        eg.addColorStop(0,   `rgba(${Math.min(255, gR + 40)},${Math.min(255, gG + 50)},${Math.min(255, gB + 60)},${eyeAlpha})`);
        eg.addColorStop(0.4, `rgba(${gR},${gG},${gB},${eyeAlpha * 0.3})`);
        eg.addColorStop(1,   `rgba(${gR},${gG},${gB},0)`);
        ctx.fillStyle = eg;
        ctx.beginPath();
        ctx.arc(exx, eyeY, eyeR, 0, Math.PI * 2);
        ctx.fill();

        // ሥ̯̫́́༜̧ᚉ̢̮́ሸ̄𒀽̨͍̈́𒀭̻ᚍ̩̏ሁ̜̹͌ᚇ̱̬͆̕༻̖̋ܮ̧ა̨̙͌̄ܢ̳̂ᚏ̳͍͌ܪ͍̯͆ሕ̭̗ᛘ̘̐ང̜͎̟̭༦̘ሦ̧̙༢̢̪͍̚ᚂ̹̳ᚙ̨̝̍̿ቅ̠ᛗ̟̮̈͂
        if (eyeAlpha > 0.015) {
          ctx.fillStyle = `rgba(2,2,6,${eyeAlpha * 0.7})`;
          ctx.beginPath();
          ctx.arc(exx, eyeY, eyeR * 0.3, 0, Math.PI * 2);
          ctx.fill();
        }
      }
    }

    // 𒀠̦̉̂ሐ̭̇̂ᛃ́ላ̎̊ሀ̻̰̾𒀱̇͆༐̳̏̕შ̙͋༈̢̤̒͆ᚪ̳ჶ̞̰̻ܠ̥༧͉̬̩͌ჹ̢̒̌̌ყ̪
    if (ghost.crack > 0.1) {
      const crackAlpha = alpha * ghost.crack * 0.6;
      ctx.strokeStyle = `rgba(${Math.min(255, gR + 30)},${Math.min(255, gG + 25)},${Math.min(255, gB + 35)},${crackAlpha})`;
      ctx.lineWidth = 0.3 + ghost.crack * 0.4;
      const crackCount = Math.floor(ghost.crack * 6) + 1;
      for (let i = 0; i < crackCount; i++) {
        const angle = ghost.phase + i * (Math.PI * 2 / crackCount) * 0.7;
        const len = headR * (0.6 + ghost.crack * 1.2);
        // ̥̠̹ܰ̓༯̇͌ሁ̭თ̤̦̞͊ር͌ሃ͂ሯ̧͇̬̒ᛩ̤̈͆ᚇ̏̐ቂ̖ሗ̲̻̚༆̒ბ̻̓̂ᚇ̧̟̤̞݉̌ᚗ̙͌𒁇̯̉༎̧̇̂ͅሎ̢̽ᛢ̱ᛖ̞̐̎ᚎ̜́༭̹̺́̿
        const bx = gcx + Math.cos(angle) * len;
        const by = headY + Math.sin(angle) * len;
        ctx.beginPath();
        ctx.moveTo(gcx, headY);
        ctx.lineTo(bx, by);
        ctx.stroke();

        // ᚍ́ܚ̡̪͋ܥ̟̭̌̊ሇ̟̞༺̙̰͆̒ᚑ̩̝݂̄̔𒁀̖̀̃ቆ̤̄̕༿̜̈́̽ሯ̿༡̖͇̒༴̀თ̡̯̘̎༔̡̗̜ܞ̤𒀵͇̱͉༧̣̞̗ღ̆͊𒁆̢̼რ̫ܗ̯̹̒͆ᚁ༙̼̰̏͊́̓́̕༳̙̀̂ܜ̡݅́́ჟ̡་̻͊̽̑ᚌ̺̯𒀎̝̆𒀠̨̥̈́𒀄̩̔ܬ̝̅ܙ̤̳̌̍
        if (ghost.crack > 0.4 && i % 2 === 0) {
          const subAngle = angle + (shardHash(i, ghost.index) - 0.5) * 1.2;
          const subLen = len * 0.45;
          ctx.beginPath();
          ctx.moveTo(bx, by);
          ctx.lineTo(bx + Math.cos(subAngle) * subLen, by + Math.sin(subAngle) * subLen);
          ctx.stroke();
        }
      }

      // ᚜̦̫𒀊̱͂̕ ̫̄𒀰̻ሑ̹̩ሀ̞́༞̨ܸ̳͂ܛ́ཆ͈𒀀̈༦̟̘̋́ᛅ̣ᚬ̯̣̘̓ᚍ̕༓̬𒀱̮̪̌ᚑ̜̑̑̾
      if (ghost.crack > 0.3 && ghost.crackCount > 3) {
        const tCrackCount = Math.min(4, Math.floor(ghost.crack * 3));
        for (let i = 0; i < tCrackCount; i++) {
          const angle = ghost.phase * 0.7 + i * 1.4;
          const len = torsoR * (0.3 + ghost.crack * 0.5);
          ctx.beginPath();
          ctx.moveTo(gcx, torsoY);
          ctx.lineTo(gcx + Math.cos(angle) * len, torsoY + Math.sin(angle) * len);
          ctx.stroke();
        }
      }
    }

    // ᚈ̡̪́ᚘ̠̜̺̚ܘ̫̇ራ̠̘გ̫̦̄ܵͅგ̼̏ሃ̜̈̀̊ტ̾݊̿მ̨̰̋༩̋ሾ̯ሸ͆ᛢ̀ᚔ̯̅༂̫͍̋ܟ̱̥ሁ̺̀̏́ ̅̄
    if (ghost.erasure > 0.15) {
      const eraseAlpha = alpha * ghost.erasure * 0.4;
      ctx.strokeStyle = `rgba(${Math.floor(gR * 0.7)},${Math.floor(gG * 0.75)},${Math.floor(gB * 0.85)},${eraseAlpha})`;
      ctx.lineWidth = 0.3 + ghost.erasure * 0.5;
      const scratchCount = Math.floor(ghost.erasure * 4) + 1;
      for (let i = 0; i < scratchCount; i++) {
        const sx = gcx + (shardHash(i + ghost.index * 17, 42) - 0.5) * headR * 2.2;
        const sy = headY + (shardHash(i + ghost.index * 31, 77) - 0.3) * headR * 3;
        const ex = sx + (shardHash(i + ghost.index * 53, 19) - 0.5) * headR * 1.5;
        const ey = sy + shardHash(i + ghost.index * 71, 53) * headR * 0.8;
        ctx.beginPath();
        ctx.moveTo(sx, sy);
        ctx.lineTo(ex, ey);
        ctx.stroke();
      }

      // 𒀼̟̱ሒ̼̬̀̕𒀊̟̂ძ̡ሦ̰̉ͅܕܑ͇͍̍̐͆ᛟ̫ሖ̡̤̊̎წ̯̩̮̎ᚐ͇༓̡̪̚ᚕ̧ᚍ̨̫ሂ̻̗̆ͅሑ͈̤̎̂ᚫ͎̱̞̻ი̠ᚕ̡̣̻ܻᚨ͉̕𒀬̯̹̿́ܖ̧ᚃ̊
      if (ghost.erasure > 0.5) {
        const mouthY = headY + headR * 0.45;
        const mouthW = headR * 0.35;
        const stitchAlpha = alpha * (ghost.erasure - 0.5) * 0.5;
        ctx.strokeStyle = `rgba(${gR},${gG},${gB},${stitchAlpha})`;
        ctx.lineWidth = 0.3;
        const stitchCount = Math.floor((ghost.erasure - 0.5) * 6) + 2;
        for (let i = 0; i < stitchCount; i++) {
          const sx = gcx - mouthW + (i / stitchCount) * mouthW * 2;
          ctx.beginPath();
          ctx.moveTo(sx, mouthY - 1.5);
          ctx.lineTo(sx, mouthY + 1.5);
          ctx.stroke();
        }
        ctx.beginPath();
        ctx.moveTo(gcx - mouthW, mouthY);
        ctx.lineTo(gcx + mouthW, mouthY);
        ctx.stroke();
      }
    }

    // ሠ̳̙́̿ቂ̲𒀷̘̗̞̀ᚉ̖ᛖ̯̈̄ᚏ̦̜̓̔
    if (ghost.drowning > 0.05) {
      const dAlpha = alpha * ghost.drowning * 0.55;
      // ჰ̝͇̖̮𒀾̠რ̞̓ᛒ̪̂̇პ̹̅̉̀𒀄̺̀ሇ̫ᚒ͎̳̱̉ᚒ̧̝̪̝ܜ̀ᚏ̙̣̠̚𒁂̡ܥ̮͌ᚐ͈̀ܣ̓
      const ghostBottom = torsoY + torsoR;
      const waterFrac = 1 - ghost.drowning * 0.55;
      const waterY = headY + (ghostBottom - headY) * waterFrac;

      // ስ̃ჰ͇͉ᚳ͍ე̥̅ვ͊͂̋ሞ̡̖༥̢̭͆͂༌̟̝̣̌𒁋̫ܒ̬̌𒀏̨̲̜ჸ̜̖͌̇𒀣̡̨̈́̽ᚵ̠̃ც̕ᛥ̻̟̈̓ܙ̳̹̀̚
      const waterH = ghostBottom - waterY;
      if (waterH > 2) {
        const wg = ctx.createLinearGradient(0, waterY, 0, ghostBottom);
        wg.addColorStop(0,   `rgba(1,2,8,${dAlpha * 0.25})`);
        wg.addColorStop(0.4, `rgba(1,1,6,${dAlpha * 0.5})`);
        wg.addColorStop(1,   `rgba(0,1,4,${dAlpha * 0.7})`);
        ctx.fillStyle = wg;
        ctx.beginPath();
        ctx.ellipse(gcx, (waterY + ghostBottom) / 2, torsoR * 0.85, waterH / 2, 0, 0, Math.PI * 2);
        ctx.fill();
      }

      // ܪ́༥̑ᚱ̞̍ܚ̞ሧ̪̌͂ე͍̽༯̖̝̟͋ሞ͍ܱ̾̏̏𒁏̳
      if (ghost.drowning > 0.15) {
        const rippleAlpha = dAlpha * 0.4;
        ctx.strokeStyle = `rgba(${Math.min(255, gR + 20)},${Math.min(255, gG + 30)},${Math.min(255, gB + 40)},${rippleAlpha})`;
        ctx.lineWidth = 0.3;
        ctx.beginPath();
        const rippleW = torsoR * 0.7;
        for (let x = gcx - rippleW; x <= gcx + rippleW; x += 3) {
          const ripple = Math.sin(x * 0.05 + t * 0.8 + ghost.phase) * 1.5 * ghost.drowning;
          const py = waterY + ripple;
          if (x <= gcx - rippleW + 1) ctx.moveTo(x, py);
          else ctx.lineTo(x, py);
        }
        ctx.stroke();
      }
    }

    // ჸ̺̒̓ᚄ̣̹̺ͅჯ̿̓ᛢ̨́ᛐ̙̺͌შ̼༧̻̒̐̊𒀧̤̊̽ቆ̐̿́༎̤̰̇̇ჹ̪͌ᚳ̢̥̖̽ܿ̃̃݃̒̀̚კ̹̹̌̚ሡ͈̄̓̄ܝ̓̃̇ͅሰ̫̩̀ᚁ̞͂ᚘ̮ܨ̏̃͋̈́ཀ̯̆̆̀ᛓ̱̱̑ᚓ̼̱̦༔͇ც̨̲́
    if (ghost.pulse > 0.15 && ghostConv > 0.2) {
      const pulsePhase = Math.sin(t * 1.8 + ghost.phase * 0.9);
      if (pulsePhase > 0.3) {
        const pulseAlpha = alpha * ghost.pulse * (pulsePhase - 0.3) * 0.35;
        const pulseR = headR * (1.2 + pulsePhase * 0.15);
        ctx.strokeStyle = `rgba(${Math.min(255, gR + 25)},${Math.min(255, gG + 20)},${Math.min(255, gB + 15)},${pulseAlpha})`;
        ctx.lineWidth = 0.3;
        ctx.beginPath();
        ctx.arc(gcx, torsoY - torsoR * 0.15, pulseR, 0, Math.PI * 2);
        ctx.stroke();
      }
    }
  }

  ctx.restore();
}

// ᛤ̞͇̈𒀵̢ܷ͋̄̔ჰ̭̌̚ე́̊̽̚ᛎ̓̌ͅᛎ̡̔༞̤̓̓ჲ̈ᛝ̻̰ბ̡̹͊ܵ𒀦̹͊ܫ͇̙̒
function renderMirror() {
  const canvas = document.getElementById('mirror-canvas');
  const ctx    = canvas.getContext('2d');
  const W      = canvas.width;
  const H      = canvas.height;
  const p      = state.portrait;
  const e      = p.env;
  const t      = Date.now() * 0.001;
  const ms     = e.motionScale;

  // ܖ͎̞̐ል͉͊̽̀ᚕ̫͂𒀣̤ᚥ̡̥̀̀ᚃ͉̅͆́གྷ͎́་̡̻̰̀ቆ̭ܒ̤̾̅ܡ̡̠ᚉ̳̻𒁂̡̞݅̆̚ვ́༄̧̦̼ܾ́̑݅͌ཇ̠͉༪̫
  const lightDx = Math.cos(p.lightAngle);
  const lightDy = Math.sin(p.lightAngle);

  // ܼ̓༃̦̈́̕ᚕ͉̄ሷ́ܧ̹̮̑̽ܓ͎̪̣̅𒀟̘ᚈ̧͉̐̅𒀞̨̨̇̕༎̮̠༖̬༿̤̏̃̚კ̦̕
  ctx.fillStyle = `rgb(${e.bgR},${e.bgG},${e.bgB})`;
  ctx.fillRect(0, 0, W, H);

  // ̗ܲ̾̃ͅ𒁈̏̕ሸ̤̊ძ̯͎̥̄ᚤ̄ሙ̏̕ᚏ̳͌ᚚ̞́̍ᛖ̣̈̎ͅᛉ̬͉̇𒀘̩̱͌ሀ̕ᛧ̭̠༵̟̽̃̂ᛦ̨̰̋ჭ̲̤̂
  if (state.driftPolys.length) drawDriftPolys(ctx, W, H, p, t);

  // ༯̦̱̓̅᛬̢݈̝͇𒀓̖̝̔ͅܕ̢̼̾ᛓ̪̈́̃͌𒁀͉ქ̲ܴ̦̪̌ܔ̻̽͋̌რ̦̀ܕ̃̽̿ሄ́
  if (state.metaballs.length) drawMetaballs(ctx, W, H, p, t);

  // ᚗ͇̠́პ̣̣̍ᚁ͇͋̐ᚓ̥̇̈́́𒀤̺̱̒ܢ̧̩̏ტ̟̭̌̄ᛋ̜̒ᛉ͉ᛠ̐ᚚ̡͇̋ቈ̞̃ᚎ̡̟̀̌ሔ̝̉̎ͅܔ̳ᛉ̥̥̄̍ᛁ̤̒ܰܟ̄ᛛ̃ᚄ̏ფ̱̞̓̓༑̦ᚫ̞ܚ̲̮̝̉𒀣̞༌̳̯̑̅ቃ̳̦̓ཅ̢̯͉༙͎რ̲́་̢̙̙̊ᛊ̢̀̔ሿ̧͊𒀤̙͂𒀬͉̖̉ͅ
  drawLiquidMirror(ctx, W, H, p, t);

  // ვ̣̭̳̂ܖ̺𒁋̻̺̦̇ܽ̓͂𒀝̼ᚂ̌ᚄ̲̓ჸ̞̇̆ᛯ̮𒀝̉ᚌ͉̐̂͊ჳ̢̣̯̳̻̗̰̍݊༿͈̇ᚨ̘̳̣̒̈݊𒁆̰̪̃ᚸ̯͈͂ᚎ̳̗ᛋ̍̆ჰ͎͂̆ᚢ͊ሽ̭༖́̄༯̪̮̙̉᛬̡̕ᚷ̥̜̪ܶ̅
  const transientSink = p.sinkDepth * H * 0.06;
  const drownSink     = p.drowning * H * 0.28;   // ሬ̟̝̌̒݁ሻ͆̉̈መ̡̩͋༱̑̈ሩ̨̲̅ሷ̬̦ሬ̘̞̜̆ე̝̑̕ᚋ̱̞̋̿𒀚̭͍̝̕𒀵̥͈𒀸̢̄̋͆ሶ͇̟̌𒁌̱̻̈́̕ს̻̅᚜̣̬͉̤
  const sinkY         = transientSink + drownSink;

  ctx.save();
  ctx.translate(0, sinkY);

  // ̹̺͈ܶ̆᚜̠̞̈ᚂ̖̙̄᛭̜̑̒𒀆͎̎ᛀ̅͊
  if (p.resizeInjury > 0.04) {
    const shear = p.resizeInjury * 0.08 * Math.sin(t * 12) * ms;
    ctx.transform(1, shear, -shear * 0.5, 1, 0, 0);
  }

  // ܪ̄༯̕ቄ͇̗̃༻͇̄̒ቆ̮͋𒀭͈̋༰̟ჺ̖̭͍̍ᛂ̽̎̌ͅ༡̪݄̟ᚊ̳𒀪͉̿თ̥̪̄̀ܢ̠̉͂ჹ̈
  if (p.breathDepth > 0.01) {
    const breathY = Math.sin(t * 0.6) * p.breathDepth * H * 0.012 * ms;
    ctx.translate(0, breathY);
  }

  // ᚃ͍̺ზ̢ܢ̼͋ህ̱̟̅̿ቀ̘̞̅𒀭̻̂́ჸ̩̑ც̠̤͂̀ሷ̲̮̿̈𒀚̗ᛆ̧͎̉༊̼͉̇̍༕̞̳̯ᚐ̬̄ს̟̹̇̓ܘ̧̦̼༙̟̇͌́𒁋̫͇̋ሎ̖̀́̐𒁃̋ሲ͂ͅܒ̰̠̜ܱ̪̻͊͋ሽ̢͇̹̗ܩ̡̢ნ̼̯ܓ̇̚ტ̨̪̫ჲ̥̽ჟ̞̗̓ᚁ̥̮́̂༇̣̘̦݉̿̑ሢ͈̅̈́ᚶ́̾̋ᚊ̦̃̌
  if (e.sovereignty < 0.8) {
    const shrink = 1 - (1 - e.sovereignty) * 0.08;
    const dx = W * (1 - shrink) * 0.5;
    const dy = H * (1 - shrink) * 0.5;
    ctx.translate(dx, dy);
    ctx.scale(shrink, shrink);
  }

  // ༼̨̮̕ሼ̤̱̄̕ჩ̿̓͂ᚅ̲̕ཅ͇̬̈́ი̡̰̆ቂ̺͎̅݊̂ሐ̜ჱ̾ሊ̳ሗ̞̻ᛚ̨̋ლ̰́̄༤̠ሑ͂༤͂̿ჩ̰͈̘̤𒀼̻ᛒ͈̼͆ቄ̿̓༃̻ჺ̦̘̥̑̀ܽ̕ሑ̫̈́̀
  // ჳ́༓͍ᚙ̩̒͊̕ჷ̡̱̠𒀤̀༓̈́ᚗ̯̒́ᛪ̀༐̌͋༈̨̨̎̾
  const autoBase  = p.autonomy;
  const swayAmt   = autoBase * 4.5 * ms;
  const swayX     = Math.sin(t * 0.28) * swayAmt * e.driftDir;
  const swayY     = Math.cos(t * 0.19) * swayAmt * 0.5;
  const breathAmt = autoBase * Math.sin(t * 0.85) * 1.2 * ms;
  const headDrift = autoBase * Math.sin(t * 0.12) * 2.0 * ms * e.driftDir;
  ctx.translate(swayX + headDrift, swayY + breathAmt);

  // ̤̹̼݊𒀡̡̈́͆ᚃ͋̋ሶ̲ᚅ̓́ሗ̼͉༓̢̽̌༿̙̊̕༧̽̉ი̹̓ܪ̔̕ܠ̒ᚋ̞̖̋̀ფ̨͇̾༿̦̣
  const erasureSeed = Math.floor(t * 0.4);  // ሹ̔ቂ̽̍̋ᛪ̌𒀽̌𒀍͉̟͂͌𒀗̟̙̌ཆ̬ჷ̌̓ჭ͉̖̮ܻ̟̥̅̚ ̓̈́ཆ̧ᚄ̼̆̾́ቅ̢̖̭̌𒀵̜̆̐ᛩ̢̢̠̀𒀌̟ܹ̲ͅჵ͂
  state.shards.forEach((s, idx) => {
    s.glowTarget = s.inPortrait * p.convergence * (p.brightness + p.autonomy * 0.1);
    s.update();

    // ᚁ̣݃́̐̎ ̘̯̱̫ሾ̨̥̮̎ ̗̰ܵ̇̋༜̨̎͂ᚥ̔̕ሜ̦̩̱༏̣̜̹ቈ̨ᛝ͍̚ᛒ̊́𒀖̲̰͊̓ᚏ̲ᛤ͎ܪ̨̖თ̲̋ᚼ̖͇̊ᚆ͍̥̬̗ᚧ̯̈́ͅ
    if (p.erasure > 0.15 && s.inPortrait > 0.4) {
      const erasureChance = p.erasure * 0.45 * s.inPortrait;
      if (shardHash(idx, erasureSeed) < erasureChance) return;
    }

    // ᚎ̺̀𒀠͌ᚕ̢ლ̨̯͊ܗ̢̦̬̰ფ̟͂̃ᛤ̜̲̾̕ᚻ̱̍̾ቄ̺̓̕ᛜ̓ᛈ̧̄̔̍ᛌ̱͍̠̪ჺ̰̀̿͊ᛕ̩
    const ny = s.cy / H;
    let tremorX = 0;

    // ༕̯̘̚̕ቄ̢̫̰͈̿ܶ̀ܧ̘̺̐͌ᚓ̺́᚜̬̭
    if (p.typeTremor > 0.1) {
      const inJaw  = (ny > 0.34 && ny < 0.42) ? 1 : 0;
      const inRibs = (ny > 0.52 && ny < 0.68) ? 0.7 : 0;
      tremorX = (inJaw + inRibs) * p.typeTremor * (Math.random() - 0.5) * 7;
    }

    const needsDisplace = p.jitter > 0.35 || tremorX !== 0;

    if (needsDisplace) {
      const mag = p.jitter > 0.35 ? (p.jitter - 0.35) / 0.65 : 0;
      const jx  = (Math.random() - 0.5) * mag * 5 + tremorX;
      const jy  = (Math.random() - 0.5) * mag * 4;
      const jverts = s.origVerts.map(v => ({ x: v.x + jx, y: v.y + jy }));
      const savedV = s.origVerts;
      s.origVerts  = jverts;
      s.draw(ctx, p, lightDx, lightDy);
      s.origVerts  = savedV;
    } else {
      s.draw(ctx, p, lightDx, lightDy);
    }

    // ܮ̫̖͉݅̇ͅუ̟́ܪ̻̿̽̈́ር̡̳ܪ̠̞̖̋ᚭ̮̦𒀽̞̦̼̪𒀉̦̈͋༛̤̬̌͆ሀ̺̻̆̏ཀ̫̝̊ᚓ݈̖͈̰̓̆༔̰̍̍༼͇༣̮̭͉̉᛭̽ᛂ̟
    if (p.panic > 0.2 && s.inPortrait > 0.25) {
      const copies = p.panic > 0.7 ? 2 : 1;
      for (let c = 0; c < copies; c++) {
        const pMag = p.panic * 8;
        const pverts = s.origVerts.map(v => ({
          x: v.x + (Math.random() - 0.5) * pMag,
          y: v.y + (Math.random() - 0.5) * pMag * 0.7,
        }));
        ctx.globalAlpha = p.panic * 0.18;
        const savedV2 = s.origVerts;
        s.origVerts = pverts;
        s.draw(ctx, p, lightDx, lightDy);
        s.origVerts = savedV2;
      }
      ctx.globalAlpha = 1;
    }
  });

  ctx.restore();

  // ܴ̃᚜͇̓༂̋̌ᚊ̘̹ܘ͍ᚑ̨͎̎ᚚ́̿̏ჶ̨̯̔ሦ͋ᚚ̱̬̃́༿͉ም̔𒁆̗̭̀
  if (p.convergence > 0.08) drawPortraitGlow(ctx, W, H, p, t);

  // 𒀄̰༗̖̯შ͌თ̝ܭ̩̂̇͋𒁌͉̍𒀁̥̀༕̙̦̋ძ͌́ሯ̩̉̌ላ̰͊̀͋ᚔ̽კ̜̄̈༏̓̎̚
  if (p.convergence > 0.28) drawEyes(ctx, W, H, p, t);

  // ᛛ̧ჟ݆̟̒̔̀̆̃༏̗̤̚ቁ̪̫̯ሌ̃̂ܠ̡̙᛫̯ܴ̈̔̔̇͂ᚫ̪ܾ̭̞̙̽̄ͅܡ̪̯̖ሁ̟̝͆̐ሺ͆̕პ̡͉ܸ̲͂̏́̏ܪ̄ᛅ̼ჶ̔ሩ̡༿̲̩́༻͈̞̋̕
  drawHoverWounds(ctx, W, H, t);

  // ქ͉̝̥̿ܯ̢༘̣̲̳̉̌ხ̦𒀝̠༜̢̢̘̱̲̟̏݇̍ ̠̫̈́ᚄ͇̽̋𒀦̱́̏̓ᚏ̂̇ረ̬͂̋ͅᚗ̰͊̓͂ᛩ͌͋̕ჩ̗̽̾།̓༃̇̑̾𒀐̘̮̯ᚉ͇̏́༕̳̼̭༫̱̗𒀥̙̣̏̈ᛎ̡̨́́
  drawHeatScars(ctx, W, H, p, t);

  // ܸ͈̿̊̚ვ̾ሁ̏̾༟̱̫̼̦ᛏ̙͉̈𒀿̼̜̯ܐ͍̅𒁀̫́ᛰ̝̞̯̄ᛘ༹̗̌̓̓͊͌ᚱ̝̹̓̉ሁ̤ᚯ̄ᛘ̼̆ᚒ̠͉̀̈́ᚋ̩́ჰ̳̰̾̀ᚬ̮̭̯ძ̓̕ሐ͍༤̻ᚱ̗̠̅ვ݂̋́͂༒̲̈ჭ͂
  drawCursorTrail(ctx, W, H, p, t);

  // ᚂ̧̘̃̊̿݇͆̊ͅღ̘შ̮ᚍ̻͂̆̓ჩ̆͌𒀤̲ܷ̥ᛢ̤̓།͍̻༻̡̌̆ᚈ̱̀ᚆ̧̥͌ͅܠ̳̖̦̚ᚵ̝̋̄̈
  drawMotionAnatomy(ctx, W, H, p, t);

  // ሂ̻̱͉ቈ̕𒁂̨ᚕ̐̐༈̨͉̞̮𒀝̘̏̾༎̤̤̘̿ჹ̻̀
  drawFingerTrails(ctx, W, H, p, t);

  // ሿ̩̑̍̌𒀃͍ჰ̘̑̈́ᚹ͍͇ღ̨̬̐̐ܛ͆ᛎ͈̑̿̽ᚁ̞̥̘̥̽ܰ̎̀ሴ̉ზ̧᛭̝̓́̕𒀨̑̋ᛌ̧̨̘ላ̱̣̟̏
  drawScarGhosts(ctx, W, H, p, t);

  // ݂͌༿̎̅̏ᚒ̞̎ܥ̿𒁈̤̇̒ܕ̢̳͇̟݆̳̃ͅᛄ̡̩̋𒁄̰͋ხ̮̀რ̇༉̧༧̨̇ሃ̖͇ᚅ̤̯̳̈́ჟ̲𒀽̓რ͉𒀈ͅ𒁏̡༹̪̯̙̓̿̿ང̭̹̺𒀷̲ܴ̎̅̌ቂ̽ᛚ͉უ̣̆ᛈ͈̠ͅ༌̡𒀈̳̲̒̃ᛆ͎ᚭ̾̕ᚖ̲̊́༂̬̔
  if (p.typeTremor > 0.15) drawTypeTremorFlash(ctx, W, H, p, t);

  // ܯ̈̐ཀ̇͊ღ͂დ̮༲͎̎ქ̠̉̒ᚁ͈̭͇̮𒀘̦ჱ̽̈́ᛀ̨̮ᚄ̣ᚌ̳̝̑͂༠̞̺̤ᚆ̢͇̿̓༎̧͉̇ሽ̧༹͎̥́̈̒̍ܵ̇̚ང̨̰̞̿ܧ̠̊̿̒ܖ̰̣ܹ̝̏ሸ̧̠ሡ̤̭̄̃̏݊᚜̚ᚄܼ̭̔̾͂ሤ̰̏༬̻̑ᛃ͇͍ᚆ͍̯̇༕̞̔𒀺̗̒́̒ܚ̃̕༟༘̝͊͌
  if (p.erasure > 0.2) drawErasureScars(ctx, W, H, p, t);

  // ༱͌̕ܗ̩̓̈̚ሾ̢༷͉̖̋́̈́ሟ̡̨͉̅𒀡̭̀̊̇
  drawCrackMap(ctx, W, H, p, t);

  // ᚊ̠̑̅̍𒀓̡ჯ̲́ͅ𒀹̙̽̑ᛐ̩̏̇̔ሓ̡༙͊̚𒀜̣̙̃
  drawRitualGeometry(ctx, W, H, p, t);

  // ჴ͉̟ܽᚈ̣̞͊̆ᛐ̦̾͋̕𒀈̺͇ሟ̭̒͊̎་͈̙̓ჹܱ̤̄̌̄͆᚜̪̃ᚇ̜̤ᚌ̤ᚔ̲̗ܷ̜̎̍̕༐̪̦̂ᛧ̳̑́კ͎ჷ̺̅̂́ᛩ̻͎̎ሪ̃̉̕᚜͋ͅᚅܼ̯̪̆͌̀༰̧̿̈́̇ᚨ̼̝̃ც̨̐ᚚ̳ܢ̼ܴ̔̏̑̀ͅრ̱ᚾ̮̗̂̀𒀈̻
  if (p.smear > 0.05) drawSmearOverlay(ctx, canvas, W, H, p);

  // ᛬̯̪ሼ̹̗̈ሺ̫̄͂ሰ̬𒀲̒̓̇̾ხ̪̻́𒀃͍̋ᚑ̻̼̑ሲ̘̾͂̉ܺͅܛ̥̮ቃ̥̇̉ል͆ᚑ̀̊̏̈́ჩ͆უ̞̻͇͊ܭ̊ཁ̯̫͊̚༨̣̱̕ͅ𒀇͊̚ᚔ̪̪̒ܧ̨̓̕ᚍ̻̃ᚇ̓
  if (p.drowning > 0.01) drawDrowningHaze(ctx, W, H, p, t);

  // ཆ̻̟̿ჳ̭̻̇ܖ̰̠͊𒀧̩̥͋́ᚉ̬̦ܸ̓̎̕ც̫̞̂༸̑ᚖ̻̮̆𒀳̢̀́̎ᛎ͌ᚔ͍̈𒀕̝͂̍ܠ̱̞̘ᚔ̲ᚇ́ͅሰ͉̪̍ᛨ̈𒀵̦̽ᛇ̪̑ͅჸ̒ᚌ́ሜ̍ཀ̽ᚒ̧༯̿༴͎̆̿̃༞͎͇̓݃͊̐̌ᚔ̄̇ܡ̗̍̓ი͍̭̉ᛦ͎̦̓̈ܢ͈͋͊ሇ͎͊̾
  if (p.resizeInjury > 0.08) drawResizeInjuryFlash(ctx, W, H, p, t);

  // ᚈ͍̺͂͋༴̬̆̏́ཁ͋͋༠̜𒀏̨̳̘͎ܢ̳̩ሉ̏̍ᚃ̱̿ቁ̨͎̃́ܟ༹̺̼̔̓ཀ̰͊̇̚ሣ̭͊̈̔ᚂ̀ܙ̼͊ͅღ͇̹̄ᚷ̓̍ᚺ̨ვ̜̉ቅ̥͉𒀄̭̭̑̒ܥ̝̮რ̐ͅ𒁋̧̳́̾ሣ̯͇შ̢̠̫̃𒁄̘̪̼݁͊̇̒ᚏ̩̺̆̈გ̺̈༳̤̆
  drawNoise(ctx, W, H, p);

  // ༢̘͌༪̘̈̆̚༭̹̳́ܫ̄༭̃͌ᚕ̹̈́̆ᚖ̗̹̭ሟ̯͍͌̈́༆̂კ͉̖̏̓𒁊̔𒀸̞̰𒀶͈̮𒁁̖̪̍༉̭ᚓ̘̩̃̕𒀢̜͇̹ͅᛀ̧̽ᚷ̱𒀌̬ܞ̣͌ሢ̩͉̓̃ᚓ̤ᚣ̙𒀴̽̀̔ራ̥̍́༮̢̪ܙ̙͌̐̂ᚏ͇̘̄̕𒀏̪̾̓ჱ̞̔̉ܭ̣ᚡ̝͆ቁ̙ხ̚༁̡̰̄რ̢̅̅ሽ̓
  if (p.split > 0.08 || p.desync > 0.06) {
    const splitAmt = Math.max(p.split, p.desync);
    ctx.save();
    // ფ̨͍̻𒀺̬͍̠͉ᛈ̩̝͎𒀭̚ჯ̳͍̦̋༮̖ზ̺̋ሡ̑̔̓ང͆̆༐̲̂̓̔ሪ̻̽͆𒀁̺͉͆̔𒀸͍̖̬̻ሹ̆ܬ̼̼ܱ̞̭ᚠ͉̍͆ሶ̨͇ሯ̠̙̿ܫ̡͋༆̑ܐ̀̂ሌ̘͊̐̓ሹ̝̻̂𒀩̄უ̺̌̇ͅሙ̓პ̋
    ctx.globalAlpha = splitAmt * 0.10;
    ctx.globalCompositeOperation = 'screen';
    ctx.translate(splitAmt * 11, p.desync * 3 * Math.sin(t * 2.1));
    ctx.drawImage(canvas, 0, 0);
    // ᚔ̬̋͆̈ቁ̠̜̯ረ̅̀ቈ̉𒀃̖ᚆ̆༚̡͍́ͅ𒁅̜̪́͌ܥ̝ᚢ̘̩̏̑შ̳̲̏༲̩̠̾༾̪̣͋ሕ̲̄ჷ̡̪̆̊ሷ̹̪̱ძ́ᛢ̻̀̏ܘ̱̕̕
    ctx.translate(-splitAmt * 22, -p.desync * 6 * Math.sin(t * 2.1));
    ctx.globalAlpha = splitAmt * 0.06;
    ctx.drawImage(canvas, 0, 0);
    ctx.restore();
  }
}

function drawPortraitGlow(ctx, W, H, p, t) {
  const shift = p.skeletonShift;
  const cx    = W * (0.5 + shift);
  const headY = H * (0.270 + p.sinkDepth * 0.06);
  const pulse = 1 + Math.sin(t * 1.4) * 0.03 * p.pulse;
  const e     = p.env;

  // ლ̣̅̐ᚃ̨𒀓̧̮̅͆ᚒ͍̋̒ᚃ́̀̒̋ი͆̈́ძ̽ܪ̞̽̾̾ሸ͈𒀈̖͇གྷ̈́ቆ͍̲͆𒀕̡̢̔ል̢̞ᚯ̬̄ჶ̫͌ᚭ̫͇̄́ም̝̙̒𒀶̧̡̟̙̭̺ܰ̊ᚎ̨̘͆̈́༸̨͇̓ͅሎ̖პ̅̆ͅሐ̥̀̑ᚹ̥̣̳̌
  const headR = Math.min(W, H) * 0.145 * pulse;
  const hg    = ctx.createRadialGradient(cx, headY, 0, cx, headY, headR);
  const ha    = p.convergence * p.brightness * 0.18;
  hg.addColorStop(0,   `rgba(${e.paletteR},${e.paletteG},${e.paletteB},${ha})`);
  hg.addColorStop(0.55,`rgba(${Math.floor(e.paletteR*0.64)},${Math.floor(e.paletteG*0.69)},${Math.floor(e.paletteB*0.78)},${ha * 0.38})`);
  hg.addColorStop(1,   `rgba(${Math.floor(e.paletteR*0.64)},${Math.floor(e.paletteG*0.69)},${Math.floor(e.paletteB*0.78)},0)`);
  ctx.fillStyle = hg;
  ctx.beginPath();
  ctx.ellipse(cx, headY, headR, headR * 1.22, 0, 0, Math.PI * 2);
  ctx.fill();

  // ს̺̓̚ቀ̽ሺ̺̙̈̍ჭ̢̘𒀷̲̀̏᚛͎̋̉ვ̙̓𒀭̡̘͍̜ር̠͉̊ͅᚙ̨თ͍̹͆̚ሷ͎̦̹̉
  const shY = H * (0.490 + p.sinkDepth * 0.06);
  const sg  = ctx.createRadialGradient(cx, shY, 0, cx, shY, W * 0.26);
  const sa  = p.convergence * p.brightness * 0.09;
  sg.addColorStop(0,  `rgba(${Math.floor(e.paletteR*0.84)},${Math.floor(e.paletteG*0.86)},${Math.floor(e.paletteB*0.91)},${sa})`);
  sg.addColorStop(1,  `rgba(${Math.floor(e.paletteR*0.84)},${Math.floor(e.paletteG*0.86)},${Math.floor(e.paletteB*0.91)},0)`);
  ctx.fillStyle = sg;
  ctx.beginPath();
  ctx.ellipse(cx, shY, W * 0.26, H * 0.068, 0, 0, Math.PI * 2);
  ctx.fill();
}

function drawEyes(ctx, W, H, p, t) {
  const shift  = p.skeletonShift;
  const cx     = W * (0.5 + shift);
  const eyeY   = H * (0.258 + p.sinkDepth * 0.06);
  const spacing = W * 0.052;
  const e      = p.env;

  // 𒀶̟̰̓̈ᚯܑ̟̟͊̾̒̋̓ᚐ̢̈́̇ͅᛞ̦ᚍ̣̜̲̊ტ̲̅̊̀ሊ͌𒀵̄͋გ͍́̆̕ᚗ̢̭̏ܘ̝̒ཁ̟̍ც̻̇̽ͅ𒀾̪̥̃̍ሷ͈͈̕ܧ̻̰̀̄༤͎́ᛚ̻̾̈̕༒͂̂̈́𒀀́̆̚𒀻͋ჭ̭͇̇ܰ̑ሢ͈̀̌𒀋̥̠̊ᛄ̺̂̈ჰ̘̾ቆ̥̰͉̳ሔ̢ჲ̻̊ᛪ̪́ͅ𒀨̞̼̽༶̞̲̘̔
  const blinkPhase = Math.sin(t * 0.53) * Math.sin(t * 1.3);
  const blink      = blinkPhase > 0.96 ? 0 : 1;

  const baseAlpha = p.convergence * (0.22 + p.eyeIntensity * 0.55) * blink;

  // ც̹̟ሚ༵̜̜̱̓͊̎ᚇ̝̗͎𒀩̝̖́̒ሓ̰͇̣𒁌̡̍ል̬̟ᚖ͆ᚮ̡̮̳̈გ̬༂͇͍̑̅𒀷̤̰̀
  const eyeScale = 0.85 + e.intimacy * 0.3;

  for (const side of [-1, 1]) {
    const ex = cx + side * spacing;
    const ey = eyeY + Math.sin(t * 0.18 + side * 0.8) * H * 0.0025 * e.motionScale;

    const targetX = state.mirrorCursor.x;
    const targetY = state.mirrorCursor.y;
    const lookX   = (targetX / W - 0.5) * W * 0.004 * side;
    const lookY   = (targetY / H - 0.5) * H * 0.003;

    const egR = W * 0.026 * eyeScale;
    const eg  = ctx.createRadialGradient(ex + lookX, ey + lookY, 0, ex, ey, egR);
    eg.addColorStop(0,    `rgba(${e.paletteR},${Math.min(255,e.paletteG+37)},255,${baseAlpha * 0.92})`);
    eg.addColorStop(0.28, `rgba(${Math.floor(e.paletteR*0.84)},${Math.floor(e.paletteG*0.95)},${Math.min(255,e.paletteB+20)},${baseAlpha * 0.52})`);
    eg.addColorStop(1,    `rgba(${Math.floor(e.paletteR*0.84)},${Math.floor(e.paletteG*0.95)},${Math.min(255,e.paletteB+20)},0)`);
    ctx.fillStyle = eg;
    ctx.beginPath();
    ctx.arc(ex, ey, egR, 0, Math.PI * 2);
    ctx.fill();

    // ᚔ̩̦̗𒀩̩́̔༯̝ᚔ̞́̓͋𒀠̺̘̉ሀ̣̹̏̌༚̉̅
    if (baseAlpha > 0.05) {
      ctx.fillStyle = `rgba(4,4,10,${baseAlpha * 0.88})`;
      ctx.beginPath();
      ctx.arc(ex + lookX, ey + lookY, W * 0.006 * eyeScale, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  // ᚌ͉̰༰͍̩̤ܱ̤̺ቈ͋ᛙ̮̯̕ܫ̰̬̎̍𒀆̽ფ̄༺͍́̓༗̩ტ̏̽ͅᛂ̀̚𒀕̹̒༟͋༿̘ᛨ̏𒀮̕ᚋ̪̤̺͋ᚿ̪ᚴ̦̿̓ͅზ̨̉̄̚༱̨̻̈̍༄̇ᚏ̟͇ራͅუ̋͋̀̚ჰ̦̮̓̔ᛩ̹̭̝ሡ̤͌̓́ሞ̻̼ᛣ̰̺̀̈ሯ͂̅ለ̻͂̀̏𒁆̭̳͂̀
  // ܹ̌́͆𒀟̿̏ሆ̀ሽ͍̮͍ሗ̑̌̆́ᚂ̞̦ᚗ̢̾̓ስ̢̪
  if (e.secondaryEyes > 0 && p.convergence > 0.35) {
    const secAlpha = p.convergence * 0.08 * blink;
    const secPositions = [
      { x: cx - W * 0.18, y: eyeY + H * 0.12 },
      { x: cx + W * 0.19, y: eyeY + H * 0.08 },
      { x: cx - W * 0.08, y: eyeY + H * 0.28 },
    ];
    for (let i = 0; i < Math.min(e.secondaryEyes, secPositions.length); i++) {
      const sp = secPositions[i];
      const sr = W * 0.012;
      const flicker = Math.sin(t * 0.7 + i * 2.3) > 0.4 ? 1 : 0;
      if (!flicker) continue;
      const sg = ctx.createRadialGradient(sp.x, sp.y, 0, sp.x, sp.y, sr);
      sg.addColorStop(0,   `rgba(${e.paletteR},${e.paletteG},${e.paletteB},${secAlpha})`);
      sg.addColorStop(1,   `rgba(${e.paletteR},${e.paletteG},${e.paletteB},0)`);
      ctx.fillStyle = sg;
      ctx.beginPath();
      ctx.arc(sp.x, sp.y, sr, 0, Math.PI * 2);
      ctx.fill();
      // ძ̢̪̩̮̪̲̙̐݀ᚙܑ̨̭̺̃̕ჰ̤̣̓̒𒁋̆̔ܕ̱̊̃གྷ̍ሚ̘͌ͅᚡ̠̭͉̐ቈ̡̖༷̪͂̕༡̰̀ნ͇͂̕ܥ̇ᚐ̩̈́͋ል̝̔́̕ს̼̺̟̍༼̖̳༷̂̀ͅ𒀷̨̅ስ̾ስ̽̇̆̚𒁋̦̑ჟ̡̏͋̈𒀶̯̫̜̐თ͍̭̙̐݅̎მ̡̘̘͍ᚆ̗̰̣́ᛮ̬̇ს̺ᛰ̱͎̎̒༡̗́𒀗̞͌̚ქ͈𒀢̩̊ሣ̘𒀈̖̓͆̄ჭ̤̰
      ctx.fillStyle = `rgba(2,2,5,${secAlpha * 0.6})`;
      ctx.beginPath();
      ctx.arc(sp.x, sp.y, sr * 0.35, 0, Math.PI * 2);
      ctx.fill();
    }
  }
}

function drawHoverWounds(ctx, W, H, t) {
  for (const hp of state.interaction.hoverPoints) {
    if (hp.intensity < 0.04) continue;
    const x  = hp.x * W;
    const y  = hp.y * H;
    const age = hp.age * 0.001;

    // ܤ̰𒀩̯̊̀መ̜༛̢̩͎̓ሆ̨̨ܘ͊̇ܜ̣̓̇̍ሞ̍̔ყ̝̥ᚚ̍̿ჸ̹͇̏͌ܣ̢̄̄༼ܴ̗̥̜̂̿ᛑ̂ᚍ̰̖̑̋ᚴ͉༵̗̞̓̆́ሎ͌̄ᚗ̈̿𒀄͂̑ᚭ̼ᛇ̪̝̌̂ც̖ჱ̩̑̇ᛨ͎̤̦̓༨̹̅༞̯̙̆̓ᛙ́ᚊ͎̆̔̈́ሼ̭ᚘ̩̒̕̚ჟ̐̇̽
    const bloomR = 34 * hp.intensity + age * 4;
    const warmth = Math.min(1, age * 0.3);
    const bR = Math.floor(205 + warmth * 50);
    const bG = Math.floor(200 - warmth * 40);
    const bB = Math.floor(252 - warmth * 120);
    const bg = ctx.createRadialGradient(x, y, 0, x, y, bloomR);
    bg.addColorStop(0,   `rgba(${bR},${bG},${bB},${hp.intensity * 0.42})`);
    bg.addColorStop(0.4, `rgba(${bR},${bG},${bB},${hp.intensity * 0.18})`);
    bg.addColorStop(1,   `rgba(${bR},${bG},${bB},0)`);
    ctx.fillStyle = bg;
    ctx.beginPath();
    ctx.arc(x, y, bloomR, 0, Math.PI * 2);
    ctx.fill();

    // 𒀖͍̓ᚭ̓༅̹̄დ̨̮̈́̎ᚴ̤̟͈̚ᚊ̐ᛇ̾́ზ̀̑𒀁̧ᚐ̯݈̏̀̚ჶ̝ሶ̔̾𒁁̥̝̏
    const coreR = 8 * hp.intensity;
    const cg = ctx.createRadialGradient(x, y, 0, x, y, coreR);
    cg.addColorStop(0,   `rgba(240,245,255,${hp.intensity * 0.55})`);
    cg.addColorStop(0.6, `rgba(220,230,250,${hp.intensity * 0.22})`);
    cg.addColorStop(1,   'rgba(220,230,250,0)');
    ctx.fillStyle = cg;
    ctx.beginPath();
    ctx.arc(x, y, coreR, 0, Math.PI * 2);
    ctx.fill();

    // ༵̤́̽̈́ᚮ̙̒ሤ̀̍́ტ̓̎ܚ̳̙̝̇ሏ̢ͅ𒀩̙ܻ̼͊̎̓ჷ͍̉̌ሼ̮̩ሗ͉ᚣ̀̀𒁉͎ܼ̼̊̑͋ሌ̢̝̐̌ሚ̥༰̮̖̩͇ჰ͆̀ᚘ͊ሯ̪͍̹ܯ̰̖̣̀ᚃ̕̕ሑ̼̂̿̎༌̞
    if (hp.intensity > 0.45) {
      const pupilR = 2.5 * hp.intensity;
      ctx.fillStyle = `rgba(2,2,8,${hp.intensity * 0.6})`;
      ctx.beginPath();
      ctx.arc(x, y, pupilR, 0, Math.PI * 2);
      ctx.fill();
    }

    // ჺ̟̍ᛖ̥̲͌𒀹̋̔̽ᚮ̣ሖ̩̟̙̦݁̏ᚌ̣̗̾ლ̫͍̙̓ე̺̘̗̎𒀜̡̼̣ͅཇ̾̒უ̰̰̍ረ̲͉͂́ᚒ̗̕༴̅̉ͅუ̳̾̍ᚎ̥́́ᛤ̰ͅᚐ̕ი͍̍̂𒀄̨̜̭̒ܐ̱̿̆𒁍̊ܖ̹̾ᚄ͉ܙ͌ͅჹ͉̦̀
    if (hp.intensity > 0.25) {
      const ringR = (16 + Math.sin(t * 2.4 + hp.x * 10) * 4) * hp.intensity;
      ctx.strokeStyle = `rgba(200,215,245,${hp.intensity * 0.14})`;
      ctx.lineWidth = 0.8;
      ctx.beginPath();
      ctx.arc(x, y, ringR, 0, Math.PI * 2);
      ctx.stroke();
    }
  }
}

// ም͊ሒ̘̃̋𒀻̀ሩ̢͈͆ᚐ̽𒁎̧𒁋̡̞̙ᚙ̮͉͆𒀁̗𒁌̗̯̀̀ܭ̟̥̂ͅ𒀓̐̇ჳ̆༎̭̊̉ᚸ͈̘̔𒀴̯ቃ̩̎̉ᚕ̯̞̝͋༯́̔ቁ̳ᚂ̺̱́̾༳̡̝̍̒ሂ̧̔̽𒀊̩ᚖ̟̒𒀷͉͆᛭̟̮̣̅ሳ̒༚̧̇́̐𒀥̬ͅܭ̹რ̖̾༶͈̝̞༤̢̺̈́ሢ̰კ̲̏ნ̗̂ჲ̋̽
// ᛔ̗ᚑ͈̍̽།̔ლ̖̏̏ܢ̢̯༜̝̪̙̓ᚆ̪̳͌̋ር͉̘ͅᚰ̟̑̕𒀢̞̘̃ሎ̤ᚚ̠მ̅̈́𒀡̱̖̼̲
function drawTypeTremorFlash(ctx, W, H, p, t) {
  const shift = p.skeletonShift;
  const cx    = W * (0.5 + shift);

  ctx.save();
  ctx.globalAlpha = p.typeTremor * 0.35;
  ctx.strokeStyle = 'rgba(200,215,240,0.6)';

  // ༞̣𒀺̩̐მ̥̒ᚸ̧̼ܸ̺̐̑̒ᚘ̲͂𒀜̪̜༘̗̓̓͂༧̪ܷ̝̪͊̓̌ሆ͌́ᛩ̃͊̔𒁎̏ሼ͎̐ᚎ̠݂̘̘̽ჸ̾̑𒁌̠͈̇̒ሄ̡̍ᛀ͎͍𒀖̄̑
  const ribCount = Math.floor(p.typeTremor * 6) + 1;
  for (let i = 0; i < ribCount; i++) {
    const ribY = H * (0.53 + i * 0.025);
    const ribW = W * (0.06 + p.typeTremor * 0.04);
    const flicker = Math.sin(t * 18 + i * 2.7) > 0 ? 1 : 0;
    if (!flicker) continue;
    ctx.lineWidth = 0.5 + p.typeTremor * 0.8;
    ctx.beginPath();
    ctx.moveTo(cx - ribW, ribY + (Math.random() - 0.5) * 2);
    ctx.lineTo(cx + ribW, ribY + (Math.random() - 0.5) * 2);
    ctx.stroke();
  }

  // ቆ̈́͂̑͂ᚣ̹༲̙͍ᚺ̀̾ᚊ̘̠̏ᚄ̮̒ბ̿ሿ̟
  const jawY  = H * 0.375;
  const jawW  = W * 0.042;
  const jawOn = Math.sin(t * 22) > 0.3 ? 1 : 0;
  if (jawOn) {
    ctx.lineWidth = 0.6 + p.typeTremor * 1.2;
    ctx.beginPath();
    ctx.moveTo(cx - jawW, jawY);
    ctx.lineTo(cx + jawW, jawY);
    ctx.stroke();
  }

  ctx.restore();
}

// ሱ͍̏̎ሠ̼𒀁͆𒀓̻ሳ̔̀̓𒀜̳𒀔̪͌̍ა̪̏̍̽ሑ̲ᛨ̤́𒀲̞̎̒ᛮ̡̠͉̗̀̀݇́ܵ̔̈́ვ̩ሼ̤̹̅̆ቀ̙̤ᛔ̥̪̉ᚰ̎̑ნ̟̠𒀼̱ᛞ̗̾̂̃༓͇̗̏̊ሤ̟͉݀͋ᚂ̀ܔ͍̆𒀚̟ᛂ̒ᚋ̬̠̪̿ᚦ͂̋̄̄ᛠ̡ܾ̎༼̝̻̖ჲ͌ჸ̘̾
// ᛢ͂༉̹͆̕༜̡̾݀̂̋༦͍͈̽̿ჶ̰̏̊ჴ̥͎͍ხ̐̚̚ჱ̓̂̆̉𒀠̤̄𒁀̹̹̙̖݇̊̚̚ͅ𒀀̞ᚃ̥̞̣̍რ̧̼̃̍༗̗𒀃̩ሡ̡̧̳̼̯ܶ𒀢̢𒁀̄̕ჰ̊̔ლ͈͂ᛅ̙̑͋̆ჯ̻̆
function drawErasureScars(ctx, W, H, p, t) {
  const shift = p.skeletonShift;
  const cx    = W * (0.5 + shift);
  const seed  = Math.floor(t * 0.3);

  ctx.save();
  ctx.globalAlpha = p.erasure * 0.45;
  ctx.strokeStyle = 'rgba(140,150,180,0.5)';

  // 𒀫̤ᚘ͍̒͊݉̈́ሹ͍̊͌͊ჲ́̊ቇ̋༴̳ᚈ̗ሂ̰̦̍̌༓̥̼̜͆ᚌ̼͆́̀
  const scratchCount = Math.floor(p.erasure * 5) + 1;
  for (let i = 0; i < scratchCount; i++) {
    const sx = cx + (shardHash(i, seed) - 0.5) * W * 0.22;
    const sy = H * (0.22 + shardHash(i + 37, seed) * 0.42);
    const ex = sx + (shardHash(i + 71, seed) - 0.5) * W * 0.10;
    const ey = sy + shardHash(i + 99, seed) * H * 0.08;
    ctx.lineWidth = 0.4 + p.erasure * 0.9;
    ctx.beginPath();
    ctx.moveTo(sx, sy);
    ctx.lineTo(ex, ey);
    ctx.stroke();
  }

  // ༓̆𒁍̼͌́̉პ̑̽̅ᛀ̉̍̊༄̢̈́̑̏ᚑ̂༜̠̃̿̕მ̗̃͊́ܮ͆̑́̚ܖ̯̤̆ܽ̈̉̕ͅ༬̒ቇ̘̞̠̀𒀦ܑ̧̰́̽̀̈́ᛦ̰̈́̐𒀹̺͈ሬ̍༝̳̏ሐ̠̞̼̲ܽ̑̋᛭̈́̊ܙ͈̊̋მ́ር̱̐̈ͅ༁̨̹ლ̭͆
  if (p.erasure > 0.4) {
    const mouthY = H * 0.34;
    const mouthW = W * 0.032;
    const stitchCount = Math.floor((p.erasure - 0.4) * 8) + 2;
    ctx.lineWidth = 0.5;
    for (let i = 0; i < stitchCount; i++) {
      const sx = cx - mouthW + (i / stitchCount) * mouthW * 2;
      ctx.beginPath();
      ctx.moveTo(sx, mouthY - 2);
      ctx.lineTo(sx, mouthY + 2);
      ctx.stroke();
    }
    // ሑ̻̓ᚺ͌ᚉ̋̎̉ͅᚴ͋̚𒁀̡̳ཇ̩̓𒀋̡𒁊̏ሂ̗̟͋ሩ̓ܥ̧̫̭̽𒀚̜̗̈̈༳͎̺̆͌ሩ̜̹ሓ̦̚ᛑ̙̳̎𒀺̣ს̫̌̈𒀭̗̣̕ᛏ͉̍̾ჲ̉̌̀𒀿̐𒁂̺̜̼̫ܹ̃̔ᛉ͈̾ᚘ̢̼̳̣͇́ܳ༨̩͂ᚕ̡༘́̎ᛤ̢݈̗̤̋𒀓̠̆̽̓პ͇͎̣̣༵̂ሟ͉̎͋ᚬ̇ሷ̮̆̒ჷ̧̜̫̖
    ctx.beginPath();
    ctx.moveTo(cx - mouthW, mouthY);
    ctx.lineTo(cx + mouthW, mouthY);
    ctx.stroke();
  }

  ctx.restore();
}

// ༕̝̓̃̾ი̳̫̚ም̰̳ܖ͉̍𒁂̈́༬̰̦̋ᚚ́𒀪̹̞̳𒀷̽ᚄ̩̘̐̽
// ჹ̲̋ᚥ͉̘ܝ̱̬̓̇ܩ͋̓͊ᛅ̼̩𒀍̒̌𒀰͈͂ძ̥̂̉̕ᚡ̪̖̿̀ᚘ̟ ̱̚ᚺ̰̮̔̑ሕ͍ܼ̫̉̔̃ᛩ̥̬̇ܭ͈̫̓̑༗̱̹̒ᚚ̊̾̚ო̢̰̝̂ሷ̣̘ ̺̂ͅ༤͉̌ቀ̙̩̚༒̈ᚲ̫͍̬̍݅༂̖͍̚
function drawSmearOverlay(ctx, canvas, W, H, p) {
  const layers = Math.min(4, Math.floor(p.smear * 5) + 1);
  ctx.save();
  for (let i = 1; i <= layers; i++) {
    const offset = i * p.smear * H * 0.012;
    ctx.globalAlpha = p.smear * (0.08 / i);
    ctx.drawImage(canvas, 0, offset);
    ctx.drawImage(canvas, 0, -offset * 0.5);
  }
  ctx.restore();
}

// 𒀭ܹ͎̊̅̚ᛃ̻̙̋ͅᛘ̹͋𒀼̗͋̌ᚹ̧̟̐̀ᚯ̤̂̾̾ჱ̙̍ͅ༞̄̕ማ̢͍̌𒁌̩̦͌̚ჺ̫̻̜̈დ̰͌რ̤̥͇̟
// 𒀫̬̱̻͋༦͉͎̦ܰძ̜̙̉̋𒀑̊̄̉ᚓ̤̔̏ͅቇ̆გ̻ᚊ̧̤̒ᛡ̱̺ᚔ̡ᚪ͉̪̖̒ᚗ̱ሮ̃༕̧𒀄͇̥̾༕͋̏ვ͍͂ܨ̙̯̅̽ᚕ͍̜̗̈ტ̧́ག̠̳ͅ༺̱ܕ̨ሑ̔̎ᛃ̣̭̟̕༮̬𒀮̱𒀾̡̫̠ܣ̪̼ᚒ̕༊̦̉̈̔ᛍ̙ܸ̠ͅᚙ̰̥ნ̢̏ჩ̲͇დ́༻̢̦̣̀ᚅ̢̭
// ᛇ̧̼̇̚ܖ̥̝̣݂̃͋̋ფ̫̀ሴ̘̓̆ᛛ͈̆༾̨͇̂𒀞̘̔ͅᛩ͉̳̑̄ༀ̹ჸ̾͋ᚓ̨̬͋ሜ̡̲̤̇ყ̻̌ი༙̔̊̽ᛄ̻༠̨̲̪̗̀̒ܺ̽ᚘ̐̏̈́ܯ̳͈̓ሳ̨̔ᚉ̯̙̀༻͇̻̺̆ᛜ̯̂݀̅̈́̉𒀪̘ᚒ̠̩ᚖ̋𒀞̅̈́͌̋ᛘ̭̦̦̍ሑ̠̈́ᚑ̮̞̈́̊𒀵̰́ქ̰͇݊ሒ̼̲̐̅𒀱̭̠́ሷ̇́
// ᚈ̟̭͂̃წ̍̿ჰ̳̤̬̅ᚶ̝̝̿ᚊ̜ᚮ̭͇̟̞͈̍݉𒀯̍̓ܛ̪̈́༜̠̳̓ͅ༔̧͉̏̀ᚬ̙͍̊̊ყ̣̉́ለ̑ᚄ̮
function drawDrowningHaze(ctx, W, H, p, t) {
  const d = p.drowning;
  if (d < 0.01) return;

  ctx.save();

  // ܔ̹̀༉̧ᛤ̹ᚏ͎̐̌͆ᚼ̢̖̘̓ღ̄̎̅ሀ̲ჭ̩̾͂𒀄̬𒀗̘̣̏̋ረ̨ͅᛪ̏ᚸ̞̩ܟ̨̃ჭ̦ͅ༭̖͍̮̂ᚿ͇̬̦ძ̎𒀘̅̆̓ᚳ́𒀎̺̺̕ቅ̹̽̊ჯ̪ཀ͍̅ͅ༿̲ܤ̞̍ͅ༌̜̫ᚿ̲̹̪́᚜̓̽̆ც̡̯͆̇
  const waterFrac = 1 - d * 0.65;           // ܸ̉ቇ̳̩̑̑ሔ̡̻༣̞̌ტ̭̟͇გ̖̻̑ሤ̪ሧ̧ܡ̝̮ᚄ̜̪͇̲ܗ̥ᚫ͎͋̆ჟ̧̽̏̓ᚘ̘̓ܕ̬̦̀ሲ̱ᛞ̥̂ᚖ̻͂ᚱ̤ᚊ̧༨̩̾კ̰̯̋ᚊ̨̨ᚘ̭̔ᚓ͎̪̜̿ሩ̯̣͋̂༾̬ቅ͈̊̿ᚒ̼̜̃̈́ᚘ̻რ̳̕
  const waterY    = H * waterFrac;

  // ᚛́̊͌ᚘ͈ሦ̗̯͂ᛆ̗̦͋͌ᛗ͈̊ქ̧̙̍́ሩ̫ሠ̼̯́ხ̫̍̏ͅ𒁊̧̰̘̿̀݃̀̇ሡ̞̔̚ሂ́̄ͅᚒ̢̰༄̧̮ܧ̢̪̪̅ვ̖̃ᛃ̯̗̖̙̈݁݊̓ᚚ݄̰͊̇݀̂̈́ᚴ̲̤༮̏͂᚜̞̒̑༆̮͍ܾ̜̅̕𒀙̩͌̑ཀ̽̚გ̟̕ჴ̝͎̊ͅሎ̼̳̉̐მ̖́ᚈ̪̣̉̄ᚘ́ᚤ̖̋̎ሡ̲̺̹
  const waterGrad = ctx.createLinearGradient(0, waterY, 0, H);
  const waterAlpha = Math.min(0.88, d * 0.85);
  waterGrad.addColorStop(0,    `rgba(1,2,6,${waterAlpha * 0.3})`);
  waterGrad.addColorStop(0.15, `rgba(1,2,5,${waterAlpha * 0.6})`);
  waterGrad.addColorStop(0.5,  `rgba(0,1,4,${waterAlpha * 0.82})`);
  waterGrad.addColorStop(1,    `rgba(0,0,3,${waterAlpha})`);
  ctx.fillStyle = waterGrad;
  ctx.fillRect(0, waterY, W, H - waterY);

  // ᚐ͈̀ᚒ͊ჟ̡̧̼̒ቅ̪̆ᛗ̱́̿𒀦̌𒁉́̕ჩ̬̝ზ͇̗̆ჸ̥̀ᚋ̨̲̿̑གྷ̊̈ჭ͈̿̈ሎ̹̦̖͂ჲ̙͈̹̒ც̌̀͋ܕ̻͉́ᛇ̰̀̚ሧ̘̇᚜͉̇̒ჶ̈ܞ̳̖̈́ჯ̜ܸ͇̞̋̿̅༄̞̀ཇ̔̿̅ሳ̤̾̋́ᚘ̇
  const hazeH = H * 0.12 * d;
  if (hazeH > 2) {
    const hazeGrad = ctx.createLinearGradient(0, waterY - hazeH, 0, waterY);
    hazeGrad.addColorStop(0, 'rgba(1,2,6,0)');
    hazeGrad.addColorStop(1, `rgba(1,2,6,${d * 0.25})`);
    ctx.fillStyle = hazeGrad;
    ctx.fillRect(0, waterY - hazeH, W, hazeH);
  }

  // შܑ̮͋̎ሊ̠ᚅ̡̥́ᚄ̺̄პ̡̜̘ܹ̏̏༳̼̙ͅჰ̡̰̉༐̳༣̾
  if (d > 0.05) {
    ctx.strokeStyle = `rgba(140,160,200,${d * 0.18})`;
    ctx.lineWidth   = 0.5 + d * 0.6;
    ctx.beginPath();
    for (let x = 0; x <= W; x += 4) {
      const ripple = Math.sin(x * 0.02 + t * 1.2) * 2.5 * d
                   + Math.sin(x * 0.035 + t * 0.7) * 1.5 * d;
      const py = waterY + ripple;
      if (x === 0) ctx.moveTo(x, py);
      else ctx.lineTo(x, py);
    }
    ctx.stroke();
  }

  // ܱ̈̆͌ሖ̗ჩ̓ܬ̥ᚾ̀ᚪ̍̈́ᛎ̩̋̃ሆ̩ͅሆ̗̹̇ჹ͇̃ᛋ̡̹͎̿კ̲̩͉ܺሊ̯̾ჭ̨͉݈̟̘̭̐͂𒁀̠̈́͂𒀌̮̜̮ᛈ̡̡̩̐ბ̢̊̆ሙ̱ቁ̪͈༄̨̘̞ܷ̏͂̅̎𒀾́ᛂ̻̻͋͆თ̅༫̩̘͌ܧ̀̽𒀗̳ቂ̱̩̀ͅო̓͌༣̯ܹ̲̰͉̜̉𒁀̭̈́݅̕༻̫̳̏ܢ̔თ̗̋̄͆ሴ̈
  if (d > 0.3) {
    const topWash = (d - 0.3) * 0.14;
    ctx.fillStyle = `rgba(2,4,12,${topWash})`;
    ctx.fillRect(0, 0, W, waterY);
  }

  ctx.restore();
}

// ቂ̻𒀖̖́ቃ̲̹͋ͅᚢ̠̼̀̌𒁏͇̭̹͂ܡ̧̋ᚒ̟ᛝ̗̓ᚚ̟𒀵̔̽ᚁ̤ᚖ̭ሿ̫̉ᚐ̨̱͍
// 𒀅͉̣̗ჲ͊̓̋𒀹̯̕ͅ𒀬͇̲̱̲𒀞̡̨̺̮ሕ̀̚ᚙ͇ს̨̻ሾ͇̬̍ͅ𒀯̖̼͆𒀷͍̪༧̺͇ᛒ̧̀͌ᛪ̝̌̀᚛̂ሐ̣̠̐ͅჴ̨̖͊ᚢ̈̄̽͋ሼ̼̝͊ܝ̟̬̭̚ᛣ̠̈́̾ܐ̫̿̐̈́ჱ̼̝̕ܬ̖̲̓̕ი͉̪༄̰ᛌ͍̇̈
function drawResizeInjuryFlash(ctx, W, H, p, t) {
  ctx.save();
  ctx.globalAlpha = p.resizeInjury * 0.6;
  ctx.strokeStyle = `rgba(220,230,255,${p.resizeInjury * 0.7})`;

  // ᛙ̨̪ͅᛃ̠͍̼̅ᛰ̟̍ე̱̱ረ̗ᚼ̫̿ᚊ̅̏̕ᚔ͆𒀕̼̻̔̀ܠ̣͎ሮ̻͍̥ሽ̘͌̓̑༠̧̱̩ܳ༭̄̆
  const cx = W * 0.5;
  const cy = H * 0.4;
  const crackCount = Math.floor(p.resizeInjury * 6) + 2;
  for (let i = 0; i < crackCount; i++) {
    const angle = (i / crackCount) * Math.PI * 2 + t * 0.5;
    const len   = p.resizeInjury * Math.min(W, H) * 0.15;
    ctx.lineWidth = 0.6 + p.resizeInjury * 1.5;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(cx + Math.cos(angle) * len, cy + Math.sin(angle) * len);
    ctx.stroke();
  }

  // 𒀺̤̿༳̉̿ܧ̯ሠ̃ᚃ̠̫̙ᚂ̖̰́̿༄̹͉̮̑ლ̱̊ᚧ̅ᚼ̡̺̈ቆ̦̺̾ᚽ̮𒀽͉ზ͎̫͎̇ᚾ̡̅ ͍͊̇̔ჭ̥̼́́ཇ̡̨̯̈́
  if (p.resizeInjury > 0.5) {
    ctx.fillStyle = `rgba(255,255,255,${(p.resizeInjury - 0.5) * 0.08})`;
    ctx.fillRect(0, 0, W, H);
  }

  ctx.restore();
}

function drawNoise(ctx, W, H, p) {
  if (!state.noiseFramePool.length) return;

  state.noiseCounter++;
  if (state.noiseCounter % 3 === 0) {
    state.noiseIdx = (state.noiseIdx + 1) % state.noiseFramePool.length;
  }

  // ሳ̱̫̊̚ህ̦͉̾̎ᚮ̜͆ᚿ̕ᛡ̹̤́ᚰ̨̝̻͊ჰ͉͉̦̊ᚻ͉̉͆ሃ̊
  const grainAlpha = 0.028 + p.env.grainCoarse * 0.025 + p.jitter * 0.035;
  ctx.save();
  ctx.globalAlpha = grainAlpha;
  ctx.globalCompositeOperation = 'screen';
  ctx.drawImage(state.noiseFramePool[state.noiseIdx], 0, 0, W, H);

  // ሃ̲ሶ̠̪̩̓𒀑̤̓̿ሚ̟̎̈́̉ᚎ̱𒀜̼̣̕ᛗ̖͂༳̝̙ܳ̽ᚋ̌̌ᛨ̢̜̺̠݈̱݄̹̓̈́ᚬ̪̕̕༪̦̐̑̂ܧ̧̌ᚿ̰̓ᚾ̧͆̚𒀕̨̙̒༈̊ͅᚕ̗͉̻̌ᚋ̢̰͇̀ሚ̚ᚊ̲̮̗𒀩̘༩͉ᚢ̳̒𒀁͊ང̬͇̑𒀐̑̚ܬ͆̅ለ̑̕ᚓ̀͊༔̌ܝ̢͈͆ለ̮̘͌̇༾̘̮
  if (p.env.lacquer > 0.2) {
    ctx.globalAlpha = p.env.lacquer * 0.06;
    ctx.globalCompositeOperation = 'overlay';
    ctx.fillStyle = `rgba(${p.env.paletteR},${p.env.paletteG},${p.env.paletteB},1)`;
    ctx.fillRect(0, 0, W, H);
  }

  ctx.restore();
}

// ቂ̯̇𒀚̟̾ᚍ̝̟̒̂ሠ̠̎̈́༺̱̋𒀤̗̿პ̞̥̔̓𒁍̽ღ̝͊ᚪ̢̟̝́ܟ̞ᚕ̄ᛑ̢̣̙̊༧̗́͋ᚈ̫̀ሖ̮̜̥̕ܐ̧̞̩͎͊ܵ͋̏̉ܲ𒁌̧̫͎ሂ̤̓𒁌̺̙
// ᛙ̐𒀛̖̑̿ᚍ̫̥͌̄მ̊̿ᚊ̄ც̇́ᚫ̔́͋̕ᚉ̥ᚙ̤̭̀̌ሂ̻̦̹̋ܣ̠̻̾́ᛐ̡͎̥̍ი́͋̒̚ᚍ̰𒀲̜̀ᛄ̇𒀊̓ᚼ͂̕̚𒁍̉̔ܲ̿̈́ᛚ̳ܭ̧̲̕𒁀̳݄̀̔͌ᛪ̬̎
// ༟͇̽ᚖ̐͋̉̿༢̧̧̥̙̠༙̞̺ܦ̬̰̟ᚅ̙͆́ͅ༗̟̳̄̎𒁁̙̥̇̀ᛅ̩̥ᛛ̺̞̋݅̑ሁ̙̥̦༴̗ሶ̨̝͇̐༴̧ܷ̘̻̓͌༰̝ܣ̖ ̥̕ᚬ̉͂ᛆ̬́̓̚༎̢̼༬̼ሚ̡̰ܺ̿ܓ̋

function initGlassRefraction() {
  if (typeof THREE === 'undefined') {
    // ስ̨̬̐ᚎ̌ༀ̬̮დ̆͋̃ᚉ̾ሐ̰̘͂༢̐̕ᛄ̅ᚐܑ̩̻͇̤̉̔ܿ̾თ̲̔ᚔ̑༐̠̀𒀮̧̎̆
    return;
  }

  const glassCanvas = document.getElementById('glass-canvas');
  if (!glassCanvas) return;

  try {
    const renderer = new THREE.WebGLRenderer({
      canvas: glassCanvas,
      alpha: true,
      antialias: true,
    });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const scene  = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(
      45, window.innerWidth / window.innerHeight, 0.1, 100
    );
    camera.position.z = 2.5;

    // ༌͎̠̇̕ᚫ̨̠̎̓᚛̞́ლ̦̌̐ܝ̈̉𒁉̯̍̐ვ̀ჺ̡̲̟̕ᚧ̥͇̞́ܳሇ̣͋͆̋ܿ̒̚༛̻̜༊̩̯͊̓ܘ̏̃༇̬ᚹ͎̘
    const uniforms = {
      uTime:        { value: 0 },
      uConvergence: { value: 0 },
      uCursorX:     { value: 0.5 },
      uCursorY:     { value: 0.5 },
      uResolution:  { value: new THREE.Vector2(window.innerWidth, window.innerHeight) },
    };

    const vertexShader = `
      varying vec2 vUv;
      varying vec3 vNormal;
      varying vec3 vPosition;
      void main() {
        vUv = uv;
        vNormal = normalMatrix * normal;
        vPosition = (modelViewMatrix * vec4(position, 1.0)).xyz;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `;

    const fragmentShader = `
      uniform float uTime;
      uniform float uConvergence;
      uniform float uCursorX;
      uniform float uCursorY;
      uniform vec2 uResolution;
      varying vec2 vUv;
      varying vec3 vNormal;
      varying vec3 vPosition;

      // ᚉ̮̉༠̚᚜̲ს̜̊༞̡̒̃ᛧ̣̂̓̊༮͉̒̓ሽ̟́̐ል̰ᚵ̫̺̃ხ̻̥ܱ̏̐ე̥̠͊̎ሉ̇ᚖ̤̎ܒ̑͊ᚏ͉̽͌̊ܳ͋𒀣͌ሂ̟̇̚ᛊ̂ᚅ̟̩̃ሦ̼͉͆ჱ͎͉͊̌ᚏ̧̇ᛝ͍̫ᚅ̻̪𒁉̟̰̌́᚛̙̣ᚵ̱͌̇̉პ̏̌̈̉ሯ̎̉ᚁ͎̖
      float hash(vec2 p) {
        return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
      }

      float noise(vec2 p) {
        vec2 i = floor(p);
        vec2 f = fract(p);
        f = f * f * (3.0 - 2.0 * f);
        float a = hash(i);
        float b = hash(i + vec2(1.0, 0.0));
        float c = hash(i + vec2(0.0, 1.0));
        float d = hash(i + vec2(1.0, 1.0));
        return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
      }

      void main() {
        vec2 uv = vUv;
        vec2 cursor = vec2(uCursorX, 1.0 - uCursorY);

        // ქ̿ᚁ̯͌ཆ̢ͅ ̥ხ͉༳̡̨̳̪݈̥̏̽𒀢̔ᚻ̫̼͂̊ᛜ̟ሺ̰̲̱̚ሙ̖̼̬̌ᚕ͉̞̀ᛞ̨̱́̾̂݃̒̉̋ሢ͈̎𒀛̓ܐ̼͈̔̀ხ̋̾ል̞ܹ̈͂̅ሩ̡̚შ̢͍̔̕ᛮ̠ჲ͌̈́ᚽ̙რ̫̤͈̻ᚌ̭̝̬̔𒀠̦̫̿ཇ͈̯ᛊ̿̌ᚴ̲̬̓̽
        float distFromCursor = length(uv - cursor);
        float cursorInfluence = smoothstep(0.5, 0.0, distFromCursor) * 0.02;

        // ᛥ̙̒̽𒀴̟ᛀ̋̅ყ̬̾𒀡̎᛬̠̬̳̌༛̻ᛃ̮̀̃̈𒀳̝̟̀̆ტ̘͈ܬ̽ͅტ̧̻̲͋ს̖̱̋̀𒀉̮ͅܭ̇𒀭̨̧̬݄̒ܺ̐̽̀̌̒ͅლ̩̐̾ሬ̰ܢ̾ჱ͌̚𒀑̗̍
        float n1 = noise(uv * 8.0 + uTime * 0.15) * 0.008;
        float n2 = noise(uv * 16.0 - uTime * 0.08) * 0.004;
        vec2 refracted = uv + vec2(n1 + cursorInfluence, n2 + cursorInfluence * 0.5);

        // ᚍ̿̃͊𒀑̫̣̭̆ሞ̡̯̣́ሮ̧̩̊ᚨ̡́ჲ̦͂
        float caustic1 = noise(refracted * 12.0 + uTime * 0.2);
        float caustic2 = noise(refracted * 24.0 - uTime * 0.15);
        float caustics = pow(caustic1 * caustic2, 3.0) * 2.0;

        // ც̫̏̌ᚯ̙̄́ᚂ̄ܧ̺̙ͅ༑̧̲̤͌༟̙ܻ̻̎ሳ̥̲̤͍ᚉ̢༿̢ს̞̱͎ᚊ̻̽ܢ͌͌𒁁̪̤̀̕ჶ͉̮ܾ̅̉̽ჴ̪̽ი̹̖͂̈́݅𒁉̿̌༣̰̠͂̀ܔ̼̕ჸ̫̂̓ს̯̾̐ჰ̩𒀰̨̜̇̅ཀ̝̖́̌𒀵̩̇͋̋ᛨ̫𒀙̻̫̋ᚃ̳̗
        float fresnel = pow(1.0 - abs(dot(normalize(vNormal), normalize(-vPosition))), 3.0);

        // ܔ͈ᛞ̋ე͉ᚈ̆̐ራ͆̃̋̉ᚆܑ̯̯̥̂̓ვ̡̟̩̍ም̡̹̩̿ᚉ̧𒀕͎̿̉ͅ༼̢𒀫̙༔̹͈̀ͅᚤ͍ͅხ̈ሧ̗̗̦̓̊ܿ̋̕𒀊̣̘͋𒀊͉̯𒀮̽ᛑ̗̼̒̿༼͌ሸ̙̽ܲ༣̠̃͌ქ̇̓ཅ̤̟̃ሬ̗͌̽ᛇ̻̑̕ᚉ̼𒀺͎͈͂
        vec3 glassBase = vec3(0.01, 0.015, 0.025);

        // ༡͈̺̈ቂ̮͂ህ̩̬།̢̲̂ᛡ̟༒̚ሸ̘̟̓ᛓ̳̘͊𒀰̝̰͎ᛉ̯̹ᛤ͂ܓ͈̌̔ሆ͊̔ᛒ̡̰̔༕̨̣͇͉̭̟͌ܳ̄ჹ̫̻̌̾ሎ̆ᛢ͍ཁ̢̐̾ლ͆ܨ̘̆̕კ̺ቅ̼̖̿̃༎̤̇ሸ̮̥𒁃̞̰ܡ͈ሌ̆̀͌𒀳̦̃̓ჱ̟̈́̇̅ሸ̣̙̜ܘ̦̫ჵ̮̝̑𒀲̼̘ሲ༷̦̑͌̎́̚༟̖̉ᛋ̤̘̈́̊ᚙ̞͉̾
        float spec1 = pow(max(0.0, noise(refracted * 6.0 + vec2(uTime * 0.1, 0.0))), 8.0);
        float spec2 = pow(max(0.0, noise(refracted * 4.0 + vec2(0.0, uTime * 0.07))), 12.0);
        vec3 specular = vec3(0.45, 0.48, 0.55) * (spec1 * 0.15 + spec2 * 0.08);

        // ͍ܶ̀̏მ̜͎ᛘ̻༒̡̟̼̼ᚉ͉༖̥͎̮̾ჳ̏ᚡ̽𒀺̳ᚼ̜̅კ̉͌ܥ̢͉͈͌ܳለ̰̆̓̏ህ̡̙͇𒀼̺̫̄ͅ𒁊̟ყ͉̮̄̉𒁎̫̒̈𒁃̹̮̀༃̺̓ል̦̥༈̅̽̅̚
        vec3 color = glassBase;
        color += vec3(0.35, 0.38, 0.45) * caustics * 0.12 * uConvergence;
        color += specular * (0.3 + uConvergence * 0.4);
        color += vec3(0.25, 0.28, 0.35) * fresnel * 0.08;

        // ̗̼ܿ̔̾ᛐ̿ሌ́̽ᚈ̜̭̃༭̯̊ᚱ̇ཅ̡̯̠̙̼ܳ̊ჯ̰́̃ܣ̖̇ቄ̾ᚃ̤͈͉̒ი̠͍̅̔ሐ̨̻̗̅ᚹ̡̀ᚾ̝͉͌́ᚎ̌ཅ̗̌ܦ̈́͌ሾ̩́ͅყ̄ᚰ͈̆༪̌ቃ̩̙͊ᚤ̧̕ᛓ̢͋̋ᚂ̋
        color += vec3(0.4, 0.3, 0.2) * cursorInfluence * 8.0;

        float alpha = 0.15 + fresnel * 0.12 + caustics * 0.05 * uConvergence;
        alpha = min(alpha, 0.35);

        gl_FragColor = vec4(color, alpha);
      }
    `;

    const material = new THREE.ShaderMaterial({
      uniforms: uniforms,
      vertexShader: vertexShader,
      fragmentShader: fragmentShader,
      transparent: true,
      side: THREE.DoubleSide,
    });

    const geometry = new THREE.PlaneGeometry(4, 3, 32, 32);
    const mesh = new THREE.Mesh(geometry, material);
    scene.add(mesh);

    state.glass.renderer = renderer;
    state.glass.scene    = scene;
    state.glass.camera   = camera;
    state.glass.mesh     = mesh;
    state.glass.uniforms = uniforms;
    state.glass.ready    = true;

    // ༆̤̣̹ᚩ̨̢͎̆𒀧̪ჟ̖̰̟̞ሮ̩̳̈́ᚐ̢̓༎̳ܓ̡̰̇ᚚ̮̟̲ܭ̩̘
    window.addEventListener('resize', () => {
      if (!state.glass.ready) return;
      const w = window.innerWidth;
      const h = window.innerHeight;
      state.glass.renderer.setSize(w, h);
      state.glass.camera.aspect = w / h;
      state.glass.camera.updateProjectionMatrix();
      state.glass.uniforms.uResolution.value.set(w, h);
    });
  } catch (e) {
    // ܣ͈̿̒ც̯̪͊̒ሓ̱̤̫̔ᚐ̢ᚉ̯̹̬̉̈́ܿ̀̿̚༮̥͌༑̼ܘ̼ም̙̠́ܧ̱̊̀ᚁ͍͇̃ბ̨̗̗̳̽ܽდ̹̣𒀶̭̍̇ᚵ̨̫̦̫̪ܴ̫̘݊̕ሴ͆ᚨ̔̋́̔ሌ͆̀͋ܭ͍͇̑̽𒀶̨݂͍̣̪̎͋
    state.glass.ready = false;
  }
}

function updateGlassRefraction(t) {
  if (!state.glass.ready) return;

  const u = state.glass.uniforms;
  u.uTime.value = t;
  u.uConvergence.value = state.portrait.convergence;
  u.uCursorX.value = state.mirrorCursor.x / window.innerWidth;
  u.uCursorY.value = state.mirrorCursor.y / window.innerHeight;

  state.glass.renderer.render(state.glass.scene, state.glass.camera);
}

// ᛟ̢̜̠̉𒀷̾𒀏̿ᚺ̈́ᚕ̮ბ͈̇ܣ̤̃ნ̼̑ᛧ̺̙̱̉ܿ̀ͅܩ̣̤̈́ᚦ̨̙̝ᚼ̤̹̍ᚆ̪̮༼̌ძ̫̲͇̀ჴ̨͋༮͂̓̓̔ᚔ̐̂ረ̢ᚈ̜͋̄𒁎̯̗͍̃ܥ̪̓̆ܰ̎͆ሀ̠̼̀𒀣̺ܝ̰ძ̍ሽͅ༗̩̟̦𒀺̩͌ი̻̑ͅ

function exportPortrait() {
  const canvas = document.getElementById('mirror-canvas');
  if (!canvas) return;

  // 𒁂̅̍̉ሥ̢̜݈̰̒̅̓ᚰ̡ሦ̩ቂ̟𒁇ܸ̝̻̀̀̈́̓𒁂̿𒀛̇ზ̡ܵ̌̕ᛞ̘͉̔ሜ̹კ̏̓̉ሶ̥
  const link = document.createElement('a');
  const timestamp = new Date().toISOString().replace(/[:.T]/g, '-').slice(0, 19);
  link.download = `mirror-portrait-${timestamp}.png`;

  // 𒀖̖̦̣ͅ༓̢ᚘ̎ሴ̑̒̀ስ̾̍̉ሮ̡̉ᚉ̔ቃ̝͂̋གྷ̏̕ᚉ̗̯́̀ᚌ̌ე̙̋͆ም̉ሜ̯̏̓ჳ̩̻͉།̥ᚲ̳̩̊𒀏̊̆ც̄̽̍̕༫̮̿̎̓ᛋ̭̌ሩ̨̟̓݇̿ለ̹͎̖ᚍ̐ᚄ̩̦͂̉ܩ̗̺̊̑ᚔ̬𒀕̗̦̻̉𒀈̞̜̘̐𒀠̢̺̩ሱ̉ყ̬̚ბ̒̃ყ͎̌ᛝ̡̭݀ͅ𒀝̱̃მ͆ზ̪̠̖͇
  canvas.toBlob(function(blob) {
    if (!blob) return;
    const url = URL.createObjectURL(blob);
    link.href = url;
    link.click();
    // ܾ̙̍̽ܘ͆̉̊ᛗ̱̿̅ᚔ̈́༆̢ܱ̼͎ሳ̽ཇ̓̿მ̨̗̠̏ა̨̺̑
    setTimeout(() => URL.revokeObjectURL(url), 5000);
  }, 'image/png');
}

